{
  "pipeline_type": "atac-seq",
  "description": "Multi-sample paired-end ATAC-seq pipeline on hg38 performing adapter trimming, alignment, filtering, deduplication, read shifting, peak calling, TSS QC, bigWig generation, differential accessibility analysis, peak annotation, and aggregated QC reporting, all containerized.",
  "tools": [
    {
      "name": "FastQC",
      "version": "0.11.5",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/fastqc",
        "tag": "0.11.5--1",
        "full_uri": "quay.io/biocontainers/fastqc:0.11.5--1",
        "source": "biocontainers"
      },
      "purpose": "Quality control on raw and trimmed reads",
      "language": "CLI"
    },
    {
      "name": "fastp",
      "version": "0.18.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/fastp",
        "tag": "0.18.0--hd28b015_0",
        "full_uri": "quay.io/biocontainers/fastp:0.18.0--hd28b015_0",
        "source": "biocontainers"
      },
      "purpose": "Adapter trimming and quality filtering using Nextera adapters for paired-end ATAC-seq reads",
      "language": "CLI"
    },
    {
      "name": "Bowtie2",
      "version": "2.3.4.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bowtie2",
        "tag": "2.3.4.1--py35h2d50403_1",
        "full_uri": "quay.io/biocontainers/bowtie2:2.3.4.1--py35h2d50403_1",
        "source": "biocontainers"
      },
      "purpose": "Splice-unaware alignment of trimmed reads to hg38 reference genome",
      "language": "CLI"
    },
    {
      "name": "samtools",
      "version": "0.1.19",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/samtools",
        "tag": "0.1.19--2",
        "full_uri": "quay.io/biocontainers/samtools:0.1.19--2",
        "source": "biocontainers"
      },
      "purpose": "Filter unmapped reads, low MAPQ (<30) reads, and mitochondrial (chrM) reads from BAM; sort and index BAM files",
      "language": "CLI"
    },
    {
      "name": "Picard",
      "version": "2.9.2",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/picard",
        "tag": "2.9.2--py35_1",
        "full_uri": "quay.io/biocontainers/picard:2.9.2--py35_1",
        "source": "biocontainers"
      },
      "purpose": "Remove PCR duplicates using MarkDuplicates to reduce amplification bias",
      "language": "CLI"
    },
    {
      "name": "deeptools",
      "version": "3.0.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/deeptools",
        "tag": "3.0.1--py27_0",
        "full_uri": "quay.io/biocontainers/deeptools:3.0.1--py27_0",
        "source": "biocontainers"
      },
      "purpose": "Shift reads for Tn5 insertion bias correction and generate RPGC-normalized bigWig tracks",
      "language": "CLI"
    },
    {
      "name": "MACS2",
      "version": "2.1.1.20160309",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/macs2",
        "tag": "2.1.1.20160309--py27h7eb728f_3",
        "full_uri": "quay.io/biocontainers/macs2:2.1.1.20160309--py27h7eb728f_3",
        "source": "biocontainers"
      },
      "purpose": "Call open chromatin peaks using ATAC-seq appropriate parameters",
      "language": "CLI"
    },
    {
      "name": "ataqv",
      "version": "1.0.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/ataqv",
        "tag": "1.0.0--py27heba63b0_0",
        "full_uri": "quay.io/biocontainers/ataqv:1.0.0--py27heba63b0_0",
        "source": "biocontainers"
      },
      "purpose": "Compute ATAC-seq-specific QC metrics including TSS enrichment score and fragment size distribution",
      "language": "CLI"
    },
    {
      "name": "DiffBind",
      "version": "1.20.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-deseq2",
        "tag": "1.20.0--r351hfc679d8_0",
        "full_uri": "quay.io/biocontainers/bioconductor-deseq2:1.20.0--r351hfc679d8_0",
        "source": "biocontainers"
      },
      "purpose": "Perform differential chromatin accessibility analysis between treatment and control conditions",
      "language": "R"
    },
    {
      "name": "ChIPseeker",
      "version": "1.10.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-chipseeker",
        "tag": "1.10.0--r3.4.1_0",
        "full_uri": "quay.io/biocontainers/bioconductor-chipseeker:1.10.0--r3.4.1_0",
        "source": "biocontainers"
      },
      "purpose": "Annotate peaks to nearest genomic features including promoters, enhancers, and gene bodies",
      "language": "R"
    },
    {
      "name": "MultiQC",
      "version": "1.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/multiqc",
        "tag": "1.0--py36_1",
        "full_uri": "quay.io/biocontainers/multiqc:1.0--py36_1",
        "source": "biocontainers"
      },
      "purpose": "Aggregate QC metrics from all tools into a single HTML report",
      "language": "CLI"
    }
  ],
  "rules": [
    {
      "name": "raw_fastqc",
      "tool": "FastQC",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "qc/fastqc/raw/{sample}_R1_fastqc.html",
        "qc/fastqc/raw/{sample}_R1_fastqc.zip",
        "qc/fastqc/raw/{sample}_R2_fastqc.html",
        "qc/fastqc/raw/{sample}_R2_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/fastqc/raw",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/fastqc/raw/{sample}.log"
      ]
    },
    {
      "name": "trim_reads",
      "tool": "fastp",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "qc/fastp/{sample}_fastp.json",
        "qc/fastp/{sample}_fastp.html"
      ],
      "params": {
        "threads": 8,
        "adapter_sequence": "CTGTCTCTTATACACATCT",
        "adapter_sequence_r2": "CTGTCTCTTATACACATCT",
        "min_length": 20,
        "qualified_quality_phred": 20
      },
      "shell_cmd": "fastp --in1 {input[0]} --in2 {input[1]} --out1 {output[0]} --out2 {output[1]} --json {output[2]} --html {output[3]} --adapter_sequence {params.adapter_sequence} --adapter_sequence_r2 {params.adapter_sequence_r2} --length_required {params.min_length} --qualified_quality_phred {params.qualified_quality_phred} --thread {params.threads} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 8000,
        "time_min": 90,
        "disk_mb": 30000
      },
      "log": [
        "logs/fastp/{sample}.log"
      ]
    },
    {
      "name": "post_trim_fastqc",
      "tool": "FastQC",
      "input": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz"
      ],
      "output": [
        "qc/fastqc/trimmed/{sample}_R1_fastqc.html",
        "qc/fastqc/trimmed/{sample}_R1_fastqc.zip",
        "qc/fastqc/trimmed/{sample}_R2_fastqc.html",
        "qc/fastqc/trimmed/{sample}_R2_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/fastqc/trimmed",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/fastqc/trimmed/{sample}.log"
      ]
    },
    {
      "name": "align_bowtie2",
      "tool": "Bowtie2",
      "input": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz"
      ],
      "output": [
        "aligned/{sample}.bam",
        "qc/bowtie2/{sample}_bowtie2.log"
      ],
      "params": {
        "index": "config[bowtie2_index]",
        "threads": 16,
        "maxins": 2000
      },
      "shell_cmd": "bowtie2 -p {params.threads} -X {params.maxins} --very-sensitive -x {config[bowtie2_index]} -1 {input[0]} -2 {input[1]} 2> {output[1]} | samtools view -bS - | samtools sort -o {output[0]} - 2>> {log[0]} && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 16,
        "mem_mb": 32000,
        "time_min": 180,
        "disk_mb": 50000
      },
      "log": [
        "logs/bowtie2/{sample}.log"
      ]
    },
    {
      "name": "filter_bam",
      "tool": "samtools",
      "input": [
        "aligned/{sample}.bam"
      ],
      "output": [
        "filtered/{sample}.filtered.bam",
        "filtered/{sample}.filtered.bam.bai"
      ],
      "params": {
        "mapq": 30,
        "threads": 8,
        "excluded_contigs": "chrM"
      },
      "shell_cmd": "samtools view -b -F 4 -F 256 -F 2048 -q {params.mapq} -@ {params.threads} {input[0]} $(samtools view -H {input[0]} | grep '^@SQ' | cut -f2 | sed 's/SN://' | grep -v '{params.excluded_contigs}' | tr '\\n' ' ') | samtools sort -@ {params.threads} -o {output[0]} - 2> {log[0]} && samtools index {output[0]} 2>> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 40000
      },
      "log": [
        "logs/filter_bam/{sample}.log"
      ]
    },
    {
      "name": "remove_duplicates",
      "tool": "Picard",
      "input": [
        "filtered/{sample}.filtered.bam"
      ],
      "output": [
        "deduped/{sample}.deduped.bam",
        "deduped/{sample}.deduped.bam.bai",
        "qc/picard/{sample}.dup_metrics.txt"
      ],
      "params": {
        "java_opts": "-Xmx16g",
        "remove_duplicates": "true"
      },
      "shell_cmd": "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[1]} REMOVE_DUPLICATES={params.remove_duplicates} ASSUME_SORTED=true VALIDATION_STRINGENCY=LENIENT 2> {log[0]} && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 20000,
        "time_min": 120,
        "disk_mb": 40000
      },
      "log": [
        "logs/picard/{sample}.log"
      ]
    },
    {
      "name": "shift_reads",
      "tool": "deeptools",
      "input": [
        "deduped/{sample}.deduped.bam",
        "deduped/{sample}.deduped.bam.bai"
      ],
      "output": [
        "shifted/{sample}.shifted.bam",
        "shifted/{sample}.shifted.bam.bai"
      ],
      "params": {
        "threads": 8,
        "shift_plus": 4,
        "shift_minus": -5,
        "blacklist": "config[blacklist_bed]"
      },
      "shell_cmd": "alignmentSieve --bam {input[0]} --outFile {output[0]} --numberOfProcessors {params.threads} --ATACshift --blackListFileName {config[blacklist_bed]} 2> {log[0]} && samtools sort -@ {params.threads} -o {output[0]}.tmp.bam {output[0]} && mv {output[0]}.tmp.bam {output[0]} && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 30000
      },
      "log": [
        "logs/shift_reads/{sample}.log"
      ]
    },
    {
      "name": "call_peaks",
      "tool": "MACS2",
      "input": [
        "shifted/{sample}.shifted.bam"
      ],
      "output": [
        "peaks/{sample}/{sample}_peaks.narrowPeak",
        "peaks/{sample}/{sample}_summits.bed",
        "peaks/{sample}/{sample}_peaks.xls"
      ],
      "params": {
        "genome_size": "hs",
        "outdir": "peaks/{sample}",
        "name": "{sample}",
        "nomodel": true,
        "shift": -100,
        "extsize": 200,
        "qvalue": 0.05,
        "keep_dup": "all"
      },
      "shell_cmd": "macs2 callpeak -t {input[0]} -f BAMPE -g {params.genome_size} -n {params.name} --outdir {params.outdir} --nomodel --shift {params.shift} --extsize {params.extsize} -q {params.qvalue} --keep-dup {params.keep_dup} --call-summits 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/macs2/{sample}.log"
      ]
    },
    {
      "name": "peak_qc",
      "tool": "ataqv",
      "input": [
        "shifted/{sample}.shifted.bam",
        "peaks/{sample}/{sample}_peaks.narrowPeak"
      ],
      "output": [
        "qc/ataqv/{sample}.ataqv.json.gz",
        "qc/ataqv/{sample}.ataqv.out"
      ],
      "params": {
        "genome": "hg38",
        "tss_file": "config[tss_bed]",
        "organism": "human"
      },
      "shell_cmd": "ataqv --peak-file {input[1]} --tss-file {config[tss_bed]} --metrics-file {output[0]} {params.organism} {input[0]} > {output[1]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 10000
      },
      "log": [
        "logs/ataqv/{sample}.log"
      ]
    },
    {
      "name": "create_bigwig",
      "tool": "deeptools",
      "input": [
        "shifted/{sample}.shifted.bam",
        "shifted/{sample}.shifted.bam.bai"
      ],
      "output": [
        "bigwig/{sample}.rpgc.bw"
      ],
      "params": {
        "threads": 8,
        "normalize_using": "RPGC",
        "effective_genome_size": 2747877777,
        "bin_size": 10,
        "blacklist": "config[blacklist_bed]"
      },
      "shell_cmd": "bamCoverage --bam {input[0]} --outFileName {output[0]} --outFileFormat bigwig --normalizeUsing {params.normalize_using} --effectiveGenomeSize {params.effective_genome_size} --binSize {params.bin_size} --numberOfProcessors {params.threads} --blackListFileName {config[blacklist_bed]} --extendReads 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/bigwig/{sample}.log"
      ]
    },
    {
      "name": "diff_accessibility",
      "tool": "DiffBind",
      "input": [
        "expand('shifted/{sample}.shifted.bam', sample=config['samples'])",
        "expand('peaks/{sample}/{sample}_peaks.narrowPeak', sample=config['samples'])"
      ],
      "output": [
        "diffbind/diffbind_results.csv",
        "diffbind/diffbind_report.html",
        "diffbind/consensus_peaks.bed"
      ],
      "params": {
        "samplesheet": "config[diffbind_samplesheet]",
        "fdr_threshold": 0.05,
        "fold_change": 1.0,
        "condition_col": "Condition",
        "treatment_level": "treatment",
        "control_level": "control"
      },
      "shell_cmd": "Rscript scripts/run_diffbind.R --samplesheet {config[diffbind_samplesheet]} --outdir diffbind --fdr {params.fdr_threshold} --fc {params.fold_change} --condition {params.condition_col} --treatment {params.treatment_level} --control {params.control_level} 2> {log[0]}",
      "script": "scripts/run_diffbind.R",
      "resources": {
        "cpus": 8,
        "mem_mb": 32000,
        "time_min": 180,
        "disk_mb": 20000
      },
      "log": [
        "logs/diffbind/diffbind.log"
      ]
    },
    {
      "name": "annotate_peaks",
      "tool": "ChIPseeker",
      "input": [
        "diffbind/consensus_peaks.bed",
        "diffbind/diffbind_results.csv"
      ],
      "output": [
        "annotation/peaks_annotated.csv",
        "annotation/peaks_annotation_summary.pdf",
        "annotation/peaks_genomic_distribution.pdf"
      ],
      "params": {
        "txdb": "config[txdb]",
        "organism_db": "config[organism_db]",
        "tss_region_start": -3000,
        "tss_region_end": 3000,
        "genome_build": "hg38"
      },
      "shell_cmd": "Rscript scripts/run_chipseeker.R --peaks {input[0]} --diffbind_results {input[1]} --txdb {config[txdb]} --orgdb {config[organism_db]} --tss_start {params.tss_region_start} --tss_end {params.tss_region_end} --outdir annotation 2> {log[0]}",
      "script": "scripts/run_chipseeker.R",
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/chipseeker/annotate_peaks.log"
      ]
    },
    {
      "name": "multiqc_report",
      "tool": "MultiQC",
      "input": [
        "expand('qc/fastqc/raw/{sample}_R1_fastqc.zip', sample=config['samples'])",
        "expand('qc/fastqc/raw/{sample}_R2_fastqc.zip', sample=config['samples'])",
        "expand('qc/fastqc/trimmed/{sample}_R1_fastqc.zip', sample=config['samples'])",
        "expand('qc/fastqc/trimmed/{sample}_R2_fastqc.zip', sample=config['samples'])",
        "expand('qc/fastp/{sample}_fastp.json', sample=config['samples'])",
        "expand('qc/bowtie2/{sample}_bowtie2.log', sample=config['samples'])",
        "expand('qc/picard/{sample}.dup_metrics.txt', sample=config['samples'])",
        "expand('qc/ataqv/{sample}.ataqv.out', sample=config['samples'])",
        "expand('peaks/{sample}/{sample}_peaks.xls', sample=config['samples'])",
        "annotation/peaks_annotated.csv"
      ],
      "output": [
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data"
      ],
      "params": {
        "outdir": "qc/multiqc",
        "title": "ATAC-seq QC Report",
        "dirs": "qc/ peaks/ annotation/"
      },
      "shell_cmd": "multiqc {params.dirs} --outdir {params.outdir} --title \"{params.title}\" --force 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 30,
        "disk_mb": 10000
      },
      "log": [
        "logs/multiqc/multiqc.log"
      ]
    }
  ],
  "dag_edges": [
    [
      "raw_fastqc",
      "trim_reads"
    ],
    [
      "trim_reads",
      "post_trim_fastqc"
    ],
    [
      "post_trim_fastqc",
      "align_bowtie2"
    ],
    [
      "align_bowtie2",
      "filter_bam"
    ],
    [
      "filter_bam",
      "remove_duplicates"
    ],
    [
      "remove_duplicates",
      "shift_reads"
    ],
    [
      "shift_reads",
      "call_peaks"
    ],
    [
      "shift_reads",
      "peak_qc"
    ],
    [
      "shift_reads",
      "create_bigwig"
    ],
    [
      "call_peaks",
      "diff_accessibility"
    ],
    [
      "call_peaks",
      "annotate_peaks"
    ],
    [
      "diff_accessibility",
      "annotate_peaks"
    ],
    [
      "raw_fastqc",
      "multiqc_report"
    ],
    [
      "post_trim_fastqc",
      "multiqc_report"
    ],
    [
      "trim_reads",
      "multiqc_report"
    ],
    [
      "align_bowtie2",
      "multiqc_report"
    ],
    [
      "remove_duplicates",
      "multiqc_report"
    ],
    [
      "call_peaks",
      "multiqc_report"
    ],
    [
      "peak_qc",
      "multiqc_report"
    ],
    [
      "annotate_peaks",
      "multiqc_report"
    ]
  ],
  "config_params": {
    "samples": [
      "sample1",
      "sample2",
      "sample3",
      "sample4"
    ],
    "conditions": {
      "treatment": [
        "sample1",
        "sample2"
      ],
      "control": [
        "sample3",
        "sample4"
      ]
    },
    "paired_end": true,
    "strandedness": 0,
    "genome_build": "hg38",
    "bowtie2_index": "resources/hg38/bowtie2_index/hg38",
    "blacklist_bed": "resources/hg38/hg38-blacklist.v2.bed",
    "tss_bed": "resources/hg38/hg38_tss.bed",
    "txdb": "TxDb.Hsapiens.UCSC.hg38.knownGene",
    "organism_db": "org.Hs.eg.db",
    "diffbind_samplesheet": "resources/diffbind_samplesheet.csv",
    "effective_genome_size": 2747877777,
    "macs2_genome_size": "hs",
    "macs2_qvalue": 0.05,
    "mapq_threshold": 30,
    "min_read_length": 20,
    "fdr_threshold": 0.05,
    "fold_change_threshold": 1.0
  },
  "wildcards": [
    "sample"
  ]
}