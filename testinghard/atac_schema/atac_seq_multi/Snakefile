rule align_bowtie2:
    input:
        r1 = "trimmed/{sample}_R1.fastq.gz",
        r2 = "trimmed/{sample}_R2.fastq.gz",
    output:
        "aligned/{sample}.bam",
        "qc/bowtie2/{sample}_bowtie2.log"
    params:
        index = "config[bowtie2_index]",
        threads = 16,
        maxins = 2000,
    threads: 16
    resources:
        mem_mb  = 32000,
        runtime = 180
    log:
        "logs/bowtie2/{sample}.log"
    shell:
        "bowtie2 -p {params.threads} -X {params.maxins} --very-sensitive -x {config[bowtie2_index]} -1 {input[0]} -2 {input[1]} 2> {output[1]} | samtools view -bS - | samtools sort -o {output[0]} - 2>> {log[0]} && samtools index {output[0]} 2> {log}"

# ────────────────────────────────────────────────────────────
rule filter_bam:
    input:
        "aligned/{sample}.bam",
    output:
        "filtered/{sample}.filtered.bam",
        "filtered/{sample}.filtered.bam.bai"
    params:
        mapq = 30,
        threads = 8,
        excluded_contigs = "chrM",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/filter_bam/{sample}.log"
    shell:
        "samtools view -b -F 4 -F 256 -F 2048 -q {params.mapq} -@ {params.threads} {input[0]} $(samtools view -H {input[0]} | grep '^@SQ' | cut -f2 | sed 's/SN://' | grep -v '{params.excluded_contigs}' | tr '\n' ' ') | samtools sort -@ {params.threads} -o {output[0]} - 2> {log[0]} && samtools index {output[0]} 2>> {log[0]} 2> {log}"

# ────────────────────────────────────────────────────────────
rule remove_duplicates:
    input:
        "filtered/{sample}.filtered.bam",
    output:
        "deduped/{sample}.deduped.bam",
        "deduped/{sample}.deduped.bam.bai",
        "qc/picard/{sample}.dup_metrics.txt"
    params:
        java_opts = "-Xmx16g",
        remove_duplicates = "true",
    threads: 4
    resources:
        mem_mb  = 20000,
        runtime = 120
    log:
        "logs/picard/{sample}.log"
    shell:
        "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[1]} REMOVE_DUPLICATES={params.remove_duplicates} ASSUME_SORTED=true VALIDATION_STRINGENCY=LENIENT 2> {log[0]} && samtools index {output[0]} 2> {log}"

# ────────────────────────────────────────────────────────────
rule shift_reads:
    input:
        "deduped/{sample}.deduped.bam",
        "deduped/{sample}.deduped.bam.bai",
    output:
        "shifted/{sample}.shifted.bam",
        "shifted/{sample}.shifted.bam.bai"
    params:
        threads = 8,
        shift_plus = 4,
        shift_minus = -5,
        blacklist = "config[blacklist_bed]",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/shift_reads/{sample}.log"
    shell:
        "alignmentSieve --bam {input[0]} --outFile {output[0]} --numberOfProcessors {params.threads} --ATACshift --blackListFileName {config[blacklist_bed]} 2> {log[0]} && samtools sort -@ {params.threads} -o {output[0]}.tmp.bam {output[0]} && mv {output[0]}.tmp.bam {output[0]} && samtools index {output[0]} 2> {log}"

# ────────────────────────────────────────────────────────────
rule call_peaks:
    input:
        "shifted/{sample}.shifted.bam",
    output:
        "peaks/{sample}/{sample}_peaks.narrowPeak",
        "peaks/{sample}/{sample}_summits.bed",
        "peaks/{sample}/{sample}_peaks.xls"
    params:
        genome_size = "hs",
        outdir = "peaks/{sample}",
        name = "{wildcards.sample}",
        nomodel = True,
        shift = -100,
        extsize = 200,
        qvalue = 0.05,
        keep_dup = "all",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/macs2/{sample}.log"
    shell:
        "macs2 callpeak -t {input[0]} -f BAMPE -g {params.genome_size} -n {params.name} --outdir {params.outdir} --nomodel --shift {params.shift} --extsize {params.extsize} -q {params.qvalue} --keep-dup {params.keep_dup} --call-summits 2> {log}"

# ────────────────────────────────────────────────────────────
rule create_bigwig:
    input:
        "shifted/{sample}.shifted.bam",
        "shifted/{sample}.shifted.bam.bai",
    output:
        "bigwig/{sample}.rpgc.bw"
    params:
        threads = 8,
        normalize_using = "RPGC",
        effective_genome_size = 2747877777,
        bin_size = 10,
        blacklist = "config[blacklist_bed]",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/bigwig/{sample}.log"
    shell:
        "bamCoverage --bam {input[0]} --outFileName {output[0]} --outFileFormat bigwig --normalizeUsing {params.normalize_using} --effectiveGenomeSize {params.effective_genome_size} --binSize {params.bin_size} --numberOfProcessors {params.threads} --blackListFileName {config[blacklist_bed]} --extendReads 2> {log}"

