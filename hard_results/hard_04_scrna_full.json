{
  "pipeline_type": "scrna-seq-advanced",
  "description": "Advanced single-cell RNA-seq pipeline with Cell Ranger alignment, ambient RNA removal (SoupX), doublet detection (scDblFinder), Seurat clustering, automated cell type annotation (SingleR), and pseudotime trajectory analysis (Monocle3).",
  "tools": [
    {
      "name": "cellranger_count",
      "version": "7.1.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/cellranger",
        "tag": "7.1.0--0",
        "full_uri": "quay.io/biocontainers/cellranger:7.1.0--0",
        "source": "biocontainers"
      },
      "purpose": "Align 10x Genomics reads to reference genome and generate UMI count matrices per sample",
      "language": "CLI"
    },
    {
      "name": "soupx",
      "version": "1.6.2",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/r-soupx",
        "tag": "1.6.2--r43h786b1dc_0",
        "full_uri": "quay.io/biocontainers/r-soupx:1.6.2--r43h786b1dc_0",
        "source": "biocontainers"
      },
      "purpose": "Estimate and remove ambient RNA contamination from raw count matrices",
      "language": "R"
    },
    {
      "name": "scdblfinder",
      "version": "1.14.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-scdblfinder",
        "tag": "1.14.0--r43ha9d7317_0",
        "full_uri": "quay.io/biocontainers/bioconductor-scdblfinder:1.14.0--r43ha9d7317_0",
        "source": "biocontainers"
      },
      "purpose": "Detect and flag doublets (two cells captured in one droplet) for removal",
      "language": "R"
    },
    {
      "name": "seurat",
      "version": "4.3.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/r-seurat",
        "tag": "4.3.0--r43h786b1dc_1",
        "full_uri": "quay.io/biocontainers/r-seurat:4.3.0--r43h786b1dc_1",
        "source": "biocontainers"
      },
      "purpose": "Quality control, normalization, HVG selection, PCA, UMAP, clustering, and marker gene identification",
      "language": "R"
    },
    {
      "name": "singler",
      "version": "2.2.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-singler",
        "tag": "2.2.0--r43ha9d7317_0",
        "full_uri": "quay.io/biocontainers/bioconductor-singler:2.2.0--r43ha9d7317_0",
        "source": "biocontainers"
      },
      "purpose": "Automated cell type annotation of clusters using reference transcriptomic datasets",
      "language": "R"
    },
    {
      "name": "monocle3",
      "version": "1.3.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/r-monocle3",
        "tag": "1.3.1--r43h786b1dc_0",
        "full_uri": "quay.io/biocontainers/r-monocle3:1.3.1--r43h786b1dc_0",
        "source": "biocontainers"
      },
      "purpose": "Infer pseudotime trajectories and identify genes that change along developmental or biological paths",
      "language": "R"
    }
  ],
  "rules": [
    {
      "name": "cellranger_count",
      "tool": "cellranger_count",
      "input": [
        "data/fastq/{sample}"
      ],
      "output": [
        "results/cellranger/{sample}/outs/filtered_feature_bc_matrix/matrix.mtx.gz",
        "results/cellranger/{sample}/outs/raw_feature_bc_matrix/matrix.mtx.gz",
        "results/cellranger/{sample}/outs/molecule_info.h5"
      ],
      "params": {
        "reference": "{config[cellranger_reference]}",
        "localcores": 16,
        "localmem": 64,
        "chemistry": "{config[chemistry]}"
      },
      "shell_cmd": "cellranger count --id={wildcards.sample} --transcriptome={params.reference} --fastqs={input[0]} --sample={wildcards.sample} --localcores={params.localcores} --localmem={params.localmem} --chemistry={params.chemistry} --output-dir=results/cellranger/{wildcards.sample} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 16,
        "mem_mb": 65536,
        "time_min": 480,
        "disk_mb": 100000
      },
      "log": [
        "logs/cellranger/{sample}.log"
      ]
    },
    {
      "name": "soupx",
      "tool": "soupx",
      "input": [
        "results/cellranger/{sample}/outs/filtered_feature_bc_matrix/matrix.mtx.gz",
        "results/cellranger/{sample}/outs/raw_feature_bc_matrix/matrix.mtx.gz"
      ],
      "output": [
        "results/soupx/{sample}/corrected_counts.rds"
      ],
      "params": {
        "filtered_dir": "results/cellranger/{sample}/outs/filtered_feature_bc_matrix",
        "raw_dir": "results/cellranger/{sample}/outs/raw_feature_bc_matrix",
        "out_dir": "results/soupx/{sample}",
        "contamination_fraction": "{config[soupx_contamination_fraction]}"
      },
      "shell_cmd": "Rscript scripts/run_soupx.R --filtered_dir={params.filtered_dir} --raw_dir={params.raw_dir} --out_dir={params.out_dir} --contamination_fraction={params.contamination_fraction} --sample={wildcards.sample} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 20000
      },
      "log": [
        "logs/soupx/{sample}.log"
      ]
    },
    {
      "name": "scdblfinder",
      "tool": "scdblfinder",
      "input": [
        "results/soupx/{sample}/corrected_counts.rds"
      ],
      "output": [
        "results/scdblfinder/{sample}/doublet_calls.rds"
      ],
      "params": {
        "out_dir": "results/scdblfinder/{sample}",
        "dbr_threshold": "{config[doublet_rate]}",
        "nfeatures": "{config[scdblfinder_nfeatures]}"
      },
      "shell_cmd": "Rscript scripts/run_scdblfinder.R --input={input[0]} --out_dir={params.out_dir} --dbr={params.dbr_threshold} --nfeatures={params.nfeatures} --sample={wildcards.sample} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/scdblfinder/{sample}.log"
      ]
    },
    {
      "name": "quality_control",
      "tool": "seurat",
      "input": [
        "results/scdblfinder/{sample}/doublet_calls.rds"
      ],
      "output": [
        "results/qc/{sample}/seurat_filtered.rds",
        "results/qc/{sample}/qc_metrics.csv"
      ],
      "params": {
        "out_dir": "results/qc/{sample}",
        "min_features": "{config[min_features]}",
        "max_features": "{config[max_features]}",
        "min_counts": "{config[min_counts]}",
        "max_counts": "{config[max_counts]}",
        "max_mito_pct": "{config[max_mito_pct]}",
        "mito_pattern": "{config[mito_pattern]}"
      },
      "shell_cmd": "Rscript scripts/run_seurat_qc.R --input={input[0]} --out_dir={params.out_dir} --min_features={params.min_features} --max_features={params.max_features} --min_counts={params.min_counts} --max_counts={params.max_counts} --max_mito_pct={params.max_mito_pct} --mito_pattern={params.mito_pattern} --sample={wildcards.sample} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/qc/{sample}.log"
      ]
    },
    {
      "name": "normalization",
      "tool": "seurat",
      "input": [
        "results/qc/{sample}/seurat_filtered.rds"
      ],
      "output": [
        "results/normalized/{sample}/seurat_normalized.rds"
      ],
      "params": {
        "out_dir": "results/normalized/{sample}",
        "normalization_method": "{config[normalization_method]}",
        "scale_factor": "{config[scale_factor]}"
      },
      "shell_cmd": "Rscript scripts/run_normalization.R --input={input[0]} --out_dir={params.out_dir} --normalization_method={params.normalization_method} --scale_factor={params.scale_factor} --sample={wildcards.sample} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 30,
        "disk_mb": 10000
      },
      "log": [
        "logs/normalization/{sample}.log"
      ]
    },
    {
      "name": "feature_selection",
      "tool": "seurat",
      "input": [
        "results/normalized/{sample}/seurat_normalized.rds"
      ],
      "output": [
        "results/hvg/{sample}/seurat_hvg.rds",
        "results/hvg/{sample}/hvg_list.csv"
      ],
      "params": {
        "out_dir": "results/hvg/{sample}",
        "n_hvg": "{config[n_hvg]}",
        "selection_method": "{config[hvg_selection_method]}"
      },
      "shell_cmd": "Rscript scripts/run_feature_selection.R --input={input[0]} --out_dir={params.out_dir} --n_hvg={params.n_hvg} --selection_method={params.selection_method} --sample={wildcards.sample} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 30,
        "disk_mb": 10000
      },
      "log": [
        "logs/hvg/{sample}.log"
      ]
    },
    {
      "name": "merge_samples",
      "tool": "seurat",
      "input": [
        "results/hvg/{sample}/seurat_hvg.rds"
      ],
      "output": [
        "results/merged/seurat_merged.rds"
      ],
      "params": {
        "out_dir": "results/merged",
        "samples": "{config[samples]}"
      },
      "shell_cmd": "Rscript scripts/merge_samples.R --input_dir=results/hvg --out_dir={params.out_dir} --samples={params.samples} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 32000,
        "time_min": 60,
        "disk_mb": 30000
      },
      "log": [
        "logs/merge/merge_samples.log"
      ]
    },
    {
      "name": "dimensionality_red",
      "tool": "seurat",
      "input": [
        "results/merged/seurat_merged.rds"
      ],
      "output": [
        "results/dimred/seurat_dimred.rds",
        "results/dimred/umap_coords.csv",
        "results/dimred/pca_variance.csv"
      ],
      "params": {
        "out_dir": "results/dimred",
        "n_pcs": "{config[n_pcs]}",
        "n_neighbors": "{config[umap_n_neighbors]}",
        "min_dist": "{config[umap_min_dist]}",
        "umap_dims": "{config[umap_dims]}"
      },
      "shell_cmd": "Rscript scripts/run_dimred.R --input={input[0]} --out_dir={params.out_dir} --n_pcs={params.n_pcs} --n_neighbors={params.n_neighbors} --min_dist={params.min_dist} --umap_dims={params.umap_dims} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 32000,
        "time_min": 60,
        "disk_mb": 20000
      },
      "log": [
        "logs/dimred/dimred.log"
      ]
    },
    {
      "name": "clustering",
      "tool": "seurat",
      "input": [
        "results/dimred/seurat_dimred.rds"
      ],
      "output": [
        "results/clustering/seurat_clustered.rds",
        "results/clustering/cluster_assignments.csv"
      ],
      "params": {
        "out_dir": "results/clustering",
        "resolution": "{config[clustering_resolution]}",
        "algorithm": "{config[clustering_algorithm]}",
        "dims": "{config[umap_dims]}"
      },
      "shell_cmd": "Rscript scripts/run_clustering.R --input={input[0]} --out_dir={params.out_dir} --resolution={params.resolution} --algorithm={params.algorithm} --dims={params.dims} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 32000,
        "time_min": 60,
        "disk_mb": 20000
      },
      "log": [
        "logs/clustering/clustering.log"
      ]
    },
    {
      "name": "marker_genes",
      "tool": "seurat",
      "input": [
        "results/clustering/seurat_clustered.rds"
      ],
      "output": [
        "results/markers/all_markers.csv",
        "results/markers/top_markers.csv",
        "results/markers/marker_heatmap.pdf"
      ],
      "params": {
        "out_dir": "results/markers",
        "test_method": "{config[marker_test_method]}",
        "logfc_threshold": "{config[marker_logfc_threshold]}",
        "min_pct": "{config[marker_min_pct]}",
        "top_n": "{config[top_n_markers]}"
      },
      "shell_cmd": "Rscript scripts/run_marker_genes.R --input={input[0]} --out_dir={params.out_dir} --test_method={params.test_method} --logfc_threshold={params.logfc_threshold} --min_pct={params.min_pct} --top_n={params.top_n} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 32000,
        "time_min": 90,
        "disk_mb": 10000
      },
      "log": [
        "logs/markers/marker_genes.log"
      ]
    },
    {
      "name": "singler",
      "tool": "singler",
      "input": [
        "results/clustering/seurat_clustered.rds",
        "results/markers/all_markers.csv"
      ],
      "output": [
        "results/singler/singler_annotations.rds",
        "results/singler/cell_type_labels.csv",
        "results/singler/annotation_heatmap.pdf"
      ],
      "params": {
        "out_dir": "results/singler",
        "reference": "{config[singler_reference]}",
        "annotation_level": "{config[singler_annotation_level]}",
        "de_method": "{config[singler_de_method]}"
      },
      "shell_cmd": "Rscript scripts/run_singler.R --input={input[0]} --out_dir={params.out_dir} --reference={params.reference} --annotation_level={params.annotation_level} --de_method={params.de_method} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 32000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/singler/singler.log"
      ]
    },
    {
      "name": "monocle3",
      "tool": "monocle3",
      "input": [
        "results/singler/singler_annotations.rds",
        "results/singler/cell_type_labels.csv"
      ],
      "output": [
        "results/monocle3/cds_trajectory.rds",
        "results/monocle3/pseudotime_values.csv",
        "results/monocle3/trajectory_plot.pdf",
        "results/monocle3/trajectory_genes.csv"
      ],
      "params": {
        "out_dir": "results/monocle3",
        "root_cell_type": "{config[monocle3_root_cell_type]}",
        "n_trajectory_genes": "{config[monocle3_n_trajectory_genes]}",
        "reduction_method": "{config[monocle3_reduction_method]}",
        "cluster_method": "{config[monocle3_cluster_method]}"
      },
      "shell_cmd": "Rscript scripts/run_monocle3.R --input={input[0]} --cell_labels={input[1]} --out_dir={params.out_dir} --root_cell_type={params.root_cell_type} --n_trajectory_genes={params.n_trajectory_genes} --reduction_method={params.reduction_method} --cluster_method={params.cluster_method} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 32000,
        "time_min": 120,
        "disk_mb": 20000
      },
      "log": [
        "logs/monocle3/monocle3.log"
      ]
    }
  ],
  "dag_edges": [
    [
      "cellranger_count",
      "soupx"
    ],
    [
      "soupx",
      "scdblfinder"
    ],
    [
      "scdblfinder",
      "quality_control"
    ],
    [
      "quality_control",
      "normalization"
    ],
    [
      "normalization",
      "feature_selection"
    ],
    [
      "feature_selection",
      "merge_samples"
    ],
    [
      "merge_samples",
      "dimensionality_red"
    ],
    [
      "dimensionality_red",
      "clustering"
    ],
    [
      "clustering",
      "marker_genes"
    ],
    [
      "clustering",
      "singler"
    ],
    [
      "marker_genes",
      "singler"
    ],
    [
      "singler",
      "monocle3"
    ]
  ],
  "config_params": {
    "samples": [
      "sample1",
      "sample2",
      "sample3"
    ],
    "strandedness": 0,
    "paired_end": true,
    "cellranger_reference": "resources/refdata-gex-GRCh38-2020-A",
    "chemistry": "auto",
    "soupx_contamination_fraction": "auto",
    "doublet_rate": 0.075,
    "scdblfinder_nfeatures": 1500,
    "min_features": 200,
    "max_features": 6000,
    "min_counts": 500,
    "max_counts": 50000,
    "max_mito_pct": 20,
    "mito_pattern": "^MT-",
    "normalization_method": "LogNormalize",
    "scale_factor": 10000,
    "n_hvg": 3000,
    "hvg_selection_method": "vst",
    "n_pcs": 50,
    "umap_n_neighbors": 30,
    "umap_min_dist": 0.3,
    "umap_dims": 30,
    "clustering_resolution": 0.5,
    "clustering_algorithm": 1,
    "marker_test_method": "wilcox",
    "marker_logfc_threshold": 0.25,
    "marker_min_pct": 0.1,
    "top_n_markers": 10,
    "singler_reference": "HumanPrimaryCellAtlasData",
    "singler_annotation_level": "label.main",
    "singler_de_method": "wilcox",
    "monocle3_root_cell_type": "Stem cells",
    "monocle3_n_trajectory_genes": 100,
    "monocle3_reduction_method": "UMAP",
    "monocle3_cluster_method": "leiden"
  },
  "wildcards": [
    "sample"
  ]
}