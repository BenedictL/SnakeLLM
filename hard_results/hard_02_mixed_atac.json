{
  "pipeline_type": "atac-seq",
  "description": "Mixed single-end and paired-end ATAC-seq pipeline with automatic library type detection, Bowtie2 alignment, mitochondrial filtering, duplicate removal, MACS2 peak calling, IDR reproducibility filtering, and DiffBind differential accessibility analysis.",
  "tools": [
    {
      "name": "FastQC",
      "version": "0.11.5",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/fastqc",
        "tag": "0.11.5--1",
        "full_uri": "quay.io/biocontainers/fastqc:0.11.5--1",
        "source": "biocontainers"
      },
      "purpose": "Raw and post-trimming read quality control",
      "language": "CLI"
    },
    {
      "name": "fastp",
      "version": "0.18.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/fastp",
        "tag": "0.18.0--hd28b015_0",
        "full_uri": "quay.io/biocontainers/fastp:0.18.0--hd28b015_0",
        "source": "biocontainers"
      },
      "purpose": "Adapter trimming with automatic SE/PE detection using Nextera adapters",
      "language": "CLI"
    },
    {
      "name": "Bowtie2",
      "version": "2.3.4.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bowtie2",
        "tag": "2.3.4.1--py35h2d50403_1",
        "full_uri": "quay.io/biocontainers/bowtie2:2.3.4.1--py35h2d50403_1",
        "source": "biocontainers"
      },
      "purpose": "Align trimmed reads to reference genome in SE or PE mode per sample",
      "language": "CLI"
    },
    {
      "name": "samtools",
      "version": "0.1.19",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/samtools",
        "tag": "0.1.19--2",
        "full_uri": "quay.io/biocontainers/samtools:0.1.19--2",
        "source": "biocontainers"
      },
      "purpose": "Filter unmapped, low-MAPQ, and mitochondrial reads; coordinate-sort and index BAM files",
      "language": "CLI"
    },
    {
      "name": "Picard",
      "version": "2.9.2",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/picard",
        "tag": "2.9.2--py35_1",
        "full_uri": "quay.io/biocontainers/picard:2.9.2--py35_1",
        "source": "biocontainers"
      },
      "purpose": "Mark and remove PCR duplicates using MarkDuplicates",
      "language": "CLI"
    },
    {
      "name": "deeptools",
      "version": "3.0.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/deeptools",
        "tag": "3.0.1--py27_0",
        "full_uri": "quay.io/biocontainers/deeptools:3.0.1--py27_0",
        "source": "biocontainers"
      },
      "purpose": "Shift reads for Tn5 insertion bias correction and generate normalized bigWig tracks",
      "language": "CLI"
    },
    {
      "name": "MACS2",
      "version": "2.1.1.20160309",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/macs2",
        "tag": "2.1.1.20160309--py27h7eb728f_3",
        "full_uri": "quay.io/biocontainers/macs2:2.1.1.20160309--py27h7eb728f_3",
        "source": "biocontainers"
      },
      "purpose": "Call open chromatin peaks per sample using --nomodel --shift -100 --extsize 200",
      "language": "CLI"
    },
    {
      "name": "IDR",
      "version": "0.18.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bismark",
        "tag": "0.18.1--pl5.22.0_0",
        "full_uri": "quay.io/biocontainers/bismark:0.18.1--pl5.22.0_0",
        "source": "biocontainers"
      },
      "purpose": "Apply IDR filtering across biological replicates to retain reproducible peaks",
      "language": "CLI"
    },
    {
      "name": "ataqv",
      "version": "1.0.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/ataqv",
        "tag": "1.0.0--py27heba63b0_0",
        "full_uri": "quay.io/biocontainers/ataqv:1.0.0--py27heba63b0_0",
        "source": "biocontainers"
      },
      "purpose": "ATAC-seq QC metrics including TSS enrichment and nucleosomal fragment size distribution",
      "language": "CLI"
    },
    {
      "name": "DiffBind",
      "version": "1.20.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-deseq2",
        "tag": "1.20.0--r351hfc679d8_0",
        "full_uri": "quay.io/biocontainers/bioconductor-deseq2:1.20.0--r351hfc679d8_0",
        "source": "biocontainers"
      },
      "purpose": "Count reads in consensus peak set and perform differential chromatin accessibility analysis",
      "language": "R"
    },
    {
      "name": "ChIPseeker",
      "version": "1.10.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-chipseeker",
        "tag": "1.10.0--r3.4.1_0",
        "full_uri": "quay.io/biocontainers/bioconductor-chipseeker:1.10.0--r3.4.1_0",
        "source": "biocontainers"
      },
      "purpose": "Annotate differential and consensus peaks to nearest genomic features",
      "language": "R"
    },
    {
      "name": "MultiQC",
      "version": "1.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/multiqc",
        "tag": "1.0--py36_1",
        "full_uri": "quay.io/biocontainers/multiqc:1.0--py36_1",
        "source": "biocontainers"
      },
      "purpose": "Aggregate QC metrics from all tools into a single HTML report",
      "language": "CLI"
    }
  ],
  "rules": [
    {
      "name": "fastqc_raw",
      "tool": "FastQC",
      "input": [
        "data/raw/{sample}_R1.fastq.gz"
      ],
      "output": [
        "qc/fastqc_raw/{sample}_R1_fastqc.html",
        "qc/fastqc_raw/{sample}_R1_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/fastqc_raw",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/fastqc_raw/{sample}.log"
      ]
    },
    {
      "name": "fastp_trim",
      "tool": "fastp",
      "input": [
        "data/raw/{sample}_R1.fastq.gz"
      ],
      "output": [
        "trimmed/{sample}_R1.fastq.gz",
        "qc/fastp/{sample}.json",
        "qc/fastp/{sample}.html"
      ],
      "params": {
        "adapter_sequence": "CTGTCTCTTATACACATCT",
        "adapter_sequence_r2": "CTGTCTCTTATACACATCT",
        "threads": 4,
        "min_length": 25,
        "paired_end": "{config[paired_end]}"
      },
      "shell_cmd": "if [ \"{params.paired_end}\" = \"True\" ] && [ -f data/raw/{wildcards.sample}_R2.fastq.gz ]; then fastp --thread {params.threads} --in1 data/raw/{wildcards.sample}_R1.fastq.gz --in2 data/raw/{wildcards.sample}_R2.fastq.gz --out1 trimmed/{wildcards.sample}_R1.fastq.gz --out2 trimmed/{wildcards.sample}_R2.fastq.gz --adapter_sequence {params.adapter_sequence} --adapter_sequence_r2 {params.adapter_sequence_r2} --length_required {params.min_length} --json {output[1]} --html {output[2]} 2>{log[0]}; else fastp --thread {params.threads} --in1 data/raw/{wildcards.sample}_R1.fastq.gz --out1 trimmed/{wildcards.sample}_R1.fastq.gz --adapter_sequence {params.adapter_sequence} --length_required {params.min_length} --json {output[1]} --html {output[2]} 2>{log[0]}; fi",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/fastp/{sample}.log"
      ]
    },
    {
      "name": "fastqc_post",
      "tool": "FastQC",
      "input": [
        "trimmed/{sample}_R1.fastq.gz"
      ],
      "output": [
        "qc/fastqc_post/{sample}_R1_fastqc.html",
        "qc/fastqc_post/{sample}_R1_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/fastqc_post",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/fastqc_post/{sample}.log"
      ]
    },
    {
      "name": "bowtie2_align",
      "tool": "Bowtie2",
      "input": [
        "trimmed/{sample}_R1.fastq.gz"
      ],
      "output": [
        "aligned/{sample}.bam",
        "logs/bowtie2/{sample}.log"
      ],
      "params": {
        "index": "{config[bowtie2_index]}",
        "threads": 8,
        "paired_end": "{config[paired_end]}",
        "max_fragment_size": 2000
      },
      "shell_cmd": "if [ \"{params.paired_end}\" = \"True\" ] && [ -f trimmed/{wildcards.sample}_R2.fastq.gz ]; then bowtie2 -p {params.threads} -X {params.max_fragment_size} --no-mixed --no-discordant -x {params.index} -1 trimmed/{wildcards.sample}_R1.fastq.gz -2 trimmed/{wildcards.sample}_R2.fastq.gz 2>{output[1]} | samtools view -bS - > {output[0]}; else bowtie2 -p {params.threads} -x {params.index} -U trimmed/{wildcards.sample}_R1.fastq.gz 2>{output[1]} | samtools view -bS - > {output[0]}; fi",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 32000,
        "time_min": 180,
        "disk_mb": 50000
      },
      "log": [
        "logs/bowtie2/{sample}.log"
      ]
    },
    {
      "name": "samtools_filter",
      "tool": "samtools",
      "input": [
        "aligned/{sample}.bam"
      ],
      "output": [
        "filtered/{sample}.bam"
      ],
      "params": {
        "mapq": 30,
        "threads": 4,
        "chrM_name": "{config[chrM_name]}"
      },
      "shell_cmd": "samtools view -h -b -q {params.mapq} -F 4 {input[0]} | samtools view -h -b - $(samtools view -H {input[0]} | grep '^@SQ' | grep -v '{params.chrM_name}' | sed 's/.*SN://;s/\\t.*//' | tr '\\n' ' ') > {output[0]} 2>{log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 20000
      },
      "log": [
        "logs/samtools_filter/{sample}.log"
      ]
    },
    {
      "name": "samtools_sort_index",
      "tool": "samtools",
      "input": [
        "filtered/{sample}.bam"
      ],
      "output": [
        "sorted/{sample}.bam",
        "sorted/{sample}.bam.bai"
      ],
      "params": {
        "threads": 4
      },
      "shell_cmd": "samtools sort -@ {params.threads} -o {output[0]} {input[0]} 2>{log[0]} && samtools index {output[0]} 2>>{log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 30000
      },
      "log": [
        "logs/samtools_sort_index/{sample}.log"
      ]
    },
    {
      "name": "picard_markdup",
      "tool": "Picard",
      "input": [
        "sorted/{sample}.bam"
      ],
      "output": [
        "deduped/{sample}.bam",
        "qc/picard/{sample}.MarkDuplicates.metrics"
      ],
      "params": {
        "java_mem": "8g",
        "remove_duplicates": "true",
        "validation_stringency": "LENIENT"
      },
      "shell_cmd": "picard -Xmx{params.java_mem} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[1]} REMOVE_DUPLICATES={params.remove_duplicates} VALIDATION_STRINGENCY={params.validation_stringency} 2>{log[0]} && samtools index {output[0]} 2>>{log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 120,
        "disk_mb": 30000
      },
      "log": [
        "logs/picard/{sample}.log"
      ]
    },
    {
      "name": "deeptools_shift",
      "tool": "deeptools",
      "input": [
        "deduped/{sample}.bam",
        "deduped/{sample}.bam.bai"
      ],
      "output": [
        "shifted/{sample}.bam",
        "shifted/{sample}.bam.bai"
      ],
      "params": {
        "threads": 4,
        "shift_forward": 4,
        "shift_reverse": -5,
        "paired_end": "{config[paired_end]}"
      },
      "shell_cmd": "if [ \"{params.paired_end}\" = \"True\" ]; then alignmentSieve --numberOfProcessors {params.threads} --ATACshift --bam {input[0]} -o {output[0]} 2>{log[0]}; else alignmentSieve --numberOfProcessors {params.threads} --ATACshift --bam {input[0]} -o {output[0]} 2>{log[0]}; fi && samtools sort -@ {params.threads} -o {output[0]}.tmp.bam {output[0]} && mv {output[0]}.tmp.bam {output[0]} && samtools index {output[0]} 2>>{log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 30000
      },
      "log": [
        "logs/deeptools_shift/{sample}.log"
      ]
    },
    {
      "name": "macs2_callpeak",
      "tool": "MACS2",
      "input": [
        "shifted/{sample}.bam"
      ],
      "output": [
        "peaks/{sample}_peaks.narrowPeak",
        "peaks/{sample}_summits.bed"
      ],
      "params": {
        "genome_size": "{config[macs2_genome_size]}",
        "outdir": "peaks",
        "pvalue": "0.01",
        "paired_end": "{config[paired_end]}"
      },
      "shell_cmd": "if [ \"{params.paired_end}\" = \"True\" ] && [ -f shifted/{wildcards.sample}_R2.fastq.gz ]; then macs2 callpeak -t {input[0]} -f BAMPE -g {params.genome_size} -n {wildcards.sample} --outdir {params.outdir} --nomodel --shift -100 --extsize 200 --call-summits -p {params.pvalue} 2>{log[0]}; else macs2 callpeak -t {input[0]} -f BAM -g {params.genome_size} -n {wildcards.sample} --outdir {params.outdir} --nomodel --shift -100 --extsize 200 --call-summits -p {params.pvalue} 2>{log[0]}; fi",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 120,
        "disk_mb": 20000
      },
      "log": [
        "logs/macs2/{sample}.log"
      ]
    },
    {
      "name": "idr_filter",
      "tool": "IDR",
      "input": [
        "peaks/{rep1}_peaks.narrowPeak",
        "peaks/{rep2}_peaks.narrowPeak"
      ],
      "output": [
        "idr/{condition}_idr_peaks.txt"
      ],
      "params": {
        "threshold": 0.05,
        "rank": "signal.value",
        "peak_type": "narrowPeak",
        "output_file_type": "narrowPeak"
      },
      "shell_cmd": "idr --samples {input[0]} {input[1]} --peak-list {input[0]} --input-file-type {params.peak_type} --output-file {output[0]} --output-file-type {params.output_file_type} --rank {params.rank} --soft-idr-threshold {params.threshold} --use-best-multisummit-IDR 2>{log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/idr/{condition}.log"
      ]
    },
    {
      "name": "ataqv_qc",
      "tool": "ataqv",
      "input": [
        "shifted/{sample}.bam",
        "shifted/{sample}.bam.bai"
      ],
      "output": [
        "qc/ataqv/{sample}.json.gz",
        "qc/ataqv/{sample}.ataqv.out"
      ],
      "params": {
        "organism": "{config[organism]}",
        "tss_file": "{config[tss_bed]}",
        "peak_file": "peaks/{sample}_peaks.narrowPeak"
      },
      "shell_cmd": "ataqv --peak-file {params.peak_file} --tss-file {params.tss_file} --metrics-file {output[0]} {params.organism} {input[0]} > {output[1]} 2>{log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/ataqv/{sample}.log"
      ]
    },
    {
      "name": "deeptools_bigwig",
      "tool": "deeptools",
      "input": [
        "shifted/{sample}.bam",
        "shifted/{sample}.bam.bai"
      ],
      "output": [
        "bigwig/{sample}.bw"
      ],
      "params": {
        "threads": 4,
        "bin_size": 10,
        "normalize_using": "RPKM",
        "effective_genome_size": "{config[effective_genome_size]}"
      },
      "shell_cmd": "bamCoverage --bam {input[0]} --outFileName {output[0]} --outFileFormat bigwig --binSize {params.bin_size} --normalizeUsing {params.normalize_using} --effectiveGenomeSize {params.effective_genome_size} --numberOfProcessors {params.threads} 2>{log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/deeptools_bigwig/{sample}.log"
      ]
    },
    {
      "name": "diffbind",
      "tool": "DiffBind",
      "input": [
        "idr/all_idr_peaks_merged.txt",
        "diffbind_samplesheet.csv"
      ],
      "output": [
        "results/diffbind/diffbind_results.csv",
        "results/diffbind/diffbind_report.html"
      ],
      "params": {
        "fdr_cutoff": 0.05,
        "fc_cutoff": 1.5,
        "min_overlap": 2,
        "organism_db": "{config[organism_db]}"
      },
      "shell_cmd": "Rscript scripts/run_diffbind.R {input[1]} {input[0]} {output[0]} {output[1]} {params.fdr_cutoff} {params.fc_cutoff} {params.min_overlap} {params.organism_db} 2>{log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 32000,
        "time_min": 180,
        "disk_mb": 20000
      },
      "log": [
        "logs/diffbind/diffbind.log"
      ]
    },
    {
      "name": "chipseeker_annotate",
      "tool": "ChIPseeker",
      "input": [
        "results/diffbind/diffbind_results.csv"
      ],
      "output": [
        "results/chipseeker/peak_annotation.csv",
        "results/chipseeker/peak_annotation_plots.pdf"
      ],
      "params": {
        "txdb": "{config[txdb]}",
        "organism_db": "{config[organism_db]}",
        "tss_upstream": 3000,
        "tss_downstream": 3000
      },
      "shell_cmd": "Rscript scripts/run_chipseeker.R {input[0]} {output[0]} {output[1]} {params.txdb} {params.organism_db} {params.tss_upstream} {params.tss_downstream} 2>{log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/chipseeker/chipseeker.log"
      ]
    },
    {
      "name": "multiqc",
      "tool": "MultiQC",
      "input": [
        "qc/fastqc_raw",
        "qc/fastqc_post",
        "qc/fastp",
        "logs/bowtie2",
        "qc/picard",
        "qc/ataqv",
        "results/diffbind/diffbind_report.html"
      ],
      "output": [
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data"
      ],
      "params": {
        "outdir": "qc/multiqc",
        "title": "ATAC-seq QC Report"
      },
      "shell_cmd": "multiqc qc/fastqc_raw qc/fastqc_post qc/fastp logs/bowtie2 qc/picard qc/ataqv results/diffbind --outdir {params.outdir} --title \"{params.title}\" --force 2>{log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 30,
        "disk_mb": 10000
      },
      "log": [
        "logs/multiqc/multiqc.log"
      ]
    }
  ],
  "dag_edges": [
    [
      "fastqc_raw",
      "fastp_trim"
    ],
    [
      "fastp_trim",
      "fastqc_post"
    ],
    [
      "fastp_trim",
      "bowtie2_align"
    ],
    [
      "bowtie2_align",
      "samtools_filter"
    ],
    [
      "samtools_filter",
      "samtools_sort_index"
    ],
    [
      "samtools_sort_index",
      "picard_markdup"
    ],
    [
      "picard_markdup",
      "deeptools_shift"
    ],
    [
      "deeptools_shift",
      "macs2_callpeak"
    ],
    [
      "deeptools_shift",
      "ataqv_qc"
    ],
    [
      "deeptools_shift",
      "deeptools_bigwig"
    ],
    [
      "macs2_callpeak",
      "idr_filter"
    ],
    [
      "idr_filter",
      "diffbind"
    ],
    [
      "diffbind",
      "chipseeker_annotate"
    ],
    [
      "fastqc_raw",
      "multiqc"
    ],
    [
      "fastqc_post",
      "multiqc"
    ],
    [
      "bowtie2_align",
      "multiqc"
    ],
    [
      "picard_markdup",
      "multiqc"
    ],
    [
      "ataqv_qc",
      "multiqc"
    ],
    [
      "diffbind",
      "multiqc"
    ]
  ],
  "config_params": {
    "samples": [
      "sample1",
      "sample2",
      "sample3",
      "sample4"
    ],
    "paired_end": false,
    "strandedness": 0,
    "bowtie2_index": "resources/genome/hg38",
    "chrM_name": "chrM",
    "macs2_genome_size": "hs",
    "effective_genome_size": 2747877777,
    "organism": "human",
    "organism_db": "org.Hs.eg.db",
