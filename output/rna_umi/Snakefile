# SnakeLLM — rna-seq-de-umi
# Bulk RNA-seq differential expression pipeline with UMI-based deduplication using UMI-tools prior to gene-level quantification with featureCounts.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "results/enrichment/go_enrichment_results.csv",
        "results/enrichment/kegg_enrichment_results.csv",
        "results/enrichment/go_dotplot.pdf",
        "results/enrichment/kegg_dotplot.pdf",
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",

rule raw_fastqc:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "qc/raw_fastqc/{sample}_R1_fastqc.html",
        "qc/raw_fastqc/{sample}_R1_fastqc.zip",
        "qc/raw_fastqc/{sample}_R2_fastqc.html",
        "qc/raw_fastqc/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/raw_fastqc",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/raw_fastqc/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "trimmed/{sample}_R1_trimmed.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2_trimmed.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "resources/adapters.fa",
        leading = 3,
        trailing = 3,
        sliding_window = "4:15",
        min_len = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.sliding_window} MINLEN:{params.min_len} 2> {log}"

rule umi_extract:
    input:
        r1 = "trimmed/{sample}_R1_trimmed.fastq.gz",
        r2 = "trimmed/{sample}_R2_trimmed.fastq.gz",
    output:
        "umi_extracted/{sample}_R1_umi.fastq.gz",
        "umi_extracted/{sample}_R2_umi.fastq.gz",
    params:
        bc_pattern = "NNNNNNNN",
        log_file = "logs/umi_extract/{sample}_extract.log",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/umi_extract/{sample}.log"
    shell:
        "umi_tools extract --bc-pattern={params.bc_pattern} --stdin={input[0]} --read2-in={input[1]} --stdout={output[0]} --read2-out={output[1]} --log={params.log_file} 2> {log}"

rule align_star:
    input:
        r1 = "umi_extracted/{sample}_R1_umi.fastq.gz",
        r2 = "umi_extracted/{sample}_R2_umi.fastq.gz",
    output:
        "aligned/{sample}/Aligned.sortedByCoord.out.bam",
        "aligned/{sample}/Log.final.out",
    params:
        genome_dir = "resources/star_index",
        threads = 8,
        outdir_prefix = "aligned/{sample}/",
    threads: 8
    resources:
        mem_mb  = 40000,
        runtime = 180
    log:
        "logs/star/{sample}.log"
    shell:
        "STAR --runThreadN {params.threads} --genomeDir {params.genome_dir} --readFilesIn {input[0]} {input[1]} --readFilesCommand zcat --outSAMtype BAM SortedByCoordinate --outSAMattributes NH HI AS NM MD --outFileNamePrefix {params.outdir_prefix} --outSAMunmapped Within 2> {log}"

rule post_trim_fastqc:
    input:
        r1 = "umi_extracted/{sample}_R1_umi.fastq.gz",
        r2 = "umi_extracted/{sample}_R2_umi.fastq.gz",
    output:
        "qc/post_trim_fastqc/{sample}_R1_umi_fastqc.html",
        "qc/post_trim_fastqc/{sample}_R1_umi_fastqc.zip",
        "qc/post_trim_fastqc/{sample}_R2_umi_fastqc.html",
        "qc/post_trim_fastqc/{sample}_R2_umi_fastqc.zip",
    params:
        outdir = "qc/post_trim_fastqc",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/post_trim_fastqc/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule sort_index_bam:
    input:
        "aligned/{sample}/Aligned.sortedByCoord.out.bam"
    output:
        "sorted/{sample}.sorted.bam",
        "sorted/{sample}.sorted.bam.bai",
    params:
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/samtools/{sample}.log"
    shell:
        "samtools sort -@ {params.threads} -o {output[0]} {input[0]} > {log[0]} 2>&1 && samtools index {output[0]} > 2> {log}"

rule umi_dedup:
    input:
        "sorted/{sample}.sorted.bam",
        "sorted/{sample}.sorted.bam.bai",
    output:
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai",
    params:
        method = "directional",
        log_file = "logs/umi_dedup/{sample}_dedup.log",
    threads: 2
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/umi_dedup/{sample}.log"
    shell:
        "umi_tools dedup --method={params.method} --paired -I {input[0]} -S {output[0]} --log={params.log_file} > {log[0]} 2>&1 && samtools index {output[0]} > 2> {log}"

rule featurecounts:
    input:
        "dedup/S1.dedup.bam",
        "dedup/S2.dedup.bam",
        "dedup/S3.dedup.bam",
    output:
        "counts/all_samples_counts.txt",
        "counts/all_samples_counts.txt.summary",
    params:
        gtf = "resources/annotation.gtf",
        threads = 8,
        strandedness = "{config[strandedness]}",
        paired_end_flag = "{config[paired_end]}",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/featurecounts/featurecounts.log"
    shell:
        "featureCounts -T {params.threads} -s {params.strandedness} -a {params.gtf} -o {output[0]} {input} 2> {log}"

rule differential_expr:
    input:
        "counts/all_samples_counts.txt"
    output:
        "results/deseq2/diff_expr_results.csv",
        "results/deseq2/ma_plot.pdf",
        "results/deseq2/pca_plot.pdf",
        "results/deseq2/normalized_counts.csv",
    params:
        condition_col = "condition",
        ref_level = "control",
        padj_threshold = 0.05,
        lfc_threshold = 1.0,
        organism_db = "org.Hs.eg.db",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/deseq2/deseq2.log"
    shell:
        "Rscript scripts/run_deseq2.R --counts {input[0]} --out_results {output[0]} --out_ma {output[1]} --out_pca {output[2]} --out_norm {output[3]} --condition_col {params.condition_col} --ref_level {params.ref_level} --padj_threshold {params.padj_threshold} --lfc_threshold {params.lfc_threshold} --organism_db {params.organism_db} 2> {log}"

rule go_enrichment:
    input:
        "results/deseq2/diff_expr_results.csv"
    output:
        "results/enrichment/go_enrichment_results.csv",
        "results/enrichment/kegg_enrichment_results.csv",
        "results/enrichment/go_dotplot.pdf",
        "results/enrichment/kegg_dotplot.pdf",
    params:
        organism_db = "org.Hs.eg.db",
        kegg_organism = "hsa",
        padj_threshold = 0.05,
        lfc_threshold = 1.0,
        ont = "BP",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/clusterprofiler/go_enrichment.log"
    shell:
        "Rscript scripts/run_clusterprofiler.R --de_results {input[0]} --out_go {output[0]} --out_kegg {output[1]} --out_go_plot {output[2]} --out_kegg_plot {output[3]} --organism_db {params.organism_db} --kegg_organism {params.kegg_organism} --padj_threshold {params.padj_threshold} --lfc_threshold {params.lfc_threshold} --ont {params.ont} 2> {log}"

rule multiqc_report:
    input:
        ancient("qc/raw_fastqc"),
        ancient("qc/post_trim_fastqc"),
        ancient("logs/trimmomatic"),
        ancient("logs/umi_extract"),
        ancient("aligned"),
        ancient("logs/umi_dedup"),
        "counts/all_samples_counts.txt.summary",
        "results/deseq2/diff_expr_results.csv",
    output:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",
    params:
        outdir = "qc/multiqc",
        dirs = "qc/raw_fastqc qc/post_trim_fastqc logs/trimmomatic logs/umi_extract aligned logs/umi_dedup counts results/deseq2",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc {params.dirs} --outdir {params.outdir} --force 2> {log}"