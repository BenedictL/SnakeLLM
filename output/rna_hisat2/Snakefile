# SnakeLLM — rna-seq-de
# Stranded paired-end RNA-seq differential expression pipeline using HISAT2 alignment and StringTie quantification with DESeq2 and clusterProfiler.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "results/enrichment/go_results.csv",
        "results/enrichment/kegg_results.csv",
        "results/enrichment/go_dotplot.pdf",
        "results/enrichment/kegg_dotplot.pdf",
        "qc/multiqc/multiqc_report.html",

rule raw_fastqc:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "qc/raw/{sample}_R1_fastqc.html",
        "qc/raw/{sample}_R2_fastqc.html",
        "qc/raw/{sample}_R1_fastqc.zip",
        "qc/raw/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/raw",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/raw/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "trimmed/{sample}_R1_paired.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2_paired.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "{config[adapters]}",
        leading = 3,
        trailing = 3,
        slidingwindow = "4:15",
        minlen = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log}"

rule align_hisat2:
    input:
        r1 = "trimmed/{sample}_R1_paired.fastq.gz",
        r2 = "trimmed/{sample}_R2_paired.fastq.gz",
    output:
        "aligned/{sample}.bam",
    params:
        index = "{config[hisat2_index]}",
        rna_strandness = "{config[hisat2_rna_strandness]}",
        threads = 8,
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 180
    log:
        "logs/hisat2/{sample}.log"
    shell:
        "hisat2 -p {params.threads} --rna-strandness {params.rna_strandness} --dta -x {params.index} -1 {input[0]} -2 {input[1]} 2> {log[0]} | samtools view -bS - > {output[0]} 2> {log}"

rule post_trim_fastqc:
    input:
        r1 = "trimmed/{sample}_R1_paired.fastq.gz",
        r2 = "trimmed/{sample}_R2_paired.fastq.gz",
    output:
        "qc/trimmed/{sample}_R1_paired_fastqc.html",
        "qc/trimmed/{sample}_R2_paired_fastqc.html",
        "qc/trimmed/{sample}_R1_paired_fastqc.zip",
        "qc/trimmed/{sample}_R2_paired_fastqc.zip",
    params:
        outdir = "qc/trimmed",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/trimmed/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule sort_index_bam:
    input:
        "aligned/{sample}.bam"
    output:
        "aligned/{sample}.sorted.bam",
        "aligned/{sample}.sorted.bam.bai",
    params:
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/samtools/{sample}.log"
    shell:
        "samtools sort -@ {params.threads} -o {output[0]} {input[0]} 2> {log[0]} && samtools index {output[0]} 2>> {log[0]} 2> {log}"

rule stringtie_quantify:
    input:
        "aligned/{sample}.sorted.bam"
    output:
        "stringtie/{sample}/{sample}.gtf",
        "stringtie/{sample}/e_data.ctab",
        "stringtie/{sample}/i_data.ctab",
        "stringtie/{sample}/t_data.ctab",
    params:
        gtf = "{config[gtf_file]}",
        strandedness = "{config[strandedness]}",
        threads = 8,
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/stringtie/{sample}.log"
    shell:
        "strand_flag= && stringtie {input[0]} -G {params.gtf} -e -B -p {params.threads} $strand_flag -o {output[0]} 2> {log}"

rule multiqc_report:
    input:
        ancient("qc/raw"),
        ancient("qc/trimmed"),
        ancient("logs/hisat2"),
        ancient("logs/stringtie"),
    output:
        "qc/multiqc/multiqc_report.html",
    params:
        outdir = "qc/multiqc",
        dirs = "qc/raw qc/trimmed logs/hisat2 logs/stringtie",
    threads: 2
    resources:
        mem_mb  = 4000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc {params.dirs} --outdir {params.outdir} 2> {log}"

rule prepde_matrix:
    input:
        expand("stringtie/{sample}/{sample}.gtf", sample=config["samples"]),
    output:
        "counts/gene_count_matrix.csv",
        "counts/transcript_count_matrix.csv",
    params:
        sample_list = "counts/sample_list.txt",
        outdir = "counts",
    threads: 2
    resources:
        mem_mb  = 4000,
        runtime = 30
    log:
        "logs/prepde/prepde.log"
    shell:
        "python prepDE.py -i {params.sample_list} -g {output[0]} -t {output[1]} 2> {log}"

rule differential_expr:
    input:
        "counts/gene_count_matrix.csv"
    output:
        "results/deseq2/diff_expr_results.csv",
        "results/deseq2/normalized_counts.csv",
        "results/deseq2/de_genes.txt",
    params:
        sample_sheet = "{config[sample_sheet]}",
        condition_col = "{config[condition_col]}",
        reference_level = "{config[reference_level]}",
        lfc_threshold = "{config[lfc_threshold]}",
        padj_threshold = "{config[padj_threshold]}",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/deseq2/deseq2.log"
    shell:
        "Rscript scripts/run_deseq2.R --counts {input[0]} --sample_sheet {params.sample_sheet} --condition {params.condition_col} --reference {params.reference_level} --lfc_threshold {params.lfc_threshold} --padj_threshold {params.padj_threshold} --out_results {output[0]} --out_counts {output[1]} --out_de_genes {output[2]} 2> {log}"

rule go_enrichment:
    input:
        "results/deseq2/de_genes.txt",
        "results/deseq2/diff_expr_results.csv",
    output:
        "results/enrichment/go_results.csv",
        "results/enrichment/kegg_results.csv",
        "results/enrichment/go_dotplot.pdf",
        "results/enrichment/kegg_dotplot.pdf",
    params:
        organism_db = "{config[organism_db]}",
        kegg_organism = "{config[kegg_organism]}",
        padj_threshold = "{config[padj_threshold]}",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/clusterprofiler/enrichment.log"
    shell:
        "Rscript scripts/run_clusterprofiler.R --de_genes {input[0]} --de_results {input[1]} --organism_db {params.organism_db} --kegg_organism {params.kegg_organism} --padj_threshold {params.padj_threshold} --out_go {output[0]} --out_kegg {output[1]} --out_go_plot {output[2]} --out_kegg_plot {output[3]} 2> {log}"