# SnakeLLM — rna-seq-de
# Bulk RNA-seq differential expression pipeline using Salmon for transcript quantification and tximeta for importing counts into DESeq2.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "results/enrichment/go_bp_results.csv",
        "results/enrichment/go_mf_results.csv",
        "results/enrichment/go_cc_results.csv",
        "results/enrichment/kegg_results.csv",
        "results/enrichment/go_dotplot.pdf",
        "results/enrichment/kegg_dotplot.pdf",
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",

rule raw_fastqc:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "qc/raw_fastqc/{sample}_R1_fastqc.html",
        "qc/raw_fastqc/{sample}_R1_fastqc.zip",
        "qc/raw_fastqc/{sample}_R2_fastqc.html",
        "qc/raw_fastqc/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/raw_fastqc",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/raw_fastqc/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "trimmed/{sample}_R1_paired.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2_paired.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "resources/adapters.fa",
        leading = 3,
        trailing = 3,
        slidingwindow = "4:15",
        minlen = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log}"

rule post_trim_fastqc:
    input:
        r1 = "trimmed/{sample}_R1_paired.fastq.gz",
        r2 = "trimmed/{sample}_R2_paired.fastq.gz",
    output:
        "qc/post_trim_fastqc/{sample}_R1_paired_fastqc.html",
        "qc/post_trim_fastqc/{sample}_R1_paired_fastqc.zip",
        "qc/post_trim_fastqc/{sample}_R2_paired_fastqc.html",
        "qc/post_trim_fastqc/{sample}_R2_paired_fastqc.zip",
    params:
        outdir = "qc/post_trim_fastqc",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/post_trim_fastqc/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule salmon_quant:
    input:
        r1 = "trimmed/{sample}_R1_paired.fastq.gz",
        r2 = "trimmed/{sample}_R2_paired.fastq.gz",
    output:
        "salmon/{sample}/quant.sf",
        "salmon/{sample}/lib_format_counts.json",
    params:
        index = "resources/salmon_index",
        libtype = "A",
        threads = 8,
        outdir = "salmon/{sample}",
        strandedness = "{config[strandedness]}",
        paired_end = "{config[paired_end]}",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/salmon/{sample}.log"
    shell:
        "salmon quant --index {params.index} --libType {params.libtype} -1 {input[0]} -2 {input[1]} --threads {params.threads} --validateMappings --gcBias --seqBias --output {params.outdir} 2> {log}"

rule tximeta_import:
    input:
        "salmon_quant_dirs.txt"
    output:
        "tximeta/se_object.rds",
    params:
        sample_sheet = "config/sample_sheet.csv",
        organism = "{config[organism]}",
        genome_build = "{config[genome_build]}",
        ensembl_release = "{config[ensembl_release]}",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/tximeta/tximeta_import.log"
    shell:
        "Rscript scripts/tximeta_import.R --quant_dirs {input[0]} --sample_sheet {params.sample_sheet} --organism {params.organism} --genome_build {params.genome_build} --ensembl_release {params.ensembl_release} --output {output[0]} 2> {log}"

rule differential_expr:
    input:
        "tximeta/se_object.rds"
    output:
        "results/deseq2/dds_object.rds",
        "results/deseq2/de_results.csv",
        "results/deseq2/normalized_counts.csv",
        "results/deseq2/pca_plot.pdf",
        "results/deseq2/volcano_plot.pdf",
        "results/deseq2/ma_plot.pdf",
    params:
        condition_col = "{config[condition_col]}",
        reference_level = "{config[reference_level]}",
        lfc_threshold = "{config[lfc_threshold]}",
        fdr_threshold = "{config[fdr_threshold]}",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/deseq2/differential_expr.log"
    shell:
        "Rscript scripts/run_deseq2.R --se_object {input[0]} --condition_col {params.condition_col} --reference_level {params.reference_level} --lfc_threshold {params.lfc_threshold} --fdr_threshold {params.fdr_threshold} --outdir results/deseq2 2> {log}"

rule go_enrichment:
    input:
        "results/deseq2/de_results.csv"
    output:
        "results/enrichment/go_bp_results.csv",
        "results/enrichment/go_mf_results.csv",
        "results/enrichment/go_cc_results.csv",
        "results/enrichment/kegg_results.csv",
        "results/enrichment/go_dotplot.pdf",
        "results/enrichment/kegg_dotplot.pdf",
    params:
        organism_db = "{config[organism_db]}",
        kegg_organism = "{config[kegg_organism]}",
        fdr_threshold = "{config[fdr_threshold]}",
        lfc_threshold = "{config[lfc_threshold]}",
        pvalue_cutoff = 0.05,
        qvalue_cutoff = 0.2,
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/clusterprofiler/go_enrichment.log"
    shell:
        "Rscript scripts/run_clusterprofiler.R --de_results {input[0]} --organism_db {params.organism_db} --kegg_organism {params.kegg_organism} --fdr_threshold {params.fdr_threshold} --lfc_threshold {params.lfc_threshold} --pvalue_cutoff {params.pvalue_cutoff} --qvalue_cutoff {params.qvalue_cutoff} --outdir results/enrichment 2> {log}"

rule multiqc_report:
    input:
        ancient("qc/raw_fastqc"),
        ancient("qc/post_trim_fastqc"),
        ancient("logs/trimmomatic"),
        ancient("salmon"),
        ancient("results/deseq2"),
    output:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",
    params:
        outdir = "qc/multiqc",
        title = "RNA-seq QC Report",
    threads: 2
    resources:
        mem_mb  = 4000,
        runtime = 30
    log:
        "logs/multiqc/multiqc_report.log"
    shell:
        "multiqc {input[0]} {input[1]} {input[2]} {input[3]} {input[4]} --outdir {params.outdir} --title \"{params.title}\" --force 2> {log}"