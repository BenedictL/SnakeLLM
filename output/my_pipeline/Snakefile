# SnakeLLM — rna-seq-de
# Bulk RNA-seq differential expression analysis pipeline using STAR alignment and DESeq2 with full QC and pathway enrichment.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",

rule raw_fastqc:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "qc/raw_fastqc/{sample}_R1_fastqc.html",
        "qc/raw_fastqc/{sample}_R1_fastqc.zip",
        "qc/raw_fastqc/{sample}_R2_fastqc.html",
        "qc/raw_fastqc/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/raw_fastqc",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/raw/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "trimmed/{sample}_R1_paired.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2_paired.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "resources/adapters.fa",
        leading = 3,
        trailing = 3,
        slidingwindow = "4:15",
        minlen = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log}"

rule post_trim_fastqc:
    input:
        r1 = "trimmed/{sample}_R1_paired.fastq.gz",
        r2 = "trimmed/{sample}_R2_paired.fastq.gz",
    output:
        "qc/post_trim_fastqc/{sample}_R1_paired_fastqc.html",
        "qc/post_trim_fastqc/{sample}_R1_paired_fastqc.zip",
        "qc/post_trim_fastqc/{sample}_R2_paired_fastqc.html",
        "qc/post_trim_fastqc/{sample}_R2_paired_fastqc.zip",
    params:
        outdir = "qc/post_trim_fastqc",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/post_trim/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule align_star:
    input:
        r1 = "trimmed/{sample}_R1_paired.fastq.gz",
        r2 = "trimmed/{sample}_R2_paired.fastq.gz",
    output:
        "aligned/{sample}/Aligned.sortedByCoord.out.bam",
        "aligned/{sample}/Log.final.out",
    params:
        genome_dir = "resources/star_genome",
        threads = 8,
        out_prefix = "aligned/{sample}/",
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 120
    log:
        "logs/star/{sample}.log"
    shell:
        "STAR --runThreadN {params.threads} --genomeDir {params.genome_dir} --readFilesIn {input[0]} {input[1]} --readFilesCommand zcat --outSAMtype BAM SortedByCoordinate --outSAMattributes NH HI AS NM MD --outFileNamePrefix {params.out_prefix} --outSAMstrandField intronMotif --outFilterIntronMotifs RemoveNoncanonical 2> {log}"

rule sort_index_bam:
    input:
        "aligned/{sample}/Aligned.sortedByCoord.out.bam"
    output:
        "aligned/{sample}/Aligned.sortedByCoord.out.bam.bai",
    params:
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 30
    log:
        "logs/samtools/{sample}.log"
    shell:
        "samtools index -@ {params.threads} {input[0]} {output[0]} 2> {log}"

rule featurecounts:
    input:
        "aligned/{sample}/Aligned.sortedByCoord.out.bam",
        "aligned/{sample}/Aligned.sortedByCoord.out.bam.bai",
    output:
        "counts/{sample}_counts.txt",
        "counts/{sample}_counts.txt.summary",
    params:
        gtf = "resources/annotation.gtf",
        threads = 4,
        strandness = 0,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/featurecounts/{sample}.log"
    shell:
        "featureCounts -T {params.threads} -p -s {params.strandness} -a {params.gtf} -o {output[0]} {input[0]} 2> {log}"

rule differential_expr:
    input:
        expand("counts/{sample}_counts.txt", sample=config["samples"]),
    output:
        "results/deseq2/de_results.csv",
        "results/deseq2/ma_plot.pdf",
        "results/deseq2/pca_plot.pdf",
        "results/deseq2/normalized_counts.csv",
    params:
        sample_table = "resources/sample_table.csv",
        condition_col = "condition",
        contrast = ['condition', 'treatment', 'control'],
        alpha = 0.05,
        lfc_threshold = 1.0,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/deseq2/deseq2.log"
    shell:
        "Rscript scripts/deseq2.R --sample_table {params.sample_table} --counts_dir counts/ --condition_col {params.condition_col} --alpha {params.alpha} --lfc_threshold {params.lfc_threshold} --out_results {output[0]} --out_ma {output[1]} --out_pca {output[2]} --out_norm_counts {output[3]} 2> {log}"

rule go_enrichment:
    input:
        "results/deseq2/de_results.csv"
    output:
        "results/enrichment/go_results.csv",
        "results/enrichment/kegg_results.csv",
        "results/enrichment/go_dotplot.pdf",
        "results/enrichment/kegg_dotplot.pdf",
    params:
        organism_db = "org.Hs.eg.db",
        pvalue_cutoff = 0.05,
        qvalue_cutoff = 0.2,
        lfc_threshold = 1.0,
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/clusterprofiler/clusterprofiler.log"
    shell:
        "Rscript scripts/clusterprofiler.R --de_results {input[0]} --organism_db {params.organism_db} --pvalue_cutoff {params.pvalue_cutoff} --qvalue_cutoff {params.qvalue_cutoff} --lfc_threshold {params.lfc_threshold} --out_go {output[0]} --out_kegg {output[1]} --out_go_plot {output[2]} --out_kegg_plot {output[3]} 2> {log}"

rule multiqc_report:
    input:
        ancient("qc/raw_fastqc"),
        ancient("qc/post_trim_fastqc"),
        ancient("aligned"),
        ancient("counts"),
        "results/enrichment/go_results.csv",
    output:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",
    params:
        outdir = "qc/multiqc",
        dirs = "qc/raw_fastqc qc/post_trim_fastqc aligned counts logs",
    threads: 2
    resources:
        mem_mb  = 4000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc {params.dirs} --outdir {params.outdir} --filename multiqc_report.html --force 2> {log}"