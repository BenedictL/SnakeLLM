# SnakeLLM — rna-seq-de
# Bulk RNA-seq differential expression analysis pipeline using STAR alignment and DESeq2 for identifying differentially expressed genes between conditions.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "results/enrichment/go_enrichment.csv",
        "results/enrichment/kegg_enrichment.csv",
        "results/enrichment/go_dotplot.pdf",
        "results/enrichment/kegg_dotplot.pdf",
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",

rule raw_fastqc:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "qc/raw/{sample}_R1_fastqc.html",
        "qc/raw/{sample}_R1_fastqc.zip",
        "qc/raw/{sample}_R2_fastqc.html",
        "qc/raw/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/raw",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/raw/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "config[adapters]",
        leading = 3,
        trailing = 3,
        slidingwindow = "4:15",
        minlen = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log}"

rule post_trim_fastqc:
    input:
        r1 = "trimmed/{sample}_R1.fastq.gz",
        r2 = "trimmed/{sample}_R2.fastq.gz",
    output:
        "qc/trimmed/{sample}_R1_fastqc.html",
        "qc/trimmed/{sample}_R1_fastqc.zip",
        "qc/trimmed/{sample}_R2_fastqc.html",
        "qc/trimmed/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/trimmed",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/trimmed/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule align_star:
    input:
        r1 = "trimmed/{sample}_R1.fastq.gz",
        r2 = "trimmed/{sample}_R2.fastq.gz",
    output:
        "aligned/{sample}/Aligned.out.bam",
        "aligned/{sample}/Log.final.out",
    params:
        genome_dir = "config[star_genome_dir]",
        threads = 8,
        outdir = "aligned/{sample}/",
    threads: 8
    resources:
        mem_mb  = 40000,
        runtime = 180
    log:
        "logs/star/{sample}.log"
    shell:
        "STAR --runThreadN {params.threads} --genomeDir {params.genome_dir} --readFilesIn {input[0]} {input[1]} --readFilesCommand zcat --outSAMtype BAM Unsorted --outSAMattributes NH HI AS NM --outFileNamePrefix {params.outdir} 2> {log}"

rule sort_index_bam:
    input:
        "aligned/{sample}/Aligned.out.bam"
    output:
        "aligned/{sample}/{sample}.sorted.bam",
        "aligned/{sample}/{sample}.sorted.bam.bai",
    params:
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/samtools/{sample}.log"
    shell:
        "samtools sort -@ {params.threads} -o {output[0]} {input[0]} > {log[0]} 2>&1 && samtools index {output[0]} > 2> {log}"

rule featurecounts:
    input:
        "aligned/sample1/sample1.sorted.bam",
        "aligned/sample2/sample2.sorted.bam",
        "aligned/sample3/sample3.sorted.bam",
        "aligned/sample4/sample4.sorted.bam",
    output:
        "counts/all_samples_counts.txt",
        "counts/all_samples_counts.txt.summary",
    params:
        gtf = "config[gtf_file]",
        threads = 8,
        strandedness = "config[strandedness]",
        paired_end_flag = "config[paired_end]",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/featurecounts/featurecounts.log"
    shell:
        "featureCounts -T {params.threads} -s {params.strandedness} -a {params.gtf} -o {output[0]} {input} 2> {log}"

rule differential_expr:
    input:
        "counts/all_samples_counts.txt"
    output:
        "results/deseq2/de_results.csv",
        "results/deseq2/ma_plot.pdf",
        "results/deseq2/pca_plot.pdf",
        "results/deseq2/normalized_counts.csv",
    params:
        sample_sheet = "config[sample_sheet]",
        condition_col = "config[condition_col]",
        reference_level = "config[reference_level]",
        lfc_threshold = "config[lfc_threshold]",
        padj_threshold = "config[padj_threshold]",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/deseq2/deseq2.log"
    shell:
        "Rscript scripts/run_deseq2.R --counts {input[0]} --sample_sheet {params.sample_sheet} --condition {params.condition_col} --reference {params.reference_level} --lfc_threshold {params.lfc_threshold} --padj_threshold {params.padj_threshold} --out_results {output[0]} --out_ma {output[1]} --out_pca {output[2]} --out_norm_counts {output[3]} 2> {log}"

rule go_enrichment:
    input:
        "results/deseq2/de_results.csv"
    output:
        "results/enrichment/go_enrichment.csv",
        "results/enrichment/kegg_enrichment.csv",
        "results/enrichment/go_dotplot.pdf",
        "results/enrichment/kegg_dotplot.pdf",
    params:
        organism_db = "config[organism_db]",
        padj_threshold = "config[padj_threshold]",
        lfc_threshold = "config[lfc_threshold]",
        kegg_organism = "config[kegg_organism]",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/clusterprofiler/enrichment.log"
    shell:
        "Rscript scripts/run_clusterprofiler.R --de_results {input[0]} --organism_db {params.organism_db} --kegg_organism {params.kegg_organism} --padj_threshold {params.padj_threshold} --lfc_threshold {params.lfc_threshold} --out_go {output[0]} --out_kegg {output[1]} --out_go_plot {output[2]} --out_kegg_plot {output[3]} 2> {log}"

rule multiqc_report:
    input:
        ancient("qc/raw"),
        ancient("qc/trimmed"),
        ancient("logs/star"),
        "counts/all_samples_counts.txt.summary",
        "results/deseq2/de_results.csv",
    output:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",
    params:
        outdir = "qc/multiqc",
        search_dirs = "qc/raw qc/trimmed logs/star counts results/deseq2",
    threads: 2
    resources:
        mem_mb  = 4000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc {params.search_dirs} --outdir {params.outdir} --force 2> {log}"