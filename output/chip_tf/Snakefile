# SnakeLLM — chip-seq
# ChIP-seq pipeline for transcription factor binding site identification with HOMER motif enrichment analysis.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",

rule raw_fastqc:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "qc/fastqc/raw/{sample}_R1_fastqc.html",
        "qc/fastqc/raw/{sample}_R2_fastqc.html",
        "qc/fastqc/raw/{sample}_R1_fastqc.zip",
        "qc/fastqc/raw/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/fastqc/raw",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/raw/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "config[adapters]",
        leading = 3,
        trailing = 3,
        sliding_window = "4:15",
        min_len = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.sliding_window} MINLEN:{params.min_len} 2> {log}"

rule align_bowtie2:
    input:
        r1 = "trimmed/{sample}_R1.fastq.gz",
        r2 = "trimmed/{sample}_R2.fastq.gz",
    output:
        "aligned/{sample}.bam",
    params:
        genome_index = "config[genome_index]",
        threads = 8,
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 180
    log:
        "logs/bowtie2/{sample}.log"
    shell:
        "bowtie2 -p {params.threads} -x {params.genome_index} -1 {input[0]} -2 {input[1]} 2> {log[0]} | samtools view -bS - | samtools sort -o {output[0]} - && samtools index {output[0]} 2> {log}"

rule filter_bam:
    input:
        "aligned/{sample}.bam"
    output:
        "filtered/{sample}.bam",
        "filtered/{sample}.bam.bai",
    params:
        mapq = 20,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/samtools/filter/{sample}.log"
    shell:
        "samtools view -b -q {params.mapq} -F 4 {input[0]} | samtools sort -@ {params.threads} -o {output[0]} - && samtools index {output[0]} 2> {log}"

rule remove_duplicates:
    input:
        "filtered/{sample}.bam"
    output:
        "dedup/{sample}.bam",
        "dedup/{sample}.bam.bai",
        "dedup/{sample}_metrics.txt",
    params:
        java_opts = "-Xmx8g",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/picard/{sample}.log"
    shell:
        "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[2]} REMOVE_DUPLICATES=true VALIDATION_STRINGENCY=LENIENT 2> {log[0]} && samtools index {output[0]} 2> {log}"

rule call_peaks:
    input:
        "dedup/{sample}.bam",
        "dedup/{control}.bam",
    output:
        "peaks/{sample}_peaks.narrowPeak",
        "peaks/{sample}_summits.bed",
        "peaks/{sample}_peaks.xls",
    params:
        genome_size = "config[genome_size]",
        qvalue = 0.05,
        outdir = "peaks",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/macs2/{sample}.log"
    shell:
        "macs2 callpeak -t {input[0]} -c {input[1]} -f BAMPE -g {params.genome_size} -n {wildcards.sample} --outdir {params.outdir} -q {params.qvalue} --call-summits 2> {log}"

rule create_bigwig:
    input:
        "dedup/{sample}.bam",
        "dedup/{sample}.bam.bai",
    output:
        "bigwig/{sample}.bw",
    params:
        bin_size = 10,
        normalize_using = "RPKM",
        threads = 8,
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/deeptools/bigwig/{sample}.log"
    shell:
        "bamCoverage -b {input[0]} -o {output[0]} --binSize {params.bin_size} --normalizeUsing {params.normalize_using} -p {params.threads} 2> {log}"

rule peak_qc:
    input:
        "dedup/{sample}.bam",
        "dedup/{sample}.bam.bai",
    output:
        "qc/fingerprint/{sample}_fingerprint.png",
        "qc/fingerprint/{sample}_fingerprint_metrics.txt",
    params:
        threads = 8,
        bin_size = 500,
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/deeptools/fingerprint/{sample}.log"
    shell:
        "plotFingerprint -b {input[0]} --plotFile {output[0]} --outQualityMetrics {output[1]} --binSize {params.bin_size} -p {params.threads} --plotTitle {wildcards.sample} 2> {log}"

rule annotate_peaks:
    input:
        "peaks/{sample}_peaks.narrowPeak"
    output:
        "annotation/{sample}_peak_annotation.csv",
        "annotation/{sample}_peak_annotation.pdf",
    params:
        txdb = "config[txdb]",
        organism_db = "config[organism_db]",
        tss_region_upstream = 3000,
        tss_region_downstream = 3000,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/chipseeker/{sample}.log"
    shell:
        "Rscript scripts/chipseeker_annotate.R {input[0]} {output[0]} {output[1]} {params.txdb} {params.organism_db} {params.tss_region_upstream} {params.tss_region_downstream} 2> {log}"

rule motif_analysis:
    input:
        "peaks/{sample}_summits.bed"
    output:
        "motifs/{sample}/homerResults.html",
        "motifs/{sample}/knownResults.html",
    params:
        genome = "config[genome_fasta]",
        size = 200,
        threads = 8,
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 180
    log:
        "logs/homer/{sample}.log"
    shell:
        "findMotifsGenome.pl {input[0]} {params.genome} motifs/{wildcards.sample} -size {params.size} -p {params.threads} 2> {log}"

rule multiqc_report:
    input:
        ancient("qc/fastqc/raw"),
        ancient("logs/trimmomatic"),
        ancient("logs/bowtie2"),
        ancient("dedup"),
        ancient("peaks"),
        ancient("qc/fingerprint"),
        ancient("motifs"),
        ancient("annotation"),
    output:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",
    params:
        outdir = "qc/multiqc",
        title = "ChIP-seq QC Report",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc {input} --outdir {params.outdir} --title \"{params.title}\" --force 2> {log}"