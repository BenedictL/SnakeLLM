# SnakeLLM — wgs-cnv-analysis
# Whole genome sequencing copy number variation analysis using CNVkit following read alignment and preprocessing.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "qc/multiqc/multiqc_report.html",

rule raw_fastqc:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "qc/fastqc/{sample}_R1_fastqc.html",
        "qc/fastqc/{sample}_R1_fastqc.zip",
        "qc/fastqc/{sample}_R2_fastqc.html",
        "qc/fastqc/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/fastqc",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/fastqc/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "resources/adapters.fa",
        leading = 3,
        trailing = 3,
        slidingwindow = "4:15",
        minlen = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log}"

rule align_bwa:
    input:
        r1 = "trimmed/{sample}_R1.fastq.gz",
        r2 = "trimmed/{sample}_R2.fastq.gz",
    output:
        "aligned/{sample}.bam",
    params:
        reference = "resources/genome.fa",
        threads = 16,
        read_group = "@RG\tID:{sample}\tSM:{sample}\tPL:ILLUMINA\tLB:{sample}",
    threads: 16
    resources:
        mem_mb  = 32000,
        runtime = 240
    log:
        "logs/bwa_mem2/{sample}.log"
    shell:
        "bwa-mem2 mem -t {params.threads} -R '{params.read_group}' {params.reference} {input[0]} {input[1]} | samtools view -bS - > {output[0]} 2> {log}"

rule sort_bam:
    input:
        "aligned/{sample}.bam"
    output:
        "sorted/{sample}.sorted.bam",
        "sorted/{sample}.sorted.bam.bai",
    params:
        threads = 8,
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/samtools_sort/{sample}.log"
    shell:
        "samtools sort -@ {params.threads} -o {output[0]} {input[0]} > {log[0]} 2>&1 && samtools index {output[0]} 2> {log}"

rule mark_duplicates:
    input:
        "sorted/{sample}.sorted.bam"
    output:
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai",
        "dedup/{sample}.metrics.txt",
    params:
        java_opts = "-Xmx16g",
    threads: 4
    resources:
        mem_mb  = 20000,
        runtime = 180
    log:
        "logs/picard_markdup/{sample}.log"
    shell:
        "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[2]} CREATE_INDEX=true VALIDATION_STRINGENCY=LENIENT > {log[0]} 2>&1 && mv dedup/{wildcards.sample}.dedup.bai {output[1]} 2> {log}"

rule gatk_bqsr:
    input:
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai",
    output:
        "bqsr/{sample}.recal.bam",
        "bqsr/{sample}.recal.bam.bai",
        "bqsr/{sample}.recal.table",
    params:
        reference = "resources/genome.fa",
        known_sites = "resources/dbsnp.vcf.gz",
        java_opts = "-Xmx16g",
    threads: 8
    resources:
        mem_mb  = 20000,
        runtime = 240
    log:
        "logs/gatk_bqsr/{sample}.log"
    shell:
        "gatk --java-options '{params.java_opts}' BaseRecalibrator -I {input[0]} -R {params.reference} --known-sites {params.known_sites} -O {output[2]} > {log[0]} 2>&1 && gatk --java-options '{params.java_opts}' ApplyBQSR -I {input[0]} -R {params.reference} --bqsr-recal-file {output[2]} -O {output[0]} >> {log[0]} 2>&1 && samtools index {output[0]} -o {output[1]} 2> {log}"

rule collect_recal_bams:
    input:
        expand("bqsr/{sample}.recal.bam", sample=config["samples"]),
    output:
        "bqsr/all_recal_bams.txt",
    threads: 1
    resources:
        mem_mb  = 1000,
        runtime = 5
    log:
        "logs/collect_recal_bams/collect.log"
    shell:
        "ls bqsr/*.recal.bam > {output[0]} 2> {log}"

rule cnvkit_batch:
    input:
        "bqsr/all_recal_bams.txt"
    output:
        "cnvkit/batch.done",
    params:
        reference = "resources/genome.fa",
        outdir = "cnvkit",
        method = "wgs",
        processes = 8,
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 480
    log:
        "logs/cnvkit/batch.log"
    shell:
        "cnvkit.py batch $(cat {input[0]} | tr '\n' ' ') --method {params.method} --fasta {params.reference} --output-dir {params.outdir} -p {params.processes} > {log[0]} 2>&1 && touch {output[0]} 2> {log}"

rule cnvkit_segment:
    input:
        "cnvkit/{sample}.cnr"
    output:
        "cnvkit/{sample}.cns",
    params:
        method = "cbs",
        processes = 4,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/cnvkit/segment_{sample}.log"
    shell:
        "cnvkit.py segment {input[0]} -m {params.method} -p {params.processes} -o {output[0]} 2> {log}"

rule cnvkit_call:
    input:
        "cnvkit/{sample}.cns"
    output:
        "cnvkit/{sample}.call.cns",
    params:
        ploidy = 2,
        purity = 1.0,
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/cnvkit/call_{sample}.log"
    shell:
        "cnvkit.py call {input[0]} --ploidy {params.ploidy} --purity {params.purity} -o {output[0]} 2> {log}"

rule cnvkit_scatter:
    input:
        "cnvkit/{sample}.cnr",
        "cnvkit/{sample}.call.cns",
    output:
        "cnvkit/scatter/{sample}_scatter.pdf",
    params:
        outdir = "cnvkit/scatter",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 30
    log:
        "logs/cnvkit/scatter_{sample}.log"
    shell:
        "cnvkit.py scatter {input[0]} -s {input[1]} -o {output[0]} 2> {log}"

rule collect_call_cns:
    input:
        expand("cnvkit/{sample}.call.cns", sample=config["samples"]),
    output:
        "cnvkit/all_call_cns.txt",
    threads: 1
    resources:
        mem_mb  = 1000,
        runtime = 5
    log:
        "logs/collect_call_cns/collect.log"
    shell:
        "ls cnvkit/*.call.cns > {output[0]} 2> {log}"

rule cnvkit_heatmap:
    input:
        "cnvkit/all_call_cns.txt"
    output:
        "cnvkit/heatmap/all_samples_heatmap.pdf",
    params:
        outdir = "cnvkit/heatmap",
    threads: 2
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/cnvkit/heatmap.log"
    shell:
        "cnvkit.py heatmap $(cat {input[0]} | tr '\n' ' ') -o {output[0]} 2> {log}"

rule multiqc:
    input:
        ancient("qc/fastqc"),
        ancient("logs/trimmomatic"),
        ancient("dedup"),
        ancient("cnvkit/scatter"),
    output:
        "qc/multiqc/multiqc_report.html",
    params:
        outdir = "qc/multiqc",
        dirs = "qc/fastqc logs/trimmomatic dedup cnvkit/scatter",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc {params.dirs} --outdir {params.outdir} 2> {log}"