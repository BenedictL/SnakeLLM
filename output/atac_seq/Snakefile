# SnakeLLM — atac-seq
# ATAC-seq chromatin accessibility analysis with MACS2 peak calling and IDR filtering for reproducible peak identification across biological replicates.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",

rule raw_fastqc:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "qc/fastqc/{sample}_R1_fastqc.html",
        "qc/fastqc/{sample}_R1_fastqc.zip",
        "qc/fastqc/{sample}_R2_fastqc.html",
        "qc/fastqc/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/fastqc",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "resources/NexteraPE-PE.fa",
        leading = 3,
        trailing = 3,
        slidingwindow = "4:15",
        minlen = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log}"

rule align_bowtie2:
    input:
        r1 = "trimmed/{sample}_R1.fastq.gz",
        r2 = "trimmed/{sample}_R2.fastq.gz",
    output:
        "aligned/{sample}.bam",
    params:
        index = "resources/genome/bowtie2_index",
        threads = 8,
        maxins = 2000,
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 180
    log:
        "logs/bowtie2/{sample}.log"
    shell:
        "bowtie2 -p {params.threads} -X {params.maxins} --no-mixed --no-discordant -x {params.index} -1 {input[0]} -2 {input[1]} 2> {log[0]} | samtools view -bS - | samtools sort -o {output[0]} && samtools index {output[0]} 2> {log}"

rule filter_bam:
    input:
        "aligned/{sample}.bam"
    output:
        "filtered/{sample}.filtered.bam",
    params:
        mapq = 30,
        threads = 4,
        chrM = "chrM",
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/samtools_filter/{sample}.log"
    shell:
        "samtools view -b -F 1804 -f 2 -q {params.mapq} -@ {params.threads} {input[0]} | samtools view -b --without-header $(samtools view -H {input[0]} | grep -v '{params.chrM}' | grep '^@SQ' | sed 's/@SQ\tSN:\([^\t]*\).*/\1/' | tr '\n' ' ') > {output[0]} && samtools index {output[0]} 2> {log}"

rule remove_duplicates:
    input:
        "filtered/{sample}.filtered.bam"
    output:
        "deduped/{sample}.deduped.bam",
        "qc/picard/{sample}.dup_metrics.txt",
    params:
        java_opts = "-Xmx16g",
        remove_duplicates = "true",
        validation_stringency = "LENIENT",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/picard/{sample}.log"
    shell:
        "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[1]} REMOVE_DUPLICATES={params.remove_duplicates} VALIDATION_STRINGENCY={params.validation_stringency} 2> {log[0]} && samtools index {output[0]} 2> {log}"

rule shift_reads:
    input:
        "deduped/{sample}.deduped.bam"
    output:
        "shifted/{sample}.shifted.bam",
    params:
        shift_plus = 4,
        shift_minus = -5,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/deeptools_shift/{sample}.log"
    shell:
        "alignmentSieve --numberOfProcessors {params.threads} --ATACshift --bam {input[0]} -o {output[0]} 2> {log[0]} && samtools index {output[0]} 2> {log}"

rule call_peaks:
    input:
        "shifted/{sample}.shifted.bam"
    output:
        "peaks/{sample}_peaks.narrowPeak",
        "peaks/{sample}_summits.bed",
        "peaks/{sample}_peaks.xls",
    params:
        outdir = "peaks",
        genome_size = "hs",
        qvalue = 0.05,
        shift = -100,
        extsize = 200,
        format = "BAMPE",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/macs2/{sample}.log"
    shell:
        "macs2 callpeak -t {input[0]} -f {params.format} -g {params.genome_size} -n {wildcards.sample} --outdir {params.outdir} --nomodel --shift {params.shift} --extsize {params.extsize} -q {params.qvalue} --call-summits 2> {log}"

rule create_bigwig:
    input:
        "shifted/{sample}.shifted.bam"
    output:
        "bigwig/{sample}.bw",
    params:
        threads = 8,
        bin_size = 10,
        normalize_using = "RPKM",
        effective_genome_size = 2700000000,
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/bamcoverage/{sample}.log"
    shell:
        "bamCoverage --bam {input[0]} --outFileName {output[0]} --outFileFormat bigwig --binSize {params.bin_size} --normalizeUsing {params.normalize_using} --effectiveGenomeSize {params.effective_genome_size} --numberOfProcessors {params.threads} 2> {log}"

rule idr_filter:
    input:
        "peaks/{rep1}_peaks.narrowPeak",
        "peaks/{rep2}_peaks.narrowPeak",
    output:
        "idr/{condition}_idr_peaks.narrowPeak",
        "idr/{condition}_idr_peaks.bed",
    params:
        idr_threshold = 0.05,
        input_file_type = "narrowPeak",
        rank = "signal.value",
        soft_idr_threshold = 0.1,
        plot = "--plot",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/idr/{condition}.log"
    shell:
        "idr --samples {input[0]} {input[1]} --input-file-type {params.input_file_type} --rank {params.rank} --peak-merge-method sum --soft-idr-threshold {params.soft_idr_threshold} --idr-threshold {params.idr_threshold} {params.plot} --output-file {output[0]} --log-output-file {log[0]} && awk 'BEGIN{{OFS=\"\t\"}} {{print$1,$2,$3,$4,$5,$6}}' {output[0]} > {output[1]} 2> {log}"

rule annotate_peaks:
    input:
        "idr/{condition}_idr_peaks.narrowPeak"
    output:
        "annotation/{condition}_peak_annotation.tsv",
        "annotation/{condition}_peak_annotation.pdf",
    params:
        genome = "hg38",
        tss_region_start = -3000,
        tss_region_end = 3000,
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/chipseeker/{condition}.log"
    shell:
        "Rscript scripts/chipseeker_annotate.R --peaks {input[0]} --genome {params.genome} --tss_start {params.tss_region_start} --tss_end {params.tss_region_end} --outtsv {output[0]} --outpdf {output[1]} 2> {log}"

rule motif_analysis:
    input:
        "idr/{condition}_idr_peaks.bed"
    output:
        "motifs/{condition}/knownResults.html",
        "motifs/{condition}/homerResults.html",
    params:
        genome = "hg38",
        size = 200,
        threads = 4,
        outdir = "motifs/{condition}",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/homer/{condition}.log"
    shell:
        "findMotifsGenome.pl {input[0]} {params.genome} {params.outdir} -size {params.size} -p {params.threads} 2> {log}"

rule peak_qc:
    input:
        "shifted/{sample}.shifted.bam",
        "idr/{condition}_idr_peaks.narrowPeak",
    output:
        "qc/ataqv/{sample}.ataqv.json",
        "qc/ataqv/{sample}.ataqv.txt",
    params:
        genome_name = "human",
        tss_file = "resources/tss.bed",
        thread_count = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/ataqv/{sample}.log"
    shell:
        "ataqv --peak-file {input[1]} --name {wildcards.sample} --metrics-file {output[0]} --tss-file {params.tss_file} --thread-count {params.thread_count} {params.genome_name} {input[0]} > {output[1]} 2> {log}"

rule multiqc_report:
    input:
        ancient("qc/fastqc"),
        ancient("logs/trimmomatic"),
        ancient("logs/bowtie2"),
        ancient("qc/picard"),
        ancient("qc/ataqv"),
        ancient("bigwig"),
        ancient("motifs"),
        ancient("annotation"),
    output:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",
    params:
        outdir = "qc/multiqc",
        title = "ATAC-seq QC Report",
    threads: 2
    resources:
        mem_mb  = 4000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc {input} --outdir {params.outdir} --title \"{params.title}\" --force 2> {log}"