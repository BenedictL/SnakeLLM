# SnakeLLM — atac-seq
# ATAC-seq chromatin accessibility pipeline using Bowtie2 alignment, deepTools QC, and MACS2 peak calling to identify open chromatin regions.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",

rule raw_fastqc:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "qc/fastqc/{sample}_R1_fastqc.html",
        "qc/fastqc/{sample}_R1_fastqc.zip",
        "qc/fastqc/{sample}_R2_fastqc.html",
        "qc/fastqc/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/fastqc",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "config[nextera_adapters]",
        leading = 3,
        trailing = 3,
        slidingwindow = "4:15",
        minlen = 20,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log}"

rule align_bowtie2:
    input:
        r1 = "trimmed/{sample}_R1.fastq.gz",
        r2 = "trimmed/{sample}_R2.fastq.gz",
    output:
        "aligned/{sample}.bam",
    params:
        index = "config[bowtie2_index]",
        threads = 8,
        maxins = 2000,
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 180
    log:
        "logs/bowtie2/{sample}.log"
    shell:
        "bowtie2 -p {params.threads} -X {params.maxins} --very-sensitive -x {params.index} -1 {input[0]} -2 {input[1]} 2> {log[0]} | samtools view -bS - | samtools sort -o {output[0]} - && samtools index {output[0]} 2> {log}"

rule filter_bam:
    input:
        "aligned/{sample}.bam"
    output:
        "filtered/{sample}.filtered.bam",
        "filtered/{sample}.filtered.bam.bai",
    params:
        mapq = 30,
        threads = 4,
        chrM = "config[mito_chr]",
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/samtools_filter/{sample}.log"
    shell:
        "samtools view -b -F 1804 -f 2 -q {params.mapq} -@ {params.threads} {input[0]} | samtools view -b $(samtools idxstats {input[0]} | cut -f1 | grep -v '{params.chrM}' | tr '\n' ' ') -o {output[0]} && samtools index {output[0]} 2> {log}"

rule remove_duplicates:
    input:
        "filtered/{sample}.filtered.bam"
    output:
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai",
        "dedup/{sample}.dup_metrics.txt",
    params:
        java_opts = "-Xmx16g",
        validation_stringency = "LENIENT",
        remove_duplicates = "true",
    threads: 4
    resources:
        mem_mb  = 20000,
        runtime = 120
    log:
        "logs/picard/{sample}.log"
    shell:
        "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[2]} REMOVE_DUPLICATES={params.remove_duplicates} VALIDATION_STRINGENCY={params.validation_stringency} 2> {log[0]} && samtools index {output[0]} 2> {log}"

rule shift_reads:
    input:
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai",
    output:
        "shifted/{sample}.shifted.bam",
        "shifted/{sample}.shifted.bam.bai",
    params:
        threads = 4,
        atac_shift = "--ATACshift",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/deeptools_sieve/{sample}.log"
    shell:
        "alignmentSieve -b {input[0]} -o {output[0]} --numberOfProcessors {params.threads} {params.atac_shift} 2> {log[0]} && samtools sort -o {output[0]}.tmp {output[0]} && mv {output[0]}.tmp {output[0]} && samtools index {output[0]} 2> {log}"

rule call_peaks:
    input:
        "shifted/{sample}.shifted.bam"
    output:
        "peaks/{sample}_peaks.narrowPeak",
        "peaks/{sample}_peaks.xls",
        "peaks/{sample}_summits.bed",
    params:
        outdir = "peaks",
        genome_size = "config[macs2_genome_size]",
        qvalue = 0.05,
        shift = -100,
        extsize = 200,
        format = "BAM",
    threads: 2
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/macs2/{sample}.log"
    shell:
        "macs2 callpeak -t {input[0]} -f {params.format} -g {params.genome_size} -n {wildcards.sample} --outdir {params.outdir} --nomodel --shift {params.shift} --extsize {params.extsize} -q {params.qvalue} --keep-dup all --call-summits 2> {log}"

rule create_bigwig:
    input:
        "shifted/{sample}.shifted.bam",
        "shifted/{sample}.shifted.bam.bai",
    output:
        "bigwig/{sample}.bw",
    params:
        threads = 4,
        binsize = 10,
        normalize = "RPKM",
        effective_genome_size = "config[effective_genome_size]",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/bamcoverage/{sample}.log"
    shell:
        "bamCoverage -b {input[0]} -o {output[0]} --binSize {params.binsize} --normalizeUsing {params.normalize} --effectiveGenomeSize {params.effective_genome_size} --numberOfProcessors {params.threads} 2> {log}"

rule peak_qc:
    input:
        "shifted/{sample}.shifted.bam",
        "peaks/{sample}_peaks.narrowPeak",
    output:
        "qc/ataqv/{sample}.ataqv.json",
        "qc/ataqv/{sample}.ataqv.txt",
    params:
        organism = "config[organism]",
        tss_file = "config[tss_bed]",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/ataqv/{sample}.log"
    shell:
        "ataqv --tss-file {params.tss_file} --peak-file {input[1]} --metrics-file {output[0]} {params.organism} {input[0]} > {output[1]} 2> {log}"

rule annotate_peaks:
    input:
        "peaks/all_samples_peaks_merged.narrowPeak"
    output:
        "annotation/peaks_annotation.csv",
        "annotation/peaks_annotation_summary.pdf",
    params:
        txdb = "config[txdb]",
        organism_db = "config[organism_db]",
        tss_region_start = -3000,
        tss_region_end = 3000,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/chipseeker/annotate_peaks.log"
    shell:
        "Rscript scripts/chipseeker_annotate.R {input[0]} {output[0]} {output[1]} {params.txdb} {params.organism_db} {params.tss_region_start} {params.tss_region_end} 2> {log}"

rule multiqc_report:
    input:
        ancient("qc/fastqc"),
        ancient("logs/trimmomatic"),
        ancient("logs/bowtie2"),
        ancient("dedup"),
        ancient("qc/ataqv"),
        ancient("bigwig"),
        ancient("annotation"),
    output:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",
    params:
        outdir = "qc/multiqc",
        config = "config[multiqc_config]",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc qc/fastqc logs/trimmomatic logs/bowtie2 dedup qc/ataqv bigwig annotation --outdir {params.outdir} --config {params.config} --force 2> {log}"