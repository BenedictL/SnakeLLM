# SnakeLLM — atac-seq
# ATAC-seq chromatin accessibility pipeline with MACS2 peak calling and IDR filtering for reproducible peak identification across biological replicates.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",

rule raw_fastqc:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "qc/fastqc/{sample}_R1_fastqc.html",
        "qc/fastqc/{sample}_R1_fastqc.zip",
        "qc/fastqc/{sample}_R2_fastqc.html",
        "qc/fastqc/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/fastqc",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "config[nextera_adapters]",
        leading = 3,
        trailing = 3,
        slidingwindow = "4:15",
        minlen = 20,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log}"

rule align_bowtie2:
    input:
        r1 = "trimmed/{sample}_R1.fastq.gz",
        r2 = "trimmed/{sample}_R2.fastq.gz",
    output:
        "aligned/{sample}.bam",
    params:
        index = "config[bowtie2_index]",
        threads = 8,
        max_insert = 2000,
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 180
    log:
        "logs/bowtie2/{sample}.log"
    shell:
        "bowtie2 -p {params.threads} -X {params.max_insert} --very-sensitive -x {params.index} -1 {input[0]} -2 {input[1]} 2> {log[0]} | samtools sort -@ {params.threads} -o {output[0]} - && samtools index {output[0]} 2> {log}"

rule filter_bam:
    input:
        "aligned/{sample}.bam"
    output:
        "filtered/{sample}.filtered.bam",
    params:
        mapq = 30,
        threads = 4,
        chrM = "config[mito_chrom]",
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/filter_bam/{sample}.log"
    shell:
        "samtools view -@ {params.threads} -F 1804 -f 2 -q {params.mapq} -b {input[0]} | samtools view -@ {params.threads} -b --exclude-flags 0 - | grep -v '{params.chrM}' | samtools sort -@ {params.threads} -o {output[0]} - && samtools index {output[0]} 2> {log}"

rule remove_duplicates:
    input:
        "filtered/{sample}.filtered.bam"
    output:
        "deduped/{sample}.deduped.bam",
        "deduped/{sample}.dup_metrics.txt",
    params:
        java_opts = "-Xmx16g",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/picard/{sample}.log"
    shell:
        "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[1]} REMOVE_DUPLICATES=true ASSUME_SORTED=true VALIDATION_STRINGENCY=LENIENT 2> {log[0]} && samtools index {output[0]} 2> {log}"

rule shift_reads:
    input:
        "deduped/{sample}.deduped.bam"
    output:
        "shifted/{sample}.shifted.bam",
    params:
        threads = 4,
        shift_plus = 4,
        shift_minus = -5,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/shift_reads/{sample}.log"
    shell:
        "alignmentSieve --numberOfProcessors {params.threads} --ATACshift --bam {input[0]} -o {output[0]} 2> {log[0]} && samtools sort -@ {params.threads} -o {output[0]}.sorted.bam {output[0]} && mv {output[0]}.sorted.bam {output[0]} && samtools index {output[0]} 2> {log}"

rule call_peaks:
    input:
        "shifted/{sample}.shifted.bam"
    output:
        "peaks/{sample}_peaks.narrowPeak",
        "peaks/{sample}_summits.bed",
    params:
        outdir = "peaks",
        genome_size = "config[genome_size]",
        qvalue = 0.05,
        shift = -100,
        extsize = 200,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/macs2/{sample}.log"
    shell:
        "macs2 callpeak -t {input[0]} -f BAMPE -g {params.genome_size} -n {wildcards.sample} --outdir {params.outdir} --nomodel --shift {params.shift} --extsize {params.extsize} -q {params.qvalue} --keep-dup all 2> {log}"

rule create_bigwig:
    input:
        "shifted/{sample}.shifted.bam"
    output:
        "bigwigs/{sample}.bw",
    params:
        threads = 4,
        bin_size = 10,
        normalize = "RPKM",
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/bigwig/{sample}.log"
    shell:
        "bamCoverage --numberOfProcessors {params.threads} --binSize {params.bin_size} --normalizeUsing {params.normalize} --bam {input[0]} -o {output[0]} 2> {log}"

rule idr_filtering:
    input:
        "peaks/idr_input_rep1.narrowPeak",
        "peaks/idr_input_rep2.narrowPeak",
    output:
        "idr/idr_peaks.narrowPeak",
        "idr/idr_output.txt",
    params:
        idr_threshold = 0.05,
        rank = "signal.value",
        peak_merge_method = "sum",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/idr/idr.log"
    shell:
        "idr --samples {input[0]} {input[1]} --input-file-type narrowPeak --rank {params.rank} --idr-threshold {params.idr_threshold} --peak-merge-method {params.peak_merge_method} --output-file {output[1]} --plot --log-output-file {log[0]} && awk 'BEGIN{{OFS=\"\t\"}} $12>=({params.idr_threshold}*-1)*log(10)/log(10) {{print}}' {output[1]} > {output[0]} 2> {log}"

rule annotate_peaks:
    input:
        "idr/idr_peaks.narrowPeak"
    output:
        "annotation/peak_annotation.tsv",
        "annotation/peak_annotation_plots.pdf",
    params:
        genome_build = "config[genome_build]",
        txdb = "config[txdb]",
        organism_db = "config[organism_db]",
        tss_region_start = -3000,
        tss_region_end = 3000,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/chipseeker/annotate_peaks.log"
    shell:
        "Rscript scripts/annotate_peaks.R --peaks {input[0]} --txdb {params.txdb} --organism_db {params.organism_db} --tss_start {params.tss_region_start} --tss_end {params.tss_region_end} --out_table {output[0]} --out_plots {output[1]} 2> {log}"

rule motif_analysis:
    input:
        "idr/idr_peaks.narrowPeak"
    output:
        "motifs/motif_enrichment.txt",
        "motifs/known_motifs_results.txt",
    params:
        genome = "config[genome_build]",
        size = 200,
        outdir = "motifs",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/motif/motif_analysis.log"
    shell:
        "findMotifsGenome.pl {input[0]} {params.genome} {params.outdir} -size {params.size} -mask 2> {log[0]} && cp {params.outdir}/knownResults.txt {output[1]} && cp {params.outdir}/homerResults.html {output[0]} 2> {log}"

rule peak_qc:
    input:
        "idr/idr_peaks.narrowPeak",
        "deduped/all_samples_merged.bam",
    output:
        "qc/ataqv/ataqv_metrics.json",
        "qc/ataqv/ataqv_report.html",
    params:
        tss_file = "config[tss_bed]",
        organism = "config[organism]",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/ataqv/ataqv.log"
    shell:
        "ataqv --peak-file {input[0]} --tss-file {params.tss_file} --metrics-file {output[0]} {params.organism} {input[1]} 2> {log[0]} && mkarv --force {output[1]} {output[0]} 2> {log}"

rule multiqc_report:
    input:
        ancient("qc/fastqc"),
        ancient("logs/trimmomatic"),
        ancient("logs/bowtie2"),
        ancient("deduped"),
        "qc/ataqv/ataqv_metrics.json",
        "annotation/peak_annotation.tsv",
        "motifs/known_motifs_results.txt",
    output:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",
    params:
        outdir = "qc/multiqc",
        config = "config[multiqc_config]",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc --force --config {params.config} --outdir {params.outdir} qc/fastqc logs/trimmomatic logs/bowtie2 deduped qc/ataqv 2> {log}"