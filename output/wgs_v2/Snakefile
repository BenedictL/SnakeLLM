# SnakeLLM — wgs-variant-calling
# Whole genome sequencing germline variant calling pipeline following GATK4 Best Practices with HaplotypeCaller in GVCF mode.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "qc/multiqc/multiqc_report.html",

rule raw_fastqc:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "qc/fastqc/{sample}_R1_fastqc.html",
        "qc/fastqc/{sample}_R1_fastqc.zip",
        "qc/fastqc/{sample}_R2_fastqc.html",
        "qc/fastqc/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/fastqc",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "config[adapters]",
        min_len = 36,
        leading = 3,
        trailing = 3,
        slidingwindow = "4:15",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 120
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.min_len} 2> {log}"

rule align_bwa:
    input:
        r1 = "trimmed/{sample}_R1.fastq.gz",
        r2 = "trimmed/{sample}_R2.fastq.gz",
    output:
        "aligned/{sample}.bam",
    params:
        reference = "config[reference]",
        threads = 16,
        read_group = "@RG\tID:{wildcards.sample}\tSM:{wildcards.sample}\tPL:ILLUMINA\tLB:{wildcards.sample}",
    threads: 16
    resources:
        mem_mb  = 32000,
        runtime = 480
    log:
        "logs/bwa_mem2/{sample}.log"
    shell:
        "bwa-mem2 mem -t {params.threads} -R '{params.read_group}' {params.reference} {input[0]} {input[1]} | samtools view -bS - > {output[0]} 2> {log}"

rule sort_bam:
    input:
        "aligned/{sample}.bam"
    output:
        "sorted/{sample}.sorted.bam",
        "sorted/{sample}.sorted.bam.bai",
    params:
        threads = 8,
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/samtools_sort/{sample}.log"
    shell:
        "samtools sort -@ {params.threads} -o {output[0]} {input[0]} 2> {log[0]} && samtools index {output[0]} 2>> {log[0]} 2> {log}"

rule mark_duplicates:
    input:
        "sorted/{sample}.sorted.bam"
    output:
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bai",
        "qc/picard/{sample}.dup_metrics.txt",
    params:
        java_opts = "-Xmx16g",
        tmp_dir = "tmp/",
    threads: 4
    resources:
        mem_mb  = 20000,
        runtime = 240
    log:
        "logs/picard_markdup/{sample}.log"
    shell:
        "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[2]} CREATE_INDEX=true TMP_DIR={params.tmp_dir} VALIDATION_STRINGENCY=LENIENT 2> {log}"

rule base_recalibrator:
    input:
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bai",
    output:
        "bqsr/{sample}.recal.table",
    params:
        reference = "config[reference]",
        known_sites_dbsnp = "config[known_sites_dbsnp]",
        known_sites_mills = "config[known_sites_mills]",
        known_sites_1kg = "config[known_sites_1kg]",
        java_opts = "-Xmx16g",
    threads: 4
    resources:
        mem_mb  = 20000,
        runtime = 360
    log:
        "logs/base_recalibrator/{sample}.log"
    shell:
        "gatk --java-options '{params.java_opts}' BaseRecalibrator -I {input[0]} -R {params.reference} --known-sites {params.known_sites_dbsnp} --known-sites {params.known_sites_mills} --known-sites {params.known_sites_1kg} -O {output[0]} 2> {log}"

rule apply_bqsr:
    input:
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bai",
        "bqsr/{sample}.recal.table",
    output:
        "bqsr/{sample}.recal.bam",
        "bqsr/{sample}.recal.bai",
    params:
        reference = "config[reference]",
        java_opts = "-Xmx16g",
    threads: 4
    resources:
        mem_mb  = 20000,
        runtime = 360
    log:
        "logs/apply_bqsr/{sample}.log"
    shell:
        "gatk --java-options '{params.java_opts}' ApplyBQSR -R {params.reference} -I {input[0]} --bqsr-recal-file {input[2]} -O {output[0]} 2> {log}"

rule haplotype_caller:
    input:
        "bqsr/{sample}.recal.bam",
        "bqsr/{sample}.recal.bai",
    output:
        "gvcf/{sample}.g.vcf.gz",
        "gvcf/{sample}.g.vcf.gz.tbi",
    params:
        reference = "config[reference]",
        java_opts = "-Xmx16g",
        dbsnp = "config[known_sites_dbsnp]",
    threads: 8
    resources:
        mem_mb  = 24000,
        runtime = 720
    log:
        "logs/haplotype_caller/{sample}.log"
    shell:
        "gatk --java-options '{params.java_opts}' HaplotypeCaller -R {params.reference} -I {input[0]} -O {output[0]} -ERC GVCF --dbsnp {params.dbsnp} -G StandardAnnotation -G AS_StandardAnnotation 2> {log}"

rule combine_gvcfs:
    input:
        "gvcf/all_samples.gvcf.list"
    output:
        "genotyping/cohort.g.vcf.gz",
        "genotyping/cohort.g.vcf.gz.tbi",
    params:
        reference = "config[reference]",
        java_opts = "-Xmx32g",
    threads: 8
    resources:
        mem_mb  = 40000,
        runtime = 480
    log:
        "logs/combine_gvcfs/combine.log"
    shell:
        "gatk --java-options '{params.java_opts}' CombineGVCFs -R {params.reference} --variant {input[0]} -O {output[0]} 2> {log}"

rule genotype_gvcfs:
    input:
        r1 = "genotyping/cohort.g.vcf.gz",
        r2 = "genotyping/cohort.g.vcf.gz.tbi",
    output:
        "genotyping/cohort.vcf.gz",
        "genotyping/cohort.vcf.gz.tbi",
    params:
        reference = "config[reference]",
        dbsnp = "config[known_sites_dbsnp]",
        java_opts = "-Xmx32g",
    threads: 8
    resources:
        mem_mb  = 40000,
        runtime = 480
    log:
        "logs/genotype_gvcfs/genotype.log"
    shell:
        "gatk --java-options '{params.java_opts}' GenotypeGVCFs -R {params.reference} -V {input[0]} --dbsnp {params.dbsnp} -O {output[0]} 2> {log}"

rule variant_filtration:
    input:
        r1 = "genotyping/cohort.vcf.gz",
        r2 = "genotyping/cohort.vcf.gz.tbi",
    output:
        "filtered/cohort.filtered.vcf.gz",
        "filtered/cohort.filtered.vcf.gz.tbi",
    params:
        reference = "config[reference]",
        java_opts = "-Xmx16g",
        snp_filter_expr = "QD < 2.0 || FS > 60.0 || MQ < 40.0 || MQRankSum < -12.5 || ReadPosRankSum < -8.0",
        indel_filter_expr = "QD < 2.0 || FS > 200.0 || ReadPosRankSum < -20.0",
    threads: 4
    resources:
        mem_mb  = 20000,
        runtime = 240
    log:
        "logs/variant_filtration/filter.log"
    shell:
        "gatk --java-options '{params.java_opts}' VariantFiltration -R {params.reference} -V {input[0]} --filter-expression '{params.snp_filter_expr}' --filter-name 'SNP_HARD_FILTER' --filter-expression '{params.indel_filter_expr}' --filter-name 'INDEL_HARD_FILTER' -O {output[0]} 2> {log}"

rule annotate_variants:
    input:
        r1 = "filtered/cohort.filtered.vcf.gz",
        r2 = "filtered/cohort.filtered.vcf.gz.tbi",
    output:
        "annotated/cohort.annotated.vcf.gz",
        "annotated/cohort.annotated.vcf.gz.tbi",
    params:
        reference = "config[reference]",
        data_sources = "config[funcotator_data_sources]",
        ref_version = "config[ref_version]",
        java_opts = "-Xmx16g",
    threads: 4
    resources:
        mem_mb  = 20000,
        runtime = 480
    log:
        "logs/funcotator/annotate.log"
    shell:
        "gatk --java-options '{params.java_opts}' Funcotator -R {params.reference} -V {input[0]} -O {output[0]} --output-file-format VCF --data-sources-path {params.data_sources} --ref-version {params.ref_version} 2> {log}"

rule variant_qc:
    input:
        "annotated/cohort.annotated.vcf.gz"
    output:
        "qc/bcftools/cohort.stats.txt",
    threads: 2
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/bcftools_stats/stats.log"
    shell:
        "bcftools stats {input[0]} > {output[0]} 2> {log}"

rule multiqc_report:
    input:
        ancient("qc/fastqc"),
        ancient("qc/picard"),
        ancient("qc/bcftools"),
        ancient("logs/"),
    output:
        "qc/multiqc/multiqc_report.html",
    params:
        outdir = "qc/multiqc",
        dirs = "qc/ logs/",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc {params.dirs} --outdir {params.outdir} --filename multiqc_report.html 2> {log}"