# SnakeLLM — rna-seq-de
# Bulk RNA-seq differential expression analysis pipeline using STAR alignment, featureCounts quantification, and DESeq2 for identifying differentially expressed genes.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "results/enrichment/go_enrichment_results.csv",
        "results/enrichment/kegg_enrichment_results.csv",
        "results/enrichment/go_dotplot.pdf",
        "results/enrichment/kegg_dotplot.pdf",
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",

rule raw_fastqc:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "qc/raw/{sample}_R1_fastqc.html",
        "qc/raw/{sample}_R1_fastqc.zip",
        "qc/raw/{sample}_R2_fastqc.html",
        "qc/raw/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/raw",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/raw/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "trimmed/{sample}_R1_trimmed.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2_trimmed.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "resources/adapters.fa",
        leading = 3,
        trailing = 3,
        slidingwindow = "4:15",
        minlen = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log}"

rule align_star:
    input:
        r1 = "trimmed/{sample}_R1_trimmed.fastq.gz",
        r2 = "trimmed/{sample}_R2_trimmed.fastq.gz",
    output:
        "aligned/{sample}/Aligned.sortedByCoord.out.bam",
        "aligned/{sample}/Log.final.out",
    params:
        genome_dir = "resources/star_index",
        threads = 8,
        outdir_prefix = "aligned/{sample}/",
    threads: 8
    resources:
        mem_mb  = 40000,
        runtime = 180
    log:
        "logs/star/{sample}.log"
    shell:
        "STAR --runThreadN {params.threads} --genomeDir {params.genome_dir} --readFilesIn {input[0]} {input[1]} --readFilesCommand zcat --outSAMtype BAM SortedByCoordinate --outSAMattributes NH HI AS NM MD --outFileNamePrefix {params.outdir_prefix} --runMode alignReads 2> {log}"

rule post_trim_fastqc:
    input:
        r1 = "trimmed/{sample}_R1_trimmed.fastq.gz",
        r2 = "trimmed/{sample}_R2_trimmed.fastq.gz",
    output:
        "qc/trimmed/{sample}_R1_trimmed_fastqc.html",
        "qc/trimmed/{sample}_R1_trimmed_fastqc.zip",
        "qc/trimmed/{sample}_R2_trimmed_fastqc.html",
        "qc/trimmed/{sample}_R2_trimmed_fastqc.zip",
    params:
        outdir = "qc/trimmed",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/trimmed/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule sort_index_bam:
    input:
        "aligned/{sample}/Aligned.sortedByCoord.out.bam"
    output:
        "aligned/{sample}/{sample}.sorted.bam",
        "aligned/{sample}/{sample}.sorted.bam.bai",
    params:
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/samtools/{sample}.log"
    shell:
        "samtools sort -@ {params.threads} -o {output[0]} {input[0]} && samtools index {output[0]} 2> {log}"

rule featurecounts:
    input:
        "aligned/S1/S1.sorted.bam",
        "aligned/S2/S2.sorted.bam",
        "aligned/S3/S3.sorted.bam",
        "aligned/S4/S4.sorted.bam",
        "aligned/S5/S5.sorted.bam",
        "aligned/S6/S6.sorted.bam",
    output:
        "counts/all_samples_counts.txt",
        "counts/all_samples_counts.txt.summary",
    params:
        gtf = "resources/annotation.gtf",
        threads = 8,
        strandedness = "{config[strandedness]}",
        paired_end_flag = "{config[paired_end]}",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/featurecounts/featurecounts.log"
    shell:
        "featureCounts -T {params.threads} -s {params.strandedness} -a {params.gtf} -o {output[0]} {input} 2> {log}"

rule differential_expr:
    input:
        "counts/all_samples_counts.txt"
    output:
        "results/deseq2/diff_expr_results.csv",
        "results/deseq2/ma_plot.pdf",
        "results/deseq2/pca_plot.pdf",
        "results/deseq2/normalized_counts.csv",
    params:
        sample_info = "resources/sample_info.csv",
        condition_col = "condition",
        reference_level = "control",
        lfc_threshold = 1.0,
        padj_threshold = 0.05,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/deseq2/deseq2.log"
    shell:
        "Rscript scripts/run_deseq2.R --counts {input[0]} --sample_info {params.sample_info} --condition_col {params.condition_col} --reference_level {params.reference_level} --lfc_threshold {params.lfc_threshold} --padj_threshold {params.padj_threshold} --results_out {output[0]} --ma_plot {output[1]} --pca_plot {output[2]} --norm_counts {output[3]} 2> {log}"

rule go_enrichment:
    input:
        "results/deseq2/diff_expr_results.csv"
    output:
        "results/enrichment/go_enrichment_results.csv",
        "results/enrichment/kegg_enrichment_results.csv",
        "results/enrichment/go_dotplot.pdf",
        "results/enrichment/kegg_dotplot.pdf",
    params:
        organism_db = "org.Hs.eg.db",
        kegg_organism = "hsa",
        padj_threshold = 0.05,
        lfc_threshold = 1.0,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/clusterprofiler/enrichment.log"
    shell:
        "Rscript scripts/run_clusterprofiler.R --deseq2_results {input[0]} --organism_db {params.organism_db} --kegg_organism {params.kegg_organism} --padj_threshold {params.padj_threshold} --lfc_threshold {params.lfc_threshold} --go_out {output[0]} --kegg_out {output[1]} --go_plot {output[2]} --kegg_plot {output[3]} 2> {log}"

rule multiqc_report:
    input:
        ancient("qc/raw"),
        ancient("qc/trimmed"),
        "counts/all_samples_counts.txt.summary",
        "results/deseq2/diff_expr_results.csv",
    output:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",
    params:
        outdir = "qc/multiqc",
        search_dirs = "qc/raw qc/trimmed logs/star logs/featurecounts",
    threads: 2
    resources:
        mem_mb  = 4000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc {params.search_dirs} logs/star logs/trimmomatic logs/featurecounts --outdir {params.outdir} --filename multiqc_report.html 2> {log}"