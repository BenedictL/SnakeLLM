# SnakeLLM — wgs-variant-calling
# Whole genome sequencing germline variant calling following GATK4 Best Practices with HaplotypeCaller in GVCF mode and joint genotyping.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",

rule raw_fastqc:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "qc/fastqc/{sample}_R1_fastqc.html",
        "qc/fastqc/{sample}_R1_fastqc.zip",
        "qc/fastqc/{sample}_R2_fastqc.html",
        "qc/fastqc/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/fastqc",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "resources/adapters.fa",
        leading = 3,
        trailing = 3,
        slidingwindow = "4:15",
        minlen = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log}"

rule align_bwa:
    input:
        r1 = "trimmed/{sample}_R1.fastq.gz",
        r2 = "trimmed/{sample}_R2.fastq.gz",
    output:
        "aligned/{sample}.bam",
    params:
        reference = "resources/reference/genome.fa",
        threads = 16,
        read_group = "@RG\tID:{sample}\tSM:{sample}\tPL:ILLUMINA\tLB:{sample}",
    threads: 16
    resources:
        mem_mb  = 32000,
        runtime = 240
    log:
        "logs/bwa_mem2/{sample}.log"
    shell:
        "bwa-mem2 mem -t {params.threads} -R '{params.read_group}' {params.reference} {input[0]} {input[1]} | samtools view -bS - > {output[0]} 2> {log}"

rule sort_bam:
    input:
        "aligned/{sample}.bam"
    output:
        "sorted/{sample}.sorted.bam",
        "sorted/{sample}.sorted.bam.bai",
    params:
        threads = 8,
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/samtools_sort/{sample}.log"
    shell:
        "samtools sort -@ {params.threads} -o {output[0]} {input[0]} 2> {log[0]} && samtools index {output[0]} 2>> {log[0]} 2> {log}"

rule mark_duplicates:
    input:
        "sorted/{sample}.sorted.bam"
    output:
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai",
        "qc/picard/{sample}.dup_metrics.txt",
    params:
        java_opts = "-Xmx16g",
    threads: 4
    resources:
        mem_mb  = 20000,
        runtime = 180
    log:
        "logs/picard_markdup/{sample}.log"
    shell:
        "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[2]} CREATE_INDEX=true ASSUME_SORTED=true VALIDATION_STRINGENCY=SILENT 2> {log}"

rule base_recalibration:
    input:
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai",
    output:
        "bqsr/{sample}.recal.bam",
        "bqsr/{sample}.recal.bam.bai",
        "bqsr/{sample}.recal_data.table",
    params:
        reference = "resources/reference/genome.fa",
        known_sites_dbsnp = "resources/known_sites/dbsnp.vcf.gz",
        known_sites_mills = "resources/known_sites/mills_gold.vcf.gz",
        known_sites_1kg = "resources/known_sites/1000G_phase1.vcf.gz",
        java_opts = "-Xmx16g",
    threads: 8
    resources:
        mem_mb  = 20000,
        runtime = 300
    log:
        "logs/bqsr/{sample}.log"
    shell:
        "gatk --java-options '{params.java_opts}' BaseRecalibrator -I {input[0]} -R {params.reference} --known-sites {params.known_sites_dbsnp} --known-sites {params.known_sites_mills} --known-sites {params.known_sites_1kg} -O {output[2]} 2> {log[0]} && gatk --java-options '{params.java_opts}' ApplyBQSR -R {params.reference} -I {input[0]} --bqsr-recal-file {output[2]} -O {output[0]} 2>> {log[0]} 2> {log}"

rule haplotype_caller:
    input:
        "bqsr/{sample}.recal.bam",
        "bqsr/{sample}.recal.bam.bai",
    output:
        "gvcf/{sample}.g.vcf.gz",
        "gvcf/{sample}.g.vcf.gz.tbi",
    params:
        reference = "resources/reference/genome.fa",
        java_opts = "-Xmx16g",
    threads: 8
    resources:
        mem_mb  = 20000,
        runtime = 480
    log:
        "logs/haplotypecaller/{sample}.log"
    shell:
        "gatk --java-options '{params.java_opts}' HaplotypeCaller -R {params.reference} -I {input[0]} -O {output[0]} -ERC GVCF --tmp-dir tmp/ 2> {log}"

rule combine_gvcfs:
    input:
        "gvcf/all_samples.gvcf_list.txt"
    output:
        "joint/combined.g.vcf.gz",
        "joint/combined.g.vcf.gz.tbi",
    params:
        reference = "resources/reference/genome.fa",
        java_opts = "-Xmx32g",
    threads: 8
    resources:
        mem_mb  = 40000,
        runtime = 480
    log:
        "logs/combine_gvcfs/combined.log"
    shell:
        "gatk --java-options '{params.java_opts}' CombineGVCFs -R {params.reference} $(awk '{{print\"--variant\"$1}}' {input[0]}) -O {output[0]} 2> {log}"

rule genotype_gvcfs:
    input:
        r1 = "joint/combined.g.vcf.gz",
        r2 = "joint/combined.g.vcf.gz.tbi",
    output:
        "joint/genotyped.vcf.gz",
        "joint/genotyped.vcf.gz.tbi",
    params:
        reference = "resources/reference/genome.fa",
        java_opts = "-Xmx32g",
    threads: 8
    resources:
        mem_mb  = 40000,
        runtime = 300
    log:
        "logs/genotype_gvcfs/genotyped.log"
    shell:
        "gatk --java-options '{params.java_opts}' GenotypeGVCFs -R {params.reference} -V {input[0]} -O {output[0]} 2> {log}"

rule variant_filtration:
    input:
        r1 = "joint/genotyped.vcf.gz",
        r2 = "joint/genotyped.vcf.gz.tbi",
    output:
        "filtered/filtered.vcf.gz",
        "filtered/filtered.vcf.gz.tbi",
    params:
        reference = "resources/reference/genome.fa",
        snp_filter_expr = "QD < 2.0 || FS > 60.0 || MQ < 40.0 || MQRankSum < -12.5 || ReadPosRankSum < -8.0",
        snp_filter_name = "SNP_HARD_FILTER",
        indel_filter_expr = "QD < 2.0 || FS > 200.0 || ReadPosRankSum < -20.0",
        indel_filter_name = "INDEL_HARD_FILTER",
        java_opts = "-Xmx16g",
    threads: 8
    resources:
        mem_mb  = 20000,
        runtime = 180
    log:
        "logs/variant_filtration/filtered.log"
    shell:
        "gatk --java-options '{params.java_opts}' SelectVariants -R {params.reference} -V {input[0]} --select-type-to-include SNP -O filtered/snps_raw.vcf.gz 2> {log[0]} && gatk --java-options '{params.java_opts}' SelectVariants -R {params.reference} -V {input[0]} --select-type-to-include INDEL -O filtered/indels_raw.vcf.gz 2>> {log[0]} && gatk --java-options '{params.java_opts}' VariantFiltration -R {params.reference} -V filtered/snps_raw.vcf.gz --filter-expression '{params.snp_filter_expr}' --filter-name '{params.snp_filter_name}' -O filtered/snps_filtered.vcf.gz 2>> {log[0]} && gatk --java-options '{params.java_opts}' VariantFiltration -R {params.reference} -V filtered/indels_raw.vcf.gz --filter-expression '{params.indel_filter_expr}' --filter-name '{params.indel_filter_name}' -O filtered/indels_filtered.vcf.gz 2>> {log[0]} && gatk --java-options '{params.java_opts}' MergeVcfs I=filtered/snps_filtered.vcf.gz I=filtered/indels_filtered.vcf.gz O={output[0]} 2>> {log[0]} 2> {log}"

rule annotate_variants:
    input:
        r1 = "filtered/filtered.vcf.gz",
        r2 = "filtered/filtered.vcf.gz.tbi",
    output:
        "annotated/annotated.vcf.gz",
        "annotated/annotated.vcf.gz.tbi",
    params:
        dbsnp = "resources/known_sites/dbsnp.vcf.gz",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 120
    log:
        "logs/annotate_variants/annotated.log"
    shell:
        "bcftools annotate --threads {params.threads} -a {params.dbsnp} -c ID -O z -o {output[0]} {input[0]} 2> {log[0]} && bcftools index --tbi {output[0]} 2>> {log[0]} 2> {log}"

rule variant_qc:
    input:
        r1 = "annotated/annotated.vcf.gz",
        r2 = "annotated/annotated.vcf.gz.tbi",
    output:
        "qc/bcftools/variant_stats.txt",
    params:
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/bcftools_stats/variant_stats.log"
    shell:
        "bcftools stats --threads {params.threads} {input[0]} > {output[0]} 2> {log}"

rule multiqc_report:
    input:
        ancient("qc/fastqc"),
        ancient("logs/trimmomatic"),
        ancient("qc/picard"),
        "qc/bcftools/variant_stats.txt",
    output:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",
    params:
        outdir = "qc/multiqc",
        search_dirs = "qc/ logs/",
    threads: 2
    resources:
        mem_mb  = 4000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc {params.search_dirs} --outdir {params.outdir} --force 2> {log}"