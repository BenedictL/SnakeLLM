# SnakeLLM — chip-seq
# ChIP-seq pipeline for H3K27ac histone modification analysis using MACS2 broad peak calling with full QC, annotation, and differential binding steps.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        expand("results/motifs/{sample}/homerResults.html", sample=config["samples"]),
        expand("results/motifs/{sample}/knownResults.html", sample=config["samples"]),
        "results/multiqc/multiqc_report.html",
        "results/multiqc/multiqc_data",

rule raw_fastqc:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "results/fastqc/raw/{sample}_R1_fastqc.html",
        "results/fastqc/raw/{sample}_R1_fastqc.zip",
        "results/fastqc/raw/{sample}_R2_fastqc.html",
        "results/fastqc/raw/{sample}_R2_fastqc.zip",
    params:
        outdir = "results/fastqc/raw",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/raw/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "results/trimmed/{sample}_R1_trimmed.fastq.gz",
        "results/trimmed/{sample}_R1_unpaired.fastq.gz",
        "results/trimmed/{sample}_R2_trimmed.fastq.gz",
        "results/trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "config[adapters]",
        leading = 3,
        trailing = 3,
        slidingwindow = "4:15",
        minlen = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log}"

rule align_bowtie2:
    input:
        r1 = "results/trimmed/{sample}_R1_trimmed.fastq.gz",
        r2 = "results/trimmed/{sample}_R2_trimmed.fastq.gz",
    output:
        "results/aligned/{sample}.bam",
    params:
        index = "config[bowtie2_index]",
        threads = 8,
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 180
    log:
        "logs/bowtie2/{sample}.log"
    shell:
        "bowtie2 -p {params.threads} -x {params.index} -1 {input[0]} -2 {input[1]} 2> {log[0]} | samtools view -bS - | samtools sort -o {output[0]} - && samtools index {output[0]} 2> {log}"

rule filter_bam:
    input:
        "results/aligned/{sample}.bam"
    output:
        "results/filtered/{sample}.filtered.bam",
    params:
        mapq = 20,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/samtools/filter/{sample}.log"
    shell:
        "samtools view -b -q {params.mapq} -F 4 -@ {params.threads} {input[0]} > {output[0]} && samtools index {output[0]} 2> {log}"

rule remove_duplicates:
    input:
        "results/filtered/{sample}.filtered.bam"
    output:
        "results/dedup/{sample}.dedup.bam",
        "results/dedup/{sample}.dedup.metrics.txt",
    params:
        java_opts = "-Xmx8g",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/picard/{sample}.log"
    shell:
        "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[1]} REMOVE_DUPLICATES=true VALIDATION_STRINGENCY=LENIENT CREATE_INDEX=true 2> {log}"

rule call_peaks:
    input:
        "results/dedup/{sample}.dedup.bam",
        "results/dedup/{control}.dedup.bam",
    output:
        "results/peaks/{sample}_broad_peaks.broadPeak",
        "results/peaks/{sample}_broad_peaks.gappedPeak",
        "results/peaks/{sample}_broad_summits.bed",
    params:
        genome_size = "config[macs2_genome_size]",
        broad_cutoff = 0.1,
        outdir = "results/peaks",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/macs2/{sample}.log"
    shell:
        "macs2 callpeak -t {input[0]} -c {input[1]} -f BAMPE -g {params.genome_size} -n {wildcards.sample}_broad --broad --broad-cutoff {params.broad_cutoff} --outdir {params.outdir} 2> {log}"

rule create_bigwig:
    input:
        "results/dedup/{sample}.dedup.bam"
    output:
        "results/bigwig/{sample}.bw",
    params:
        threads = 8,
        bin_size = 10,
        normalize_using = "RPKM",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/deeptools/bamcoverage/{sample}.log"
    shell:
        "bamCoverage -b {input[0]} -o {output[0]} --binSize {params.bin_size} --normalizeUsing {params.normalize_using} -p {params.threads} 2> {log}"

rule peak_qc:
    input:
        "results/dedup/{sample}.dedup.bam",
        "results/dedup/{control}.dedup.bam",
    output:
        "results/qc/fingerprint/{sample}_fingerprint.png",
        "results/qc/fingerprint/{sample}_fingerprint_counts.tab",
    params:
        threads = 8,
        outdir = "results/qc/fingerprint",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/deeptools/fingerprint/{sample}.log"
    shell:
        "plotFingerprint -b {input[0]} {input[1]} --labels {wildcards.sample} {wildcards.control} -p {params.threads} --plotFile {output[0]} --outRawCounts {output[1]} 2> {log}"

rule annotate_peaks:
    input:
        "results/peaks/all_peaks_merged.broadPeak"
    output:
        "results/annotation/peak_annotation.csv",
        "results/annotation/peak_annotation_plots.pdf",
    params:
        txdb = "config[txdb]",
        organism_db = "config[organism_db]",
        promoter_upstream = 3000,
        promoter_downstream = 3000,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/chipseeker/annotate_peaks.log"
    shell:
        "Rscript scripts/run_chipseeker.R {input[0]} {output[0]} {output[1]} {params.txdb} {params.organism_db} {params.promoter_upstream} {params.promoter_downstream} 2> {log}"

rule diff_binding:
    input:
        "results/diffbind/sample_sheet.csv"
    output:
        "results/diffbind/diffbind_results.csv",
        "results/diffbind/diffbind_report.html",
    params:
        fdr_threshold = 0.05,
        fold_change = 1.5,
        organism_db = "config[organism_db]",
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 180
    log:
        "logs/diffbind/diffbind.log"
    shell:
        "Rscript scripts/run_diffbind.R {input[0]} {output[0]} {output[1]} {params.fdr_threshold} {params.fold_change} {params.organism_db} 2> {log}"

rule motif_analysis:
    input:
        "results/peaks/{sample}_broad_peaks.broadPeak"
    output:
        "results/motifs/{sample}/homerResults.html",
        "results/motifs/{sample}/knownResults.html",
    params:
        genome = "config[homer_genome]",
        size = 200,
        outdir = "results/motifs/{sample}",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 180
    log:
        "logs/homer/{sample}.log"
    shell:
        "findMotifsGenome.pl {input[0]} {params.genome} {params.outdir} -size {params.size} -mask 2> {log}"

rule multiqc_report:
    input:
        ancient("results/fastqc/raw"),
        ancient("results/trimmed"),
        ancient("results/dedup"),
        ancient("results/peaks"),
        ancient("results/qc/fingerprint"),
        "results/diffbind/diffbind_results.csv",
        "results/annotation/peak_annotation.csv",
    output:
        "results/multiqc/multiqc_report.html",
        "results/multiqc/multiqc_data",
    params:
        outdir = "results/multiqc",
        search_dirs = "results/",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc {params.search_dirs} --outdir {params.outdir} --force 2> {log}"