# SnakeLLM — wgs-variant-calling
# Whole genome sequencing germline variant calling pipeline following GATK4 Best Practices with HaplotypeCaller in GVCF mode and joint genotyping.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",

rule raw_fastqc:
    input:
        r1 = "data/raw/reads/{sample}_R1.fastq.gz",
        r2 = "data/raw/reads/{sample}_R2.fastq.gz",
    output:
        "qc/fastqc/{sample}_R1_fastqc.html",
        "qc/fastqc/{sample}_R1_fastqc.zip",
        "qc/fastqc/{sample}_R2_fastqc.html",
        "qc/fastqc/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/fastqc",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/reads/{sample}_R1.fastq.gz",
        r2 = "data/raw/reads/{sample}_R2.fastq.gz",
    output:
        "trimmed/{sample}_R1_paired.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2_paired.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "{config[adapters]}",
        leading = 3,
        trailing = 3,
        slidingwindow = "4:15",
        minlen = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 120
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log}"

rule align_bwa:
    input:
        r1 = "trimmed/{sample}_R1_paired.fastq.gz",
        r2 = "trimmed/{sample}_R2_paired.fastq.gz",
    output:
        "aligned/{sample}.bam",
    params:
        reference = "{config[reference]}",
        threads = 16,
        read_group = "@RG\tID:{wildcards.sample}\tSM:{wildcards.sample}\tPL:ILLUMINA\tLB:{wildcards.sample}\tPU:{wildcards.sample}",
    threads: 16
    resources:
        mem_mb  = 32000,
        runtime = 480
    log:
        "logs/bwa_mem2/{sample}.log"
    shell:
        "bwa-mem2 mem -t {params.threads} -R '{params.read_group}' {params.reference} {input[0]} {input[1]} | samtools view -bS - > {output[0]} 2> {log}"

rule sort_bam:
    input:
        "aligned/{sample}.bam"
    output:
        "sorted/{sample}.sorted.bam",
        "sorted/{sample}.sorted.bam.bai",
    params:
        threads = 8,
        mem_per_thread = "2G",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 180
    log:
        "logs/samtools_sort/{sample}.log"
    shell:
        "samtools sort -@ {params.threads} -m {params.mem_per_thread} -o {output[0]} {input[0]} 2> {log[0]} && samtools index {output[0]} 2>> {log[0]} 2> {log}"

rule mark_duplicates:
    input:
        "sorted/{sample}.sorted.bam"
    output:
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai",
        "dedup/{sample}.dedup.metrics.txt",
    params:
        java_opts = "-Xmx16g",
        validation_stringency = "SILENT",
    threads: 4
    resources:
        mem_mb  = 20000,
        runtime = 240
    log:
        "logs/picard_markdup/{sample}.log"
    shell:
        "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[2]} REMOVE_DUPLICATES=false VALIDATION_STRINGENCY={params.validation_stringency} CREATE_INDEX=true 2> {log[0]} && mv dedup/{wildcards.sample}.dedup.bai {output[1]} 2> {log}"

rule base_recalibration:
    input:
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai",
    output:
        "bqsr/{sample}.recal.bam",
        "bqsr/{sample}.recal.bam.bai",
        "bqsr/{sample}.recal.table",
    params:
        reference = "{config[reference]}",
        known_sites_dbsnp = "{config[known_sites_dbsnp]}",
        known_sites_mills = "{config[known_sites_mills]}",
        known_sites_1kg = "{config[known_sites_1kg]}",
        java_opts = "-Xmx16g",
    threads: 8
    resources:
        mem_mb  = 20000,
        runtime = 480
    log:
        "logs/bqsr/{sample}.log"
    shell:
        "gatk --java-options '{params.java_opts}' BaseRecalibrator -I {input[0]} -R {params.reference} --known-sites {params.known_sites_dbsnp} --known-sites {params.known_sites_mills} --known-sites {params.known_sites_1kg} -O {output[2]} 2> {log[0]} && gatk --java-options '{params.java_opts}' ApplyBQSR -I {input[0]} -R {params.reference} --bqsr-recal-file {output[2]} -O {output[0]} 2>> {log[0]} && samtools index {output[0]} 2>> {log[0]} 2> {log}"

rule haplotype_caller:
    input:
        "bqsr/{sample}.recal.bam",
        "bqsr/{sample}.recal.bam.bai",
    output:
        "gvcf/{sample}.g.vcf.gz",
        "gvcf/{sample}.g.vcf.gz.tbi",
    params:
        reference = "{config[reference]}",
        dbsnp = "{config[known_sites_dbsnp]}",
        java_opts = "-Xmx16g",
        emit_ref_confidence = "GVCF",
    threads: 8
    resources:
        mem_mb  = 20000,
        runtime = 720
    log:
        "logs/haplotypecaller/{sample}.log"
    shell:
        "gatk --java-options '{params.java_opts}' HaplotypeCaller -R {params.reference} -I {input[0]} -O {output[0]} -D {params.dbsnp} -ERC {params.emit_ref_confidence} --create-output-variant-index true 2> {log}"

rule combine_gvcfs:
    input:
        expand("gvcf/{sample}.g.vcf.gz", sample=config["samples"]),
    output:
        "combined/combined.g.vcf.gz",
        "combined/combined.g.vcf.gz.tbi",
    params:
        reference = "{config[reference]}",
        java_opts = "-Xmx32g",
        gvcf_inputs = "{config[gvcf_inputs]}",
    threads: 8
    resources:
        mem_mb  = 40000,
        runtime = 480
    log:
        "logs/combine_gvcfs/combined.log"
    shell:
        "gatk --java-options '{params.java_opts}' CombineGVCFs -R {params.reference} $(for f in {params.gvcf_inputs}; do echo \"--variant $f \"; done) -O {output[0]} 2> {log}"

rule genotype_gvcfs:
    input:
        r1 = "combined/combined.g.vcf.gz",
        r2 = "combined/combined.g.vcf.gz.tbi",
    output:
        "genotyped/genotyped.vcf.gz",
        "genotyped/genotyped.vcf.gz.tbi",
    params:
        reference = "{config[reference]}",
        dbsnp = "{config[known_sites_dbsnp]}",
        java_opts = "-Xmx32g",
    threads: 8
    resources:
        mem_mb  = 40000,
        runtime = 360
    log:
        "logs/genotype_gvcfs/genotyped.log"
    shell:
        "gatk --java-options '{params.java_opts}' GenotypeGVCFs -R {params.reference} -V {input[0]} -D {params.dbsnp} -O {output[0]} --create-output-variant-index true 2> {log}"

rule variant_filtration:
    input:
        r1 = "genotyped/genotyped.vcf.gz",
        r2 = "genotyped/genotyped.vcf.gz.tbi",
    output:
        "filtered/filtered.vcf.gz",
        "filtered/filtered.vcf.gz.tbi",
    params:
        reference = "{config[reference]}",
        java_opts = "-Xmx16g",
        snp_filter_expr = "QD < 2.0 || FS > 60.0 || MQ < 40.0 || MQRankSum < -12.5 || ReadPosRankSum < -8.0",
        snp_filter_name = "hard_snp_filter",
        indel_filter_expr = "QD < 2.0 || FS > 200.0 || ReadPosRankSum < -20.0",
        indel_filter_name = "hard_indel_filter",
    threads: 4
    resources:
        mem_mb  = 20000,
        runtime = 240
    log:
        "logs/variant_filtration/filtered.log"
    shell:
        "gatk --java-options '{params.java_opts}' SelectVariants -R {params.reference} -V {input[0]} --select-type-to-include SNP -O filtered/snps_raw.vcf.gz 2> {log[0]} && gatk --java-options '{params.java_opts}' VariantFiltration -R {params.reference} -V filtered/snps_raw.vcf.gz --filter-expression \"{params.snp_filter_expr}\" --filter-name \"{params.snp_filter_name}\" -O filtered/snps_filtered.vcf.gz 2>> {log[0]} && gatk --java-options '{params.java_opts}' SelectVariants -R {params.reference} -V {input[0]} --select-type-to-include INDEL -O filtered/indels_raw.vcf.gz 2>> {log[0]} && gatk --java-options '{params.java_opts}' VariantFiltration -R {params.reference} -V filtered/indels_raw.vcf.gz --filter-expression \"{params.indel_filter_expr}\" --filter-name \"{params.indel_filter_name}\" -O filtered/indels_filtered.vcf.gz 2>> {log[0]} && gatk --java-options '{params.java_opts}' MergeVcfs I=filtered/snps_filtered.vcf.gz I=filtered/indels_filtered.vcf.gz O={output[0]} 2>> {log[0]} 2> {log}"

rule annotate_variants:
    input:
        r1 = "filtered/filtered.vcf.gz",
        r2 = "filtered/filtered.vcf.gz.tbi",
    output:
        "annotated/annotated.vcf.gz",
        "annotated/annotated.vcf.gz.tbi",
    params:
        annotations_db = "{config[annotations_db]}",
        output_type = "z",
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 120
    log:
        "logs/annotate_variants/annotated.log"
    shell:
        "bcftools annotate -a {params.annotations_db} -O {params.output_type} -o {output[0]} {input[0]} 2> {log[0]} && bcftools index --tbi {output[0]} 2>> {log[0]} 2> {log}"

rule variant_qc:
    input:
        "annotated/annotated.vcf.gz"
    output:
        "qc/variant_stats/annotated.stats.txt",
    params:
        reference = "{config[reference]}",
    threads: 2
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/bcftools_stats/variant_stats.log"
    shell:
        "bcftools stats -F {params.reference} {input[0]} > {output[0]} 2> {log}"

rule multiqc_report:
    input:
        ancient("qc/fastqc"),
        ancient("logs/trimmomatic"),
        ancient("dedup"),
        ancient("logs/bqsr"),
        ancient("qc/variant_stats"),
    output:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",
    params:
        outdir = "qc/multiqc",
        search_dirs = "qc/fastqc logs/trimmomatic dedup logs/bqsr qc/variant_stats",
    threads: 2
    resources:
        mem_mb  = 4000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc {params.search_dirs} --outdir {params.outdir} --force 2> {log}"