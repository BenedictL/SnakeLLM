# SnakeLLM — atac-seq
# ATAC-seq chromatin accessibility pipeline with MACS2 peak calling and IDR reproducibility filtering across biological replicates.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",

rule raw_fastqc:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "qc/fastqc/{sample}_R1_fastqc.html",
        "qc/fastqc/{sample}_R1_fastqc.zip",
        "qc/fastqc/{sample}_R2_fastqc.html",
        "qc/fastqc/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/fastqc",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "config[nextera_adapters]",
        leading = 3,
        trailing = 3,
        sliding_window = "4:15",
        min_len = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.sliding_window} MINLEN:{params.min_len} 2> {log}"

rule align_bowtie2:
    input:
        r1 = "trimmed/{sample}_R1.fastq.gz",
        r2 = "trimmed/{sample}_R2.fastq.gz",
    output:
        "aligned/{sample}.bam",
    params:
        index = "config[bowtie2_index]",
        threads = 8,
        max_fragment_size = 2000,
        extra = "--very-sensitive",
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 180
    log:
        "logs/bowtie2/{sample}.log"
    shell:
        "bowtie2 -p {params.threads} -x {params.index} -X {params.max_fragment_size} {params.extra} -1 {input[0]} -2 {input[1]} 2> {log[0]} | samtools view -bS - | samtools sort -o {output[0]} - && samtools index {output[0]} 2> {log}"

rule filter_bam:
    input:
        "aligned/{sample}.bam"
    output:
        "filtered/{sample}.filtered.bam",
    params:
        mapq = 30,
        threads = 4,
        blacklist_chroms = "chrM",
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/samtools_filter/{sample}.log"
    shell:
        "samtools view -h -b -q {params.mapq} -F 1804 -f 2 {input[0]} | samtools view -b $(samtools view -H {input[0]} | grep '^@SQ' | grep -v '{params.blacklist_chroms}' | awk '{{gsub(\"SN:\",\"\",$2);printf$2\"\"}}') -o {output[0]} && samtools index {output[0]} 2> {log}"

rule remove_duplicates:
    input:
        "filtered/{sample}.filtered.bam"
    output:
        "deduped/{sample}.deduped.bam",
        "deduped/{sample}.dup_metrics.txt",
    params:
        java_opts = "-Xmx16g",
        remove_duplicates = "true",
        validation_stringency = "LENIENT",
    threads: 4
    resources:
        mem_mb  = 20000,
        runtime = 120
    log:
        "logs/picard/{sample}.log"
    shell:
        "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[1]} REMOVE_DUPLICATES={params.remove_duplicates} VALIDATION_STRINGENCY={params.validation_stringency} 2> {log[0]} && samtools index {output[0]} 2> {log}"

rule shift_reads:
    input:
        "deduped/{sample}.deduped.bam"
    output:
        "shifted/{sample}.shifted.bam",
    params:
        threads = 8,
        shift_plus = 4,
        shift_minus = -5,
        ATACshift = "--ATACshift",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/deeptools_shift/{sample}.log"
    shell:
        "alignmentSieve --numberOfProcessors {params.threads} --ATACshift --bam {input[0]} --outFile {output[0]} 2> {log[0]} && samtools sort -o {output[0]}.sorted.bam {output[0]} && mv {output[0]}.sorted.bam {output[0]} && samtools index {output[0]} 2> {log}"

rule call_peaks:
    input:
        "shifted/{sample}.shifted.bam"
    output:
        "peaks/{sample}_peaks.narrowPeak",
        "peaks/{sample}_summits.bed",
        "peaks/{sample}_peaks.xls",
    params:
        outdir = "peaks",
        genome_size = "config[macs2_genome_size]",
        nomodel = "--nomodel",
        shift = -100,
        extsize = 200,
        qvalue = 0.05,
        keep_dup = "all",
        call_summits = "--call-summits",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/macs2/{sample}.log"
    shell:
        "macs2 callpeak -t {input[0]} -n {wildcards.sample} --outdir {params.outdir} -g {params.genome_size} {params.nomodel} --shift {params.shift} --extsize {params.extsize} -q {params.qvalue} --keep-dup {params.keep_dup} {params.call_summits} 2> {log}"

rule create_bigwig:
    input:
        "shifted/{sample}.shifted.bam"
    output:
        "bigwig/{sample}.bw",
    params:
        threads = 8,
        bin_size = 10,
        normalize_using = "RPGC",
        effective_genome_size = "config[effective_genome_size]",
        extra = "--extendReads",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/bamcoverage/{sample}.log"
    shell:
        "bamCoverage --numberOfProcessors {params.threads} --bam {input[0]} --outFileName {output[0]} --binSize {params.bin_size} --normalizeUsing {params.normalize_using} --effectiveGenomeSize {params.effective_genome_size} {params.extra} 2> {log}"

rule peak_qc:
    input:
        "shifted/{sample}.shifted.bam",
        "peaks/{sample}_peaks.narrowPeak",
    output:
        "qc/ataqv/{sample}.ataqv.json.gz",
        "qc/ataqv/{sample}.ataqv.out",
    params:
        tss_file = "config[tss_bed]",
        organism = "config[organism]",
        excluded_region_file = "config[blacklist_bed]",
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/ataqv/{sample}.log"
    shell:
        "ataqv --tss-file {params.tss_file} --excluded-region-file {params.excluded_region_file} --metrics-file {output[0]} {params.organism} {input[0]} --peak-file {input[1]} > {output[1]} 2> {log}"

rule idr_filter:
    input:
        "peaks/{rep1}_peaks.narrowPeak",
        "peaks/{rep2}_peaks.narrowPeak",
    output:
        "idr/{rep1}_vs_{rep2}_idr_peaks.txt",
        "idr/{rep1}_vs_{rep2}_idr_peaks.narrowPeak",
    params:
        idr_threshold = 0.05,
        rank = "signal.value",
        soft_idr_threshold = 0.1,
        plot = "--plot",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/idr/{rep1}_vs_{rep2}.log"
    shell:
        "idr --samples {input[0]} {input[1]} --input-file-type narrowPeak --rank {params.rank} --output-file {output[0]} --soft-idr-threshold {params.soft_idr_threshold} --idr-threshold {params.idr_threshold} {params.plot} --log-output-file {log[0]} && awk 'BEGIN{{OFS=\"\t\"}} $12 >= -log(0.05)/log(10) {{print$0}}' {output[0]} > {output[1]} 2> {log}"

rule annotate_peaks:
    input:
        "idr/all_idr_peaks.narrowPeak"
    output:
        "annotation/peak_annotation.tsv",
        "annotation/peak_annotation_plots.pdf",
    params:
        genome_build = "config[genome_build]",
        txdb = "config[txdb_package]",
        org_db = "config[org_db]",
        promoter_upstream = 3000,
        promoter_downstream = 3000,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/chipseeker/annotate_peaks.log"
    shell:
        "Rscript scripts/annotate_peaks.R --peaks {input[0]} --genome {params.genome_build} --txdb {params.txdb} --org_db {params.org_db} --upstream {params.promoter_upstream} --downstream {params.promoter_downstream} --output_table {output[0]} --output_plots {output[1]} 2> {log}"

rule motif_analysis:
    input:
        "idr/all_idr_peaks.narrowPeak"
    output:
        "motifs/motif_enrichment.txt",
        "motifs/motif_enrichment.html",
    params:
        genome = "config[genome_build]",
        motif_db = "config[homer_motif_db]",
        size = 200,
        threads = 8,
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 180
    log:
        "logs/motif_analysis/motif_analysis.log"
    shell:
        "findMotifsGenome.pl {input[0]} {params.genome} motifs/ -size {params.size} -p {params.threads} -mknown {params.motif_db} 2> {log[0]} && cp motifs/knownResults.html {output[1]} && cp motifs/knownResults.txt {output[0]} 2> {log}"

rule multiqc_report:
    input:
        ancient("qc/fastqc"),
        ancient("logs/trimmomatic"),
        ancient("logs/bowtie2"),
        ancient("deduped"),
        ancient("qc/ataqv"),
        "motifs/knownResults.txt",
        "annotation/peak_annotation.tsv",
    output:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",
    params:
        outdir = "qc/multiqc",
        dirs = "qc/fastqc logs/trimmomatic logs/bowtie2 deduped qc/ataqv",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc {params.dirs} --outdir {params.outdir} --filename multiqc_report.html --force 2> {log}"