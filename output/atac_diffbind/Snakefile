# SnakeLLM — atac-seq
# ATAC-seq pipeline for genome-wide open chromatin profiling with differential accessibility analysis using DiffBind.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",

rule raw_fastqc:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "qc/fastqc/raw/{sample}_R1_fastqc.html",
        "qc/fastqc/raw/{sample}_R2_fastqc.html",
        "qc/fastqc/raw/{sample}_R1_fastqc.zip",
        "qc/fastqc/raw/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/fastqc/raw",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc/raw/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "resources/NexteraPE-PE.fa",
        leading = 3,
        trailing = 3,
        slidingwindow = "4:15",
        minlen = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10:8:true LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log}"

rule align_bowtie2:
    input:
        r1 = "trimmed/{sample}_R1.fastq.gz",
        r2 = "trimmed/{sample}_R2.fastq.gz",
    output:
        "aligned/{sample}.bam",
    params:
        index = "resources/bowtie2_index/genome",
        threads = 8,
        maxins = 2000,
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 180
    log:
        "logs/bowtie2/{sample}.log"
    shell:
        "bowtie2 -p {params.threads} -X {params.maxins} --very-sensitive -x {params.index} -1 {input[0]} -2 {input[1]} 2> {log[0]} | samtools view -bS - | samtools sort -o {output[0]} - && samtools index {output[0]} 2> {log}"

rule filter_bam:
    input:
        "aligned/{sample}.bam"
    output:
        "filtered/{sample}.filtered.bam",
        "filtered/{sample}.filtered.bam.bai",
    params:
        mapq = 30,
        blacklist = "resources/blacklist.bed",
        chrM = "chrM",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/samtools/filter/{sample}.log"
    shell:
        "samtools view -b -F 1804 -f 2 -q {params.mapq} {input[0]} | samtools view -b -L /dev/stdin | grep -v {params.chrM} || samtools view -h -F 1804 -f 2 -q {params.mapq} {input[0]} | grep -v \"\t{params.chrM}\t\" | samtools view -bS - | samtools sort -@ {params.threads} -o {output[0]} - && samtools index {output[0]} 2> {log}"

rule remove_duplicates:
    input:
        "filtered/{sample}.filtered.bam"
    output:
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai",
        "qc/picard/{sample}.dup_metrics.txt",
    params:
        java_opts = "-Xmx8g",
    threads: 4
    resources:
        mem_mb  = 12000,
        runtime = 120
    log:
        "logs/picard/{sample}.log"
    shell:
        "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[2]} REMOVE_DUPLICATES=true VALIDATION_STRINGENCY=LENIENT 2> {log[0]} && samtools index {output[0]} 2> {log}"

rule shift_reads:
    input:
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai",
    output:
        "shifted/{sample}.shifted.bam",
        "shifted/{sample}.shifted.bam.bai",
    params:
        threads = 4,
        shift_forward = 4,
        shift_reverse = -5,
        blacklist = "resources/blacklist.bed",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/deeptools/alignmentSieve/{sample}.log"
    shell:
        "alignmentSieve --numberOfProcessors {params.threads} --ATACshift --blackListFileName {params.blacklist} --bam {input[0]} -o {output[0]} 2> {log[0]} && samtools index {output[0]} 2> {log}"

rule call_peaks:
    input:
        "shifted/{sample}.shifted.bam"
    output:
        "peaks/{sample}/{sample}_peaks.narrowPeak",
        "peaks/{sample}/{sample}_summits.bed",
        "peaks/{sample}/{sample}_peaks.xls",
    params:
        genome_size = "hs",
        outdir = "peaks/{sample}",
        name = "{sample}",
        shift = -100,
        extsize = 200,
        qvalue = 0.05,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/macs2/{sample}.log"
    shell:
        "macs2 callpeak -t {input[0]} -f BAM -g {params.genome_size} --nomodel --shift {params.shift} --extsize {params.extsize} -q {params.qvalue} --keep-dup all -n {params.name} --outdir {params.outdir} 2> {log}"

rule create_bigwig:
    input:
        "shifted/{sample}.shifted.bam",
        "shifted/{sample}.shifted.bam.bai",
    output:
        "bigwig/{sample}.bw",
    params:
        threads = 4,
        binsize = 10,
        normalize = "RPKM",
        blacklist = "resources/blacklist.bed",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/deeptools/bamCoverage/{sample}.log"
    shell:
        "bamCoverage --numberOfProcessors {params.threads} --bam {input[0]} --outFileName {output[0]} --outFileFormat bigwig --binSize {params.binsize} --normalizeUsing {params.normalize} --blackListFileName {params.blacklist} --extendReads 2> {log}"

rule peak_qc:
    input:
        "filtered/{sample}.filtered.bam",
        "shifted/{sample}.shifted.bam",
        "peaks/{sample}/{sample}_peaks.narrowPeak",
    output:
        "qc/ataqv/{sample}.ataqv.json",
        "qc/ataqv/{sample}.ataqv.txt",
    params:
        tss_file = "resources/tss.bed",
        organism = "human",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/ataqv/{sample}.log"
    shell:
        "ataqv --tss-file {params.tss_file} --peak-file {input[2]} --metrics-file {output[0]} {params.organism} {input[1]} > {output[1]} 2> {log}"

rule diff_accessibility:
    input:
        "results/diffbind/samplesheet.csv"
    output:
        "results/diffbind/diffbind_results.csv",
        "results/diffbind/diffbind_report.html",
    params:
        fdr_threshold = 0.05,
        fold_change = 1.5,
        min_overlap = 2,
        score_method = "TMM",
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 240
    log:
        "logs/diffbind/diffbind.log"
    shell:
        "Rscript scripts/run_diffbind.R --samplesheet {input[0]} --output_csv {output[0]} --output_report {output[1]} --fdr {params.fdr_threshold} --fold_change {params.fold_change} --min_overlap {params.min_overlap} --score_method {params.score_method} 2> {log}"

rule annotate_peaks:
    input:
        "results/diffbind/diffbind_results.csv"
    output:
        "results/chipseeker/peak_annotation.csv",
        "results/chipseeker/peak_annotation_plots.pdf",
    params:
        txdb = "TxDb.Hsapiens.UCSC.hg38.knownGene",
        organism_db = "org.Hs.eg.db",
        tss_region_start = -3000,
        tss_region_end = 3000,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/chipseeker/annotate_peaks.log"
    shell:
        "Rscript scripts/run_chipseeker.R --peaks {input[0]} --output_csv {output[0]} --output_plots {output[1]} --txdb {params.txdb} --orgdb {params.organism_db} --tss_start {params.tss_region_start} --tss_end {params.tss_region_end} 2> {log}"

rule multiqc_report:
    input:
        ancient("qc/fastqc/raw"),
        ancient("logs/trimmomatic"),
        ancient("logs/bowtie2"),
        ancient("qc/picard"),
        ancient("qc/ataqv"),
        "results/chipseeker/peak_annotation.csv",
    output:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",
    params:
        outdir = "qc/multiqc",
        title = "ATAC-seq QC Report",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc --force --title \"{params.title}\" --outdir {params.outdir} qc/fastqc/raw logs/trimmomatic logs/bowtie2 qc/picard qc/ataqv 2> {log}"