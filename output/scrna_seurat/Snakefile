# SnakeLLM — scrna-seq
# Single-cell RNA-seq analysis using STARsolo for alignment and UMI counting followed by Seurat-based QC, normalization, clustering, marker gene identification, cell type annotation with SingleR, and pseudobulk differential expression with DESeq2.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "results/pseudobulk/deseq2_results.csv",
        "plots/pseudobulk/volcano_plot.pdf",
        "plots/pseudobulk/ma_plot.pdf",

rule starsolo_align:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "starsolo/{sample}/Aligned.sortedByCoord.out.bam",
        "starsolo/{sample}/Solo.out/GeneFull/filtered/matrix.mtx",
        "starsolo/{sample}/Solo.out/GeneFull/filtered/barcodes.tsv",
        "starsolo/{sample}/Solo.out/GeneFull/filtered/features.tsv",
    params:
        genome_dir = "{config[genome_dir]}",
        whitelist = "{config[barcode_whitelist]}",
        cb_len = "{config[cb_len]}",
        umi_len = "{config[umi_len]}",
        threads = 8,
        solo_cell_filter = "EmptyDrops_CR",
    threads: 8
    resources:
        mem_mb  = 40000,
        runtime = 240
    log:
        "logs/starsolo/{sample}.log"
    shell:
        "STAR --runThreadN {params.threads} --genomeDir {params.genome_dir} --readFilesIn {input[1]} {input[0]} --readFilesCommand zcat --soloType CB_UMI_Simple --soloCBwhitelist {params.whitelist} --soloCBLen {params.cb_len} --soloUMILen {params.umi_len} --soloFeatures GeneFull --soloCellFilter {params.solo_cell_filter} --outSAMtype BAM SortedByCoordinate --outSAMattributes NH HI nM AS CR UR CB UB GX GN sS sQ sM --outFileNamePrefix starsolo/{wildcards.sample}/ 2> {log}"

rule seurat_qc:
    input:
        "starsolo/{sample}/Solo.out/GeneFull/filtered/matrix.mtx",
        "starsolo/{sample}/Solo.out/GeneFull/filtered/barcodes.tsv",
        "starsolo/{sample}/Solo.out/GeneFull/filtered/features.tsv",
    output:
        "seurat/{sample}/seurat_qc.rds",
    params:
        min_cells = "{config[min_cells]}",
        min_features = "{config[min_features]}",
        max_features = "{config[max_features]}",
        max_mt_pct = "{config[max_mt_pct]}",
        mt_pattern = "{config[mt_pattern]}",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/seurat_qc/{sample}.log"
    shell:
        "Rscript scripts/seurat_qc.R --matrix_dir starsolo/{wildcards.sample}/Solo.out/GeneFull/filtered --sample {wildcards.sample} --min_cells {params.min_cells} --min_features {params.min_features} --max_features {params.max_features} --max_mt_pct {params.max_mt_pct} --mt_pattern {params.mt_pattern} --output {output[0]} 2> {log}"

rule seurat_normalize:
    input:
        "seurat/{sample}/seurat_qc.rds"
    output:
        "seurat/{sample}/seurat_normalized.rds",
    params:
        normalization_method = "{config[normalization_method]}",
        scale_factor = "{config[scale_factor]}",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/seurat_normalize/{sample}.log"
    shell:
        "Rscript scripts/seurat_normalize.R --input {input[0]} --normalization_method {params.normalization_method} --scale_factor {params.scale_factor} --output {output[0]} 2> {log}"

rule seurat_hvg:
    input:
        "seurat/{sample}/seurat_normalized.rds"
    output:
        "seurat/{sample}/seurat_hvg.rds",
    params:
        n_hvgs = "{config[n_hvgs]}",
        hvg_method = "{config[hvg_method]}",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/seurat_hvg/{sample}.log"
    shell:
        "Rscript scripts/seurat_hvg.R --input {input[0]} --n_hvgs {params.n_hvgs} --hvg_method {params.hvg_method} --output {output[0]} 2> {log}"

rule seurat_dimred:
    input:
        "seurat/{sample}/seurat_hvg.rds"
    output:
        "seurat/{sample}/seurat_dimred.rds",
        "plots/{sample}/pca_elbow.pdf",
        "plots/{sample}/umap.pdf",
    params:
        n_pcs = "{config[n_pcs]}",
        umap_dims = "{config[umap_dims]}",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/seurat_dimred/{sample}.log"
    shell:
        "Rscript scripts/seurat_dimred.R --input {input[0]} --n_pcs {params.n_pcs} --umap_dims {params.umap_dims} --output {output[0]} --pca_plot {output[1]} --umap_plot {output[2]} 2> {log}"

rule seurat_cluster:
    input:
        "seurat/{sample}/seurat_dimred.rds"
    output:
        "seurat/{sample}/seurat_clustered.rds",
        "plots/{sample}/umap_clusters.pdf",
    params:
        resolution = "{config[cluster_resolution]}",
        algorithm = "{config[cluster_algorithm]}",
        dims = "{config[umap_dims]}",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/seurat_cluster/{sample}.log"
    shell:
        "Rscript scripts/seurat_cluster.R --input {input[0]} --resolution {params.resolution} --algorithm {params.algorithm} --dims {params.dims} --output {output[0]} --umap_plot {output[1]} 2> {log}"

rule seurat_markers:
    input:
        "seurat/{sample}/seurat_clustered.rds"
    output:
        "results/{sample}/cluster_markers.csv",
        "plots/{sample}/marker_dotplot.pdf",
    params:
        test_method = "{config[marker_test]}",
        logfc_threshold = "{config[logfc_threshold]}",
        min_pct = "{config[min_pct]}",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/seurat_markers/{sample}.log"
    shell:
        "Rscript scripts/seurat_markers.R --input {input[0]} --test_method {params.test_method} --logfc_threshold {params.logfc_threshold} --min_pct {params.min_pct} --output {output[0]} --dotplot {output[1]} 2> {log}"

rule singler_annotate:
    input:
        "seurat/{sample}/seurat_clustered.rds",
        "results/{sample}/cluster_markers.csv",
    output:
        "seurat/{sample}/seurat_annotated.rds",
        "results/{sample}/cell_type_annotations.csv",
        "plots/{sample}/umap_celltypes.pdf",
    params:
        reference = "{config[singler_reference]}",
        organism = "{config[organism]}",
    threads: 4
    resources:
        mem_mb  = 32000,
        runtime = 90
    log:
        "logs/singler/{sample}.log"
    shell:
        "Rscript scripts/singler_annotate.R --input {input[0]} --markers {input[1]} --reference {params.reference} --organism {params.organism} --output_seurat {output[0]} --output_annotations {output[1]} --umap_plot {output[2]} 2> {log}"

rule pseudobulk_deseq2:
    input:
        "seurat/all_samples_annotated.rds"
    output:
        "results/pseudobulk/deseq2_results.csv",
        "plots/pseudobulk/volcano_plot.pdf",
        "plots/pseudobulk/ma_plot.pdf",
    params:
        condition_col = "{config[condition_col]}",
        ref_condition = "{config[ref_condition]}",
        fdr_threshold = "{config[fdr_threshold]}",
        lfc_threshold = "{config[lfc_threshold]}",
    threads: 4
    resources:
        mem_mb  = 32000,
        runtime = 120
    log:
        "logs/deseq2/pseudobulk.log"
    shell:
        "Rscript scripts/pseudobulk_deseq2.R --input {input[0]} --condition_col {params.condition_col} --ref_condition {params.ref_condition} --fdr_threshold {params.fdr_threshold} --lfc_threshold {params.lfc_threshold} --output {output[0]} --volcano {output[1]} --ma_plot {output[2]} 2> {log}"