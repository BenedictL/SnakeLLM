    shell:
        "STAR --runThreadN {params.threads} --genomeDir {params.genome_dir} --readFilesIn {input[0]} {input[1]} --readFilesCommand zcat --outSAMtype BAM Unsorted --outSAMattributes NH HI AS NM MD --outFileNamePrefix {params.out_prefix} --runMode alignReads 2> {log}"

