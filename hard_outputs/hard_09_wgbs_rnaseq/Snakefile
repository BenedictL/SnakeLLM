# SnakeLLM — wgbs-methylation-analysis
# Whole genome bisulfite sequencing pipeline for CpG methylation profiling, DMR calling with DSS, CpG island annotation, and integration with matched RNA-seq gene expression data.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",

rule raw_fastqc:
    input:
        r1 = "data/raw/wgbs/{sample}_R1.fastq.gz",
        r2 = "data/raw/wgbs/{sample}_R2.fastq.gz",
    output:
        "qc/raw_fastqc/{sample}_R1_fastqc.html",
        "qc/raw_fastqc/{sample}_R2_fastqc.html",
        "qc/raw_fastqc/{sample}_R1_fastqc.zip",
        "qc/raw_fastqc/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/raw_fastqc",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/raw_fastqc/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule bismark_genome_prepare:
    input:
        "resources/genome"
    output:
        "resources/genome/Bisulfite_Genome/CT_conversion/genome_mfa.CT_conversion.fa",
        "resources/genome/Bisulfite_Genome/GA_conversion/genome_mfa.GA_conversion.fa",
    params:
        genome_dir = "resources/genome",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 32000,
        runtime = 180
    log:
        "logs/bismark_genome_prepare/genome_prepare.log"
    shell:
        "bismark_genome_preparation --parallel {params.threads} {params.genome_dir} 2> {log}"

rule raw_fastqc_rnaseq:
    input:
        r1 = "data/raw/rnaseq/{sample}_R1.fastq.gz",
        r2 = "data/raw/rnaseq/{sample}_R2.fastq.gz",
    output:
        "qc/raw_fastqc_rnaseq/{sample}_R1_fastqc.html",
        "qc/raw_fastqc_rnaseq/{sample}_R2_fastqc.html",
        "qc/raw_fastqc_rnaseq/{sample}_R1_fastqc.zip",
        "qc/raw_fastqc_rnaseq/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/raw_fastqc_rnaseq",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/raw_fastqc_rnaseq/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trim_reads:
    input:
        r1 = "data/raw/wgbs/{sample}_R1.fastq.gz",
        r2 = "data/raw/wgbs/{sample}_R2.fastq.gz",
    output:
        "trimmed/wgbs/{sample}_R1_trimmed.fastq.gz",
        "trimmed/wgbs/{sample}_R1_unpaired.fastq.gz",
        "trimmed/wgbs/{sample}_R2_trimmed.fastq.gz",
        "trimmed/wgbs/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "resources/adapters.fa",
        leading = 3,
        trailing = 3,
        sliding_window = "4:15",
        min_len = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/wgbs/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.sliding_window} MINLEN:{params.min_len} 2> {log}"

rule trim_reads_rnaseq:
    input:
        r1 = "data/raw/rnaseq/{sample}_R1.fastq.gz",
        r2 = "data/raw/rnaseq/{sample}_R2.fastq.gz",
    output:
        "trimmed/rnaseq/{sample}_R1_trimmed.fastq.gz",
        "trimmed/rnaseq/{sample}_R1_unpaired.fastq.gz",
        "trimmed/rnaseq/{sample}_R2_trimmed.fastq.gz",
        "trimmed/rnaseq/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "resources/adapters.fa",
        leading = 3,
        trailing = 3,
        sliding_window = "4:15",
        min_len = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/rnaseq/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.sliding_window} MINLEN:{params.min_len} 2> {log}"

rule bismark_align:
    input:
        "trimmed/wgbs/{sample}_R1_trimmed.fastq.gz",
        "trimmed/wgbs/{sample}_R2_trimmed.fastq.gz",
        "resources/genome/Bisulfite_Genome/CT_conversion/genome_mfa.CT_conversion.fa",
    output:
        "aligned/wgbs/{sample}_bismark_bt2_pe.bam",
        "aligned/wgbs/{sample}_bismark_bt2_PE_report.txt",
    params:
        genome_dir = "resources/genome",
        outdir = "aligned/wgbs",
        threads = 8,
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 360
    log:
        "logs/bismark_align/{sample}.log"
    shell:
        "bismark --genome {params.genome_dir} -1 {input[0]} -2 {input[1]} --output_dir {params.outdir} --parallel {params.threads} 2> {log}"

rule post_trim_fastqc:
    input:
        r1 = "trimmed/wgbs/{sample}_R1_trimmed.fastq.gz",
        r2 = "trimmed/wgbs/{sample}_R2_trimmed.fastq.gz",
    output:
        "qc/post_trim_fastqc/{sample}_R1_trimmed_fastqc.html",
        "qc/post_trim_fastqc/{sample}_R2_trimmed_fastqc.html",
        "qc/post_trim_fastqc/{sample}_R1_trimmed_fastqc.zip",
        "qc/post_trim_fastqc/{sample}_R2_trimmed_fastqc.zip",
    params:
        outdir = "qc/post_trim_fastqc",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/post_trim_fastqc/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule star_align:
    input:
        r1 = "trimmed/rnaseq/{sample}_R1_trimmed.fastq.gz",
        r2 = "trimmed/rnaseq/{sample}_R2_trimmed.fastq.gz",
    output:
        "aligned/rnaseq/{sample}/Aligned.sortedByCoord.out.bam",
        "aligned/rnaseq/{sample}/Log.final.out",
    params:
        genome_dir = "resources/star_index",
        outdir_prefix = "aligned/rnaseq/{sample}/",
        threads = 8,
        outSAMtype = "BAM SortedByCoordinate",
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 180
    log:
        "logs/star_align/{sample}.log"
    shell:
        "STAR --runThreadN {params.threads} --genomeDir {params.genome_dir} --readFilesIn {input[0]} {input[1]} --readFilesCommand zcat --outSAMtype {params.outSAMtype} --outFileNamePrefix {params.outdir_prefix} 2> {log}"

rule samtools_sort:
    input:
        "aligned/wgbs/{sample}_bismark_bt2_pe.bam"
    output:
        "sorted/wgbs/{sample}_sorted.bam",
    params:
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/samtools_sort/{sample}.log"
    shell:
        "samtools sort -@ {params.threads} -o {output[0]} {input[0]} 2> {log}"

rule featurecounts:
    input:
        "counts/rnaseq_bam_list.txt"
    output:
        "counts/all_samples_counts.txt",
        "counts/all_samples_counts.txt.summary",
    params:
        gtf = "resources/annotation.gtf",
        threads = 8,
        strandedness = 0,
        paired_end = True,
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/featurecounts/featurecounts.log"
    shell:
        "featureCounts -T {params.threads} -s {params.strandedness} -p -a {params.gtf} -o {output[0]} $(cat {input[0]}) 2> {log}"

rule bismark_deduplicate:
    input:
        "sorted/wgbs/{sample}_sorted.bam"
    output:
        "dedup/wgbs/{sample}_sorted.deduplicated.bam",
        "dedup/wgbs/{sample}_sorted.deduplication_report.txt",
    params:
        outdir = "dedup/wgbs",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/bismark_deduplicate/{sample}.log"
    shell:
        "deduplicate_bismark --paired --bam --output_dir {params.outdir} {input[0]} 2> {log}"

rule deseq2_expression:
    input:
        "counts/all_samples_counts.txt"
    output:
        "expression/deseq2_results.csv",
        "expression/deseq2_normalized_counts.csv",
        "expression/deseq2_pca.pdf",
    params:
        condition_col = "condition",
        reference_level = "control",
        fdr_threshold = 0.05,
        lfc_threshold = 1.0,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/deseq2/deseq2.log"
    shell:
        "Rscript scripts/deseq2_expression.R --counts {input[0]} --results {output[0]} --normalized {output[1]} --pca {output[2]} --condition_col {params.condition_col} --reference_level {params.reference_level} --fdr {params.fdr_threshold} --lfc {params.lfc_threshold} 2> {log}"

rule bismark_methylation_extractor:
    input:
        "dedup/wgbs/{sample}_sorted.deduplicated.bam"
    output:
        "methylation/{sample}/CpG_OT_{sample}_sorted.deduplicated.txt",
        "methylation/{sample}/CpG_OB_{sample}_sorted.deduplicated.txt",
        "methylation/{sample}/{sample}_sorted.deduplicated_splitting_report.txt",
        "methylation/{sample}/{sample}_sorted.deduplicated.M-bias.txt",
    params:
        outdir = "methylation/{sample}",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 180
    log:
        "logs/bismark_methylation_extractor/{sample}.log"
    shell:
        "bismark_methylation_extractor --paired-end --comprehensive --CpG_only --gzip --parallel {params.threads} --output {params.outdir} {input[0]} 2> {log}"

rule bismark2bedgraph:
    input:
        "methylation/{sample}/CpG_OT_{sample}_sorted.deduplicated.txt",
        "methylation/{sample}/CpG_OB_{sample}_sorted.deduplicated.txt",
    output:
        "bedgraph/{sample}/{sample}.bedGraph.gz",
        "bedgraph/{sample}/{sample}.bismark.cov.gz",
    params:
        outdir = "bedgraph/{sample}",
        outfile = "{sample}.bedGraph",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/bismark2bedgraph/{sample}.log"
    shell:
        "bismark2bedGraph --output {params.outfile} --dir {params.outdir} --CX_context --zero_based {input[0]} {input[1]} 2> {log}"

rule coverage2cytosine:
    input:
        "bedgraph/{sample}/{sample}.bismark.cov.gz",
        "resources/genome/Bisulfite_Genome/CT_conversion/genome_mfa.CT_conversion.fa",
    output:
        "cytosine_reports/{sample}/{sample}.CpG_report.txt.gz",
    params:
        genome_dir = "resources/genome",
        outdir = "cytosine_reports/{sample}",
        outfile = "{sample}.CpG_report.txt",
    threads: 2
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/coverage2cytosine/{sample}.log"
    shell:
        "coverage2cytosine --genome_folder {params.genome_dir} --output {params.outfile} --dir {params.outdir} --gzip --CpG_only {input[0]} 2> {log}"

rule dss_dmr_calling:
    input:
        "cytosine_reports/all_samples_cytosine_reports.txt"
    output:
        "dmr/dss_dmr_results.txt",
        "dmr/dss_dml_results.txt",
    params:
        condition_col = "condition",
        min_cov = 5,
        delta = 0.1,
        p_threshold = 0.05,
        smoothing = True,
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 240
    log:
        "logs/dss_dmr_calling/dss_dmr.log"
    shell:
        "Rscript scripts/dss_dmr_calling.R --input {input[0]} --dmr_output {output[0]} --dml_output {output[1]} --condition_col {params.condition_col} --min_cov {params.min_cov} --delta {params.delta} --p_threshold {params.p_threshold} 2> {log}"

rule cpg_island_annotation:
    input:
        "dmr/dss_dmr_results.txt",
        "resources/cpg_islands.bed",
    output:
        "annotation/dmr_cpg_island_annotated.bed",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/cpg_island_annotation/annotation.log"
    shell:
        "bedmap --echo --echo-map --fraction-map 0.5 --delim '\t' <(awk 'NR>1 {print$1\"\t\"$2\"\t\"$3\"\t\"$0}' {input[0]} | sort-bed -) <(sort-bed {input[1]}) > {output[0]} 2> {log}"

rule methylation_expression_integration:
    input:
        "annotation/dmr_cpg_island_annotated.bed",
        "expression/deseq2_results.csv",
    output:
        "integration/methylation_expression_correlation.txt",
        "integration/methylation_expression_plot.pdf",
    params:
        correlation_method = "spearman",
        gene_window_bp = 5000,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/integration/methylation_expression.log"
    shell:
        "Rscript scripts/methylation_expression_integration.R --dmr {input[0]} --expression {input[1]} --output {output[0]} --plot {output[1]} --method {params.correlation_method} --window {params.gene_window_bp} 2> {log}"

rule multiqc:
    input:
        ancient("qc/raw_fastqc"),
        ancient("qc/post_trim_fastqc"),
        ancient("qc/raw_fastqc_rnaseq"),
        ancient("aligned/wgbs"),
        ancient("dedup/wgbs"),
        ancient("methylation"),
        ancient("aligned/rnaseq"),
        "counts/all_samples_counts.txt.summary",
    output:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",
    params:
        outdir = "qc/multiqc",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc qc/raw_fastqc qc/post_trim_fastqc qc/raw_fastqc_rnaseq aligned/wgbs dedup/wgbs methylation aligned/rnaseq counts/ --outdir {params.outdir} 2> {log}"