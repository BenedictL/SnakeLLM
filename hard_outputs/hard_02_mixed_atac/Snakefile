# SnakeLLM — atac-seq
# Mixed single-end and paired-end ATAC-seq pipeline with automatic library type detection, Bowtie2 alignment, mitochondrial filtering, duplicate removal, MACS2 peak calling, IDR reproducibility filtering, and DiffBind differential accessibility analysis.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        expand("bigwig/{sample}.bw", sample=config["samples"]),
        "results/chipseeker/peak_annotation.csv",
        "results/chipseeker/peak_annotation_plots.pdf",
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",

rule fastqc_raw:
    input:
        "data/raw/{sample}_R1.fastq.gz"
    output:
        "qc/fastqc_raw/{sample}_R1_fastqc.html",
        "qc/fastqc_raw/{sample}_R1_fastqc.zip",
    params:
        outdir = "qc/fastqc_raw",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc_raw/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input} 2> {log}"

rule fastp_trim:
    input:
        "data/raw/{sample}_R1.fastq.gz"
    output:
        "trimmed/{sample}_R1.fastq.gz",
        "qc/fastp/{sample}.json",
        "qc/fastp/{sample}.html",
    params:
        adapter_sequence = "CTGTCTCTTATACACATCT",
        adapter_sequence_r2 = "CTGTCTCTTATACACATCT",
        threads = 4,
        min_length = 25,
        paired_end = "{config[paired_end]}",
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/fastp/{sample}.log"
    shell:
        "if [ \"{params.paired_end}\" = \"True\" ] && [ -f data/raw/{wildcards.sample}_R2.fastq.gz ]; then fastp --thread {params.threads} --in1 data/raw/{wildcards.sample}_R1.fastq.gz --in2 data/raw/{wildcards.sample}_R2.fastq.gz --out1 trimmed/{wildcards.sample}_R1.fastq.gz --out2 trimmed/{wildcards.sample}_R2.fastq.gz --adapter_sequence {params.adapter_sequence} --adapter_sequence_r2 {params.adapter_sequence_r2} --length_required {params.min_length} --json {output[1]} --html {output[2]} 2>{log[0]}; else fastp --thread {params.threads} --in1 data/raw/{wildcards.sample}_R1.fastq.gz --out1 trimmed/{wildcards.sample}_R1.fastq.gz --adapter_sequence {params.adapter_sequence} --length_required {params.min_length} --json {output[1]} --html {output[2]} 2>{log[0]}; fi 2> {log}"

rule bowtie2_align:
    input:
        "trimmed/{sample}_R1.fastq.gz"
    output:
        "aligned/{sample}.bam",
        "logs/bowtie2/{sample}.log",
    params:
        index = "{config[bowtie2_index]}",
        threads = 8,
        paired_end = "{config[paired_end]}",
        max_fragment_size = 2000,
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 180
    log:
        "logs/bowtie2/{sample}.log"
    shell:
        "if [ \"{params.paired_end}\" = \"True\" ] && [ -f trimmed/{wildcards.sample}_R2.fastq.gz ]; then bowtie2 -p {params.threads} -X {params.max_fragment_size} --no-mixed --no-discordant -x {params.index} -1 trimmed/{wildcards.sample}_R1.fastq.gz -2 trimmed/{wildcards.sample}_R2.fastq.gz 2>{output[1]} | samtools view -bS - > {output[0]}; else bowtie2 -p {params.threads} -x {params.index} -U trimmed/{wildcards.sample}_R1.fastq.gz 2>{output[1]} | samtools view -bS - > {output[0]}; fi 2> {log}"

rule fastqc_post:
    input:
        "trimmed/{sample}_R1.fastq.gz"
    output:
        "qc/fastqc_post/{sample}_R1_fastqc.html",
        "qc/fastqc_post/{sample}_R1_fastqc.zip",
    params:
        outdir = "qc/fastqc_post",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc_post/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input} 2> {log}"

rule samtools_filter:
    input:
        "aligned/{sample}.bam"
    output:
        "filtered/{sample}.bam",
    params:
        mapq = 30,
        threads = 4,
        chrM_name = "{config[chrM_name]}",
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/samtools_filter/{sample}.log"
    shell:
        "samtools view -h -b -q {params.mapq} -F 4 {input[0]} | samtools view -h -b - $(samtools view -H {input[0]} | grep '^@SQ' | grep -v '{params.chrM_name}' | sed 's/.*SN://;s/\t.*//' | tr '\n' ' ') > {output[0]} 2> {log}"

rule samtools_sort_index:
    input:
        "filtered/{sample}.bam"
    output:
        "sorted/{sample}.bam",
        "sorted/{sample}.bam.bai",
    params:
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/samtools_sort_index/{sample}.log"
    shell:
        "samtools sort -@ {params.threads} -o {output[0]} {input[0]} 2>{log[0]} && samtools index {output[0]} 2>>{log[0]} 2> {log}"

rule picard_markdup:
    input:
        "sorted/{sample}.bam"
    output:
        "deduped/{sample}.bam",
        "qc/picard/{sample}.MarkDuplicates.metrics",
    params:
        java_mem = "8g",
        remove_duplicates = "true",
        validation_stringency = "LENIENT",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/picard/{sample}.log"
    shell:
        "picard -Xmx{params.java_mem} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[1]} REMOVE_DUPLICATES={params.remove_duplicates} VALIDATION_STRINGENCY={params.validation_stringency} 2>{log[0]} && samtools index {output[0]} 2>>{log[0]} 2> {log}"

rule deeptools_shift:
    input:
        "deduped/{sample}.bam",
        "deduped/{sample}.bam.bai",
    output:
        "shifted/{sample}.bam",
        "shifted/{sample}.bam.bai",
    params:
        threads = 4,
        shift_forward = 4,
        shift_reverse = -5,
        paired_end = "{config[paired_end]}",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/deeptools_shift/{sample}.log"
    shell:
        "if [ \"{params.paired_end}\" = \"True\" ]; then alignmentSieve --numberOfProcessors {params.threads} --ATACshift --bam {input[0]} -o {output[0]} 2>{log[0]}; else alignmentSieve --numberOfProcessors {params.threads} --ATACshift --bam {input[0]} -o {output[0]} 2>{log[0]}; fi && samtools sort -@ {params.threads} -o {output[0]}.tmp.bam {output[0]} && mv {output[0]}.tmp.bam {output[0]} && samtools index {output[0]} 2>>{log[0]} 2> {log}"

rule ataqv_qc:
    input:
        "shifted/{sample}.bam",
        "shifted/{sample}.bam.bai",
    output:
        "qc/ataqv/{sample}.json.gz",
        "qc/ataqv/{sample}.ataqv.out",
    params:
        organism = "{config[organism]}",
        tss_file = "{config[tss_bed]}",
        peak_file = "peaks/{sample}_peaks.narrowPeak",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/ataqv/{sample}.log"
    shell:
        "ataqv --peak-file {params.peak_file} --tss-file {params.tss_file} --metrics-file {output[0]} {params.organism} {input[0]} > {output[1]} 2> {log}"

rule deeptools_bigwig:
    input:
        "shifted/{sample}.bam",
        "shifted/{sample}.bam.bai",
    output:
        "bigwig/{sample}.bw",
    params:
        threads = 4,
        bin_size = 10,
        normalize_using = "RPKM",
        effective_genome_size = "{config[effective_genome_size]}",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/deeptools_bigwig/{sample}.log"
    shell:
        "bamCoverage --bam {input[0]} --outFileName {output[0]} --outFileFormat bigwig --binSize {params.bin_size} --normalizeUsing {params.normalize_using} --effectiveGenomeSize {params.effective_genome_size} --numberOfProcessors {params.threads} 2> {log}"

rule macs2_callpeak:
    input:
        "shifted/{sample}.bam"
    output:
        "peaks/{sample}_peaks.narrowPeak",
        "peaks/{sample}_summits.bed",
    params:
        genome_size = "{config[macs2_genome_size]}",
        outdir = "peaks",
        pvalue = "0.01",
        paired_end = "{config[paired_end]}",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/macs2/{sample}.log"
    shell:
        "if [ \"{params.paired_end}\" = \"True\" ] && [ -f shifted/{wildcards.sample}_R2.fastq.gz ]; then macs2 callpeak -t {input[0]} -f BAMPE -g {params.genome_size} -n {wildcards.sample} --outdir {params.outdir} --nomodel --shift -100 --extsize 200 --call-summits -p {params.pvalue} 2>{log[0]}; else macs2 callpeak -t {input[0]} -f BAM -g {params.genome_size} -n {wildcards.sample} --outdir {params.outdir} --nomodel --shift -100 --extsize 200 --call-summits -p {params.pvalue} 2>{log[0]}; fi 2> {log}"

rule idr_filter:
    input:
        "peaks/{rep1}_peaks.narrowPeak",
        "peaks/{rep2}_peaks.narrowPeak",
    output:
        "idr/{condition}_idr_peaks.txt",
    params:
        threshold = 0.05,
        rank = "signal.value",
        peak_type = "narrowPeak",
        output_file_type = "narrowPeak",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/idr/{condition}.log"
    shell:
        "idr --samples {input[0]} {input[1]} --peak-list {input[0]} --input-file-type {params.peak_type} --output-file {output[0]} --output-file-type {params.output_file_type} --rank {params.rank} --soft-idr-threshold {params.threshold} --use-best-multisummit-IDR 2> {log}"

rule diffbind:
    input:
        "idr/all_idr_peaks_merged.txt",
        "diffbind_samplesheet.csv",
    output:
        "results/diffbind/diffbind_results.csv",
        "results/diffbind/diffbind_report.html",
    params:
        fdr_cutoff = 0.05,
        fc_cutoff = 1.5,
        min_overlap = 2,
        organism_db = "{config[organism_db]}",
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 180
    log:
        "logs/diffbind/diffbind.log"
    shell:
        "Rscript scripts/run_diffbind.R {input[1]} {input[0]} {output[0]} {output[1]} {params.fdr_cutoff} {params.fc_cutoff} {params.min_overlap} {params.organism_db} 2> {log}"

rule chipseeker_annotate:
    input:
        "results/diffbind/diffbind_results.csv"
    output:
        "results/chipseeker/peak_annotation.csv",
        "results/chipseeker/peak_annotation_plots.pdf",
    params:
        txdb = "{config[txdb]}",
        organism_db = "{config[organism_db]}",
        tss_upstream = 3000,
        tss_downstream = 3000,
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/chipseeker/chipseeker.log"
    shell:
        "Rscript scripts/run_chipseeker.R {input[0]} {output[0]} {output[1]} {params.txdb} {params.organism_db} {params.tss_upstream} {params.tss_downstream} 2> {log}"

rule multiqc:
    input:
        ancient("qc/fastqc_raw"),
        ancient("qc/fastqc_post"),
        ancient("qc/fastp"),
        ancient("logs/bowtie2"),
        ancient("qc/picard"),
        ancient("qc/ataqv"),
        "results/diffbind/diffbind_report.html",
    output:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",
    params:
        outdir = "qc/multiqc",
        title = "ATAC-seq QC Report",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc qc/fastqc_raw qc/fastqc_post qc/fastp logs/bowtie2 qc/picard qc/ataqv results/diffbind --outdir {params.outdir} --title \"{params.title}\" --force 2> {log}"