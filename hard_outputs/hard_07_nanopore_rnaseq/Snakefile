# SnakeLLM — rna-seq-de-long-read-nanopore
# Long-read Oxford Nanopore RNA-seq pipeline with splice-aware minimap2 alignment, featureCounts quantification, DESeq2 differential expression, and cross-platform comparison against matched short-read Illumina results.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",

rule fastqc_raw_nanopore:
    input:
        "data/raw/nanopore/{sample}.fastq.gz"
    output:
        "qc/fastqc/nanopore/{sample}_fastqc.html",
        "qc/fastqc/nanopore/{sample}_fastqc.zip",
    params:
        outdir = "qc/fastqc/nanopore",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc_raw_nanopore/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} 2> {log}"

rule nanostat:
    input:
        "data/raw/nanopore/{sample}.fastq.gz"
    output:
        "qc/nanostat/{sample}_nanostat.txt",
    params:
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/nanostat/{sample}.log"
    shell:
        "NanoStat --fastq {input[0]} --threads {params.threads} --outdir qc/nanostat --name {wildcards.sample}_nanostat.txt 2> {log}"

rule fastqc_raw_illumina:
    input:
        r1 = "data/raw/illumina/{sample}_R1.fastq.gz",
        r2 = "data/raw/illumina/{sample}_R2.fastq.gz",
    output:
        "qc/fastqc/illumina/raw/{sample}_R1_fastqc.html",
        "qc/fastqc/illumina/raw/{sample}_R1_fastqc.zip",
        "qc/fastqc/illumina/raw/{sample}_R2_fastqc.html",
        "qc/fastqc/illumina/raw/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/fastqc/illumina/raw",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc_raw_illumina/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule minimap2_align:
    input:
        "data/raw/nanopore/{sample}.fastq.gz"
    output:
        "aligned/nanopore/{sample}.sam",
    params:
        genome = "resources/genome.fa",
        preset = "splice",
        extra_flags = "-uf -k14",
        threads = 8,
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 180
    log:
        "logs/minimap2/{sample}.log"
    shell:
        "minimap2 -ax {params.preset} {params.extra_flags} -t {params.threads} {params.genome} {input[0]} > {output[0]} 2> {log}"

rule trim_reads_illumina:
    input:
        r1 = "data/raw/illumina/{sample}_R1.fastq.gz",
        r2 = "data/raw/illumina/{sample}_R2.fastq.gz",
    output:
        "trimmed/illumina/{sample}_R1.fastq.gz",
        "trimmed/illumina/{sample}_R1_unpaired.fastq.gz",
        "trimmed/illumina/{sample}_R2.fastq.gz",
        "trimmed/illumina/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "resources/adapters.fa",
        leading = 3,
        trailing = 3,
        slidingwindow = "4:15",
        minlen = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trim_reads_illumina/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log}"

rule samtools_sort_index_nanopore:
    input:
        "aligned/nanopore/{sample}.sam"
    output:
        "aligned/nanopore/{sample}.sorted.bam",
        "aligned/nanopore/{sample}.sorted.bam.bai",
    params:
        threads = 4,
        mem_per_thread = "2G",
    threads: 4
    resources:
        mem_mb  = 12000,
        runtime = 90
    log:
        "logs/samtools_sort_index_nanopore/{sample}.log"
    shell:
        "samtools sort -@ {params.threads} -m {params.mem_per_thread} -o {output[0]} {input[0]} 2> {log[0]} && samtools index {output[0]} 2>> {log[0]} 2> {log}"

rule fastqc_post_trim_illumina:
    input:
        r1 = "trimmed/illumina/{sample}_R1.fastq.gz",
        r2 = "trimmed/illumina/{sample}_R2.fastq.gz",
    output:
        "qc/fastqc/illumina/trimmed/{sample}_R1_fastqc.html",
        "qc/fastqc/illumina/trimmed/{sample}_R1_fastqc.zip",
        "qc/fastqc/illumina/trimmed/{sample}_R2_fastqc.html",
        "qc/fastqc/illumina/trimmed/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/fastqc/illumina/trimmed",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc_post_trim_illumina/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule featurecounts_nanopore:
    input:
        "counts/nanopore/bam_list.txt"
    output:
        "counts/nanopore/counts_matrix.txt",
        "counts/nanopore/counts_matrix.txt.summary",
    params:
        gtf = "resources/annotation.gtf",
        threads = 8,
        strandedness = "{config[strandedness]}",
        feature_type = "exon",
        attribute_type = "gene_id",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/featurecounts_nanopore/featurecounts.log"
    shell:
        "bams=$(cat {input[0]}) && featureCounts -L -T {params.threads} -s {params.strandedness} -t {params.feature_type} -g {params.attribute_type} -a {params.gtf} -o {output[0]} $bams 2> {log}"

rule star_align:
    input:
        r1 = "trimmed/illumina/{sample}_R1.fastq.gz",
        r2 = "trimmed/illumina/{sample}_R2.fastq.gz",
    output:
        "aligned/illumina/{sample}/Aligned.sortedByCoord.out.bam",
    params:
        genome_dir = "resources/star_index",
        threads = 8,
        outdir_prefix = "aligned/illumina/{sample}/",
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 120
    log:
        "logs/star_align/{sample}.log"
    shell:
        "STAR --runThreadN {params.threads} --genomeDir {params.genome_dir} --readFilesIn {input[0]} {input[1]} --readFilesCommand zcat --outSAMtype BAM SortedByCoordinate --outFileNamePrefix {params.outdir_prefix} --outSAMattributes NH HI AS NM MD 2> {log}"

rule deseq2_nanopore:
    input:
        "counts/nanopore/counts_matrix.txt"
    output:
        "results/deseq2/nanopore/de_results.csv",
        "results/deseq2/nanopore/ma_plot.pdf",
        "results/deseq2/nanopore/pca_plot.pdf",
        "results/deseq2/nanopore/normalized_counts.csv",
    params:
        design_formula = "~condition",
        alpha = 0.05,
        lfc_threshold = 1.0,
        condition_col = "condition",
        reference_level = "control",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/deseq2_nanopore/deseq2.log"
    shell:
        "Rscript scripts/deseq2_analysis.R --counts {input[0]} --outdir results/deseq2/nanopore --design \"{params.design_formula}\" --alpha {params.alpha} --lfc_threshold {params.lfc_threshold} --condition_col {params.condition_col} --reference_level {params.reference_level} 2> {log}"

rule samtools_sort_index_illumina:
    input:
        "aligned/illumina/{sample}/Aligned.sortedByCoord.out.bam"
    output:
        "aligned/illumina/{sample}.sorted.bam",
        "aligned/illumina/{sample}.sorted.bam.bai",
    params:
        threads = 4,
        mem_per_thread = "2G",
    threads: 4
    resources:
        mem_mb  = 12000,
        runtime = 60
    log:
        "logs/samtools_sort_index_illumina/{sample}.log"
    shell:
        "samtools sort -@ {params.threads} -m {params.mem_per_thread} -o {output[0]} {input[0]} 2> {log[0]} && samtools index {output[0]} 2>> {log[0]} 2> {log}"

rule featurecounts_illumina:
    input:
        "counts/illumina/bam_list.txt"
    output:
        "counts/illumina/counts_matrix.txt",
        "counts/illumina/counts_matrix.txt.summary",
    params:
        gtf = "resources/annotation.gtf",
        threads = 8,
        strandedness = "{config[strandedness]}",
        paired_end = "{config[paired_end]}",
        feature_type = "exon",
        attribute_type = "gene_id",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/featurecounts_illumina/featurecounts.log"
    shell:
        "pe_flag= && bams=$(cat {input[0]}) && featureCounts $pe_flag -T {params.threads} -s {params.strandedness} -t {params.feature_type} -g {params.attribute_type} -a {params.gtf} -o {output[0]} $bams 2> {log}"

rule deseq2_illumina:
    input:
        "counts/illumina/counts_matrix.txt"
    output:
        "results/deseq2/illumina/de_results.csv",
        "results/deseq2/illumina/ma_plot.pdf",
        "results/deseq2/illumina/pca_plot.pdf",
        "results/deseq2/illumina/normalized_counts.csv",
    params:
        design_formula = "~condition",
        alpha = 0.05,
        lfc_threshold = 1.0,
        condition_col = "condition",
        reference_level = "control",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 60
    log:
        "logs/deseq2_illumina/deseq2.log"
    shell:
        "Rscript scripts/deseq2_analysis.R --counts {input[0]} --outdir results/deseq2/illumina --design \"{params.design_formula}\" --alpha {params.alpha} --lfc_threshold {params.lfc_threshold} --condition_col {params.condition_col} --reference_level {params.reference_level} 2> {log}"

rule cross_platform_comparison:
    input:
        "results/deseq2/nanopore/de_results.csv",
        "results/deseq2/illumina/de_results.csv",
        "counts/nanopore/counts_matrix.txt",
        "counts/illumina/counts_matrix.txt",
    output:
        "results/comparison/lfc_concordance_plot.pdf",
        "results/comparison/venn_diagram_degs.pdf",
        "results/comparison/count_correlation_plot.pdf",
        "results/comparison/platform_comparison_summary.csv",
    params:
        alpha = 0.05,
        lfc_threshold = 1.0,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/cross_platform_comparison/comparison.log"
    shell:
        "Rscript scripts/cross_platform_comparison.R --nano_de {input[0]} --illumina_de {input[1]} --nano_counts {input[2]} --illumina_counts {input[3]} --outdir results/comparison --alpha {params.alpha} --lfc_threshold {params.lfc_threshold} 2> {log}"

rule multiqc_report:
    input:
        ancient("qc/fastqc/nanopore"),
        ancient("qc/nanostat"),
        ancient("qc/fastqc/illumina/raw"),
        ancient("qc/fastqc/illumina/trimmed"),
        ancient("aligned/nanopore"),
        ancient("aligned/illumina"),
        "counts/nanopore/counts_matrix.txt.summary",
        "counts/illumina/counts_matrix.txt.summary",
    output:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",
    params:
        outdir = "qc/multiqc",
        title = "Long-read Nanopore vs Short-read Illumina RNA-seq QC Report",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc qc/fastqc/nanopore qc/nanostat qc/fastqc/illumina/raw qc/fastqc/illumina/trimmed aligned/nanopore aligned/illumina counts/nanopore counts/illumina --outdir {params.outdir} --title \"{params.title}\" --force 2> {log}"