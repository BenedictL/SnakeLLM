    params:
        out_dir = "results/clustering",
        resolution = "{config[clustering_resolution]}",
        algorithm = "{config[clustering_algorithm]}",
        dims = "{config[umap_dims]}",
    threads: 8
    resources:
        mem_mb  = 32000,
        runtime = 60
    log:
        "logs/clustering/clustering.log"
    shell:
        "Rscript scripts/run_clustering.R --input={input[0]} --out_dir={params.out_dir} --resolution={params.resolution} --algorithm={params.algorithm} --dims={params.dims} 2> {log}"

rule marker_genes:
    input:
        "results/clustering/seurat_clustered.rds"
