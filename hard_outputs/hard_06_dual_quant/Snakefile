# SnakeLLM — rna-seq-de-dual-quantification
# Bulk RNA-seq differential expression pipeline running STAR/featureCounts and Salmon/alevin quantification in parallel, with DESeq2 applied to each path independently and results compared via MultiQC.

configfile: "config.yaml"
samples = config["samples"]

rule all:
    input:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",

rule fastqc_raw:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "qc/fastqc_raw/{sample}_R1_fastqc.html",
        "qc/fastqc_raw/{sample}_R1_fastqc.zip",
        "qc/fastqc_raw/{sample}_R2_fastqc.html",
        "qc/fastqc_raw/{sample}_R2_fastqc.zip",
    params:
        outdir = "qc/fastqc_raw",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc_raw/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule trimmomatic:
    input:
        r1 = "data/raw/{sample}_R1.fastq.gz",
        r2 = "data/raw/{sample}_R2.fastq.gz",
    output:
        "trimmed/{sample}_R1_paired.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2_paired.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz",
    params:
        adapters = "resources/adapters.fa",
        leading = 3,
        trailing = 3,
        slidingwindow = "4:15",
        minlen = 36,
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 90
    log:
        "logs/trimmomatic/{sample}.log"
    shell:
        "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log}"

rule fastqc_trimmed:
    input:
        r1 = "trimmed/{sample}_R1_paired.fastq.gz",
        r2 = "trimmed/{sample}_R2_paired.fastq.gz",
    output:
        "qc/fastqc_trimmed/{sample}_R1_paired_fastqc.html",
        "qc/fastqc_trimmed/{sample}_R1_paired_fastqc.zip",
        "qc/fastqc_trimmed/{sample}_R2_paired_fastqc.html",
        "qc/fastqc_trimmed/{sample}_R2_paired_fastqc.zip",
    params:
        outdir = "qc/fastqc_trimmed",
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 4000,
        runtime = 60
    log:
        "logs/fastqc_trimmed/{sample}.log"
    shell:
        "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log}"

rule salmon_alevin:
    input:
        r1 = "trimmed/{sample}_R1_paired.fastq.gz",
        r2 = "trimmed/{sample}_R2_paired.fastq.gz",
    output:
        "salmon/{sample}/quant.sf",
        "salmon/{sample}/lib_format_counts.json",
    params:
        index = "resources/salmon_index",
        libtype = "A",
        threads = 8,
        outdir = "salmon/{sample}",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/salmon_alevin/{sample}.log"
    shell:
        "salmon quant --index {params.index} --libType {params.libtype} -1 {input[0]} -2 {input[1]} --validateMappings --threads {params.threads} --output {params.outdir} 2> {log}"

rule star_align:
    input:
        r1 = "trimmed/{sample}_R1_paired.fastq.gz",
        r2 = "trimmed/{sample}_R2_paired.fastq.gz",
    output:
        "star/{sample}/Aligned.out.bam",
        "star/{sample}/Log.final.out",
    params:
        genome_dir = "resources/star_index",
        threads = 8,
        outdir_prefix = "star/{sample}/",
    threads: 8
    resources:
        mem_mb  = 40000,
        runtime = 180
    log:
        "logs/star/{sample}.log"
    shell:
        "STAR --runThreadN {params.threads} --genomeDir {params.genome_dir} --readFilesIn {input[0]} {input[1]} --readFilesCommand zcat --outSAMtype BAM Unsorted --outSAMattributes NH HI AS NM MD --outFileNamePrefix {params.outdir_prefix} 2> {log}"

rule tximeta_deseq2_salmon:
    input:
        "salmon/sample_paths.txt"
    output:
        "results/deseq2_salmon/deseq2_salmon_results.csv",
        "results/deseq2_salmon/deseq2_salmon_normalized_counts.csv",
        "results/deseq2_salmon/deseq2_salmon_ma_plot.pdf",
        "results/deseq2_salmon/deseq2_salmon_volcano_plot.pdf",
    params:
        condition_col = "condition",
        ref_level = "control",
        alpha = 0.05,
        lfc_threshold = 1.0,
        sample_sheet = "config/sample_sheet.csv",
        tx2gene = "resources/tx2gene.csv",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/deseq2_salmon/deseq2_salmon.log"
    shell:
        "Rscript scripts/tximeta_deseq2_salmon.R --salmon_paths {input[0]} --sample_sheet {params.sample_sheet} --tx2gene {params.tx2gene} --condition {params.condition_col} --ref_level {params.ref_level} --alpha {params.alpha} --lfc_threshold {params.lfc_threshold} --outdir results/deseq2_salmon 2> {log}"

rule samtools_sort_index:
    input:
        "star/{sample}/Aligned.out.bam"
    output:
        "star/{sample}/Aligned.sortedByCoord.bam",
        "star/{sample}/Aligned.sortedByCoord.bam.bai",
    params:
        threads = 4,
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 60
    log:
        "logs/samtools/{sample}.log"
    shell:
        "samtools sort -@ {params.threads} -o {output[0]} {input[0]} && samtools index {output[0]} 2> {log}"

rule featurecounts:
    input:
        "counts/bam_list.txt"
    output:
        "counts/featurecounts_all.txt",
        "counts/featurecounts_all.txt.summary",
    params:
        gtf = "resources/annotation.gtf",
        strandedness = "{config[strandedness]}",
        threads = 8,
        paired_end_flag = "{config[paired_end]}",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 120
    log:
        "logs/featurecounts/featurecounts.log"
    shell:
        "featureCounts -s {params.strandedness} -T {params.threads} -a {params.gtf} -o {output[0]} $(cat {input[0]}) 2> {log}"

rule deseq2_featurecounts:
    input:
        "counts/featurecounts_all.txt"
    output:
        "results/deseq2_featurecounts/deseq2_fc_results.csv",
        "results/deseq2_featurecounts/deseq2_fc_normalized_counts.csv",
        "results/deseq2_featurecounts/deseq2_fc_ma_plot.pdf",
        "results/deseq2_featurecounts/deseq2_fc_volcano_plot.pdf",
    params:
        condition_col = "condition",
        ref_level = "control",
        alpha = 0.05,
        lfc_threshold = 1.0,
        sample_sheet = "config/sample_sheet.csv",
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 90
    log:
        "logs/deseq2_featurecounts/deseq2_fc.log"
    shell:
        "Rscript scripts/deseq2_featurecounts.R --counts {input[0]} --sample_sheet {params.sample_sheet} --condition {params.condition_col} --ref_level {params.ref_level} --alpha {params.alpha} --lfc_threshold {params.lfc_threshold} --outdir results/deseq2_featurecounts 2> {log}"

rule results_comparison:
    input:
        "results/deseq2_featurecounts/deseq2_fc_results.csv",
        "results/deseq2_salmon/deseq2_salmon_results.csv",
    output:
        "results/comparison/fc_vs_salmon_concordance.csv",
        "results/comparison/fc_vs_salmon_lfc_correlation.pdf",
        "results/comparison/fc_vs_salmon_venn.pdf",
        "results/comparison/fc_vs_salmon_summary.txt",
    params:
        alpha = 0.05,
        lfc_threshold = 1.0,
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 30
    log:
        "logs/results_comparison/comparison.log"
    shell:
        "Rscript scripts/results_comparison.R --fc_results {input[0]} --salmon_results {input[1]} --alpha {params.alpha} --lfc_threshold {params.lfc_threshold} --outdir results/comparison 2> {log}"

rule multiqc:
    input:
        ancient("qc/fastqc_raw"),
        ancient("qc/fastqc_trimmed"),
        ancient("logs/trimmomatic"),
        ancient("star"),
        ancient("salmon"),
        "counts/featurecounts_all.txt.summary",
        ancient("results/deseq2_featurecounts"),
        ancient("results/deseq2_salmon"),
        ancient("results/comparison"),
    output:
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data",
    params:
        outdir = "qc/multiqc",
        title = "Dual Quantification RNA-seq QC Report",
    threads: 2
    resources:
        mem_mb  = 8000,
        runtime = 30
    log:
        "logs/multiqc/multiqc.log"
    shell:
        "multiqc --force --title \"{params.title}\" --outdir {params.outdir} qc/fastqc_raw qc/fastqc_trimmed logs/trimmomatic star salmon counts results/comparison 2> {log}"